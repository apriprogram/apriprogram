    <!-- Top Nav -->
    <header class="h-16 flex items-center justify-between px-6 border-b border-slate-200 dark:border-brand-border bg-white dark:bg-brand-dark z-10 sticky top-0">
      <div class="flex items-center gap-4">
        <button id="toggle-sidebar" class="w-8 h-8 flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition focus:outline-none">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
        <h2 class="text-base font-semibold text-slate-900 dark:text-white tracking-wide" id="pageTitle">Dasbor</h2>
      </div>

      <!-- Middle: Search -->
      <div class="hidden md:flex flex-1 max-w-md mx-6">
        <div class="relative w-full">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="w-4 h-4 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <input type="text" id="global-search" onkeyup="handleGlobalSearch(this.value)" class="w-full bg-slate-100 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white text-sm rounded-lg focus:border-brand-blue block pl-10 p-2.5 transition-colors placeholder-slate-400 dark:placeholder-slate-500 outline-none" placeholder="Pencarian cepat...">
        </div>
      </div>

      <!-- Right Side: Actions -->
      <div class="flex items-center gap-1 sm:gap-2">
        <!-- View Website -->
        <a href="/" target="_blank" title="Lihat Website" class="w-8 h-8 sm:w-9 sm:h-9 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
        </a>
        
        <!-- Dark Mode Toggle -->
        <button onclick="toggleDarkMode()" class="w-8 h-8 sm:w-9 sm:h-9 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition">
          <!-- Moon Icon (shows in light mode) -->
          <svg class="w-4 h-4 block dark:hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3a9 9 0 109 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 01-4.4 2.26 5.403 5.403 0 01-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
          <!-- Sun Icon (shows in dark mode) -->
          <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </button>
        
        <!-- Notification -->
        <button class="w-8 h-8 sm:w-9 sm:h-9 rounded-full flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition relative">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/></svg>
          <span class="absolute top-1.5 right-1.5 sm:top-1 sm:right-1 w-2 h-2 bg-red-500 rounded-full border border-white dark:border-brand-darker"></span>
        </button>
        
        <!-- Profile Dropdown -->
        <div class="relative group cursor-pointer flex items-center gap-2 ml-1 sm:ml-2">
          <div class="w-8 h-8 rounded-lg bg-slate-200 dark:bg-brand-card flex items-center justify-center text-white font-bold text-sm overflow-hidden border border-slate-300 dark:border-brand-border">
            <img src="<%= user.avatar ? user.avatar : 'https://ui-avatars.com/api/?name=' + user.email + '&background=3b82f6&color=fff' %>" alt="Profile" class="w-full h-full object-cover">
          </div>
          <div class="hidden sm:flex items-center gap-2 text-left">
            <div class="flex flex-col">
              <span class="text-xs font-semibold text-slate-900 dark:text-white"><%= user.full_name ? user.full_name : user.email.split('@')[0] %></span>
              <span class="text-[10px] font-medium text-slate-500 capitalize"><%= user.role || 'Super Admin' %></span>
            </div>
            <svg class="w-4 h-4 text-slate-400 dark:text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
          </div>
          
          <div class="absolute right-0 top-full mt-3 w-56 bg-white dark:bg-[#1A1A1A] border border-slate-200 dark:border-white/10 rounded-2xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.3)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 p-2">
            
            <a href="#" onclick="switchTab('profile'); event.preventDefault();" class="flex items-center gap-3 px-3 py-2.5 text-[13.5px] font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-xl transition-colors">
              <svg class="w-4 h-4 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              Profile Settings
            </a>
            
            <a href="#" onclick="toggleDarkMode(); event.preventDefault();" class="flex items-center justify-between px-3 py-2.5 text-[13.5px] font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-xl transition-colors group/theme">
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                Darkmode
              </div>
            </a>

            <a href="#" onclick="switchTab('settings'); event.preventDefault();" class="flex items-center gap-3 px-3 py-2.5 text-[13.5px] font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 rounded-xl transition-colors">
              <svg class="w-4 h-4 text-slate-500 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              Settings
            </a>

            <div class="h-px bg-slate-200 dark:bg-white/10 my-2 mx-1"></div>
            
            <a href="/logout" class="flex items-center gap-3 px-3 py-2.5 text-[13.5px] font-medium text-slate-700 dark:text-slate-300 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 rounded-xl transition-colors">
              <svg class="w-4 h-4 text-slate-500 dark:text-slate-400 group-hover:text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
              Keluar
            </a>
          </div>
        </div>
      </div>
    </header>
