    // Fetch Orders
    async function loadOrders() {
      try {
        const res = await fetch('/api/orders');
        const data = await res.json();
        if (data.success) {
          ordersData = data.orders;
          renderOrders();
        }
      } catch (err) {
        console.error("Failed to load orders", err);
      }
    }

    // Load Settings
    async function loadSettings() {
      try {
        const res = await fetch('/api/settings');
        const data = await res.json();
        if (data.success) {
          Object.keys(data.settings).forEach(section => {
            const sectionData = data.settings[section];
            Object.keys(sectionData).forEach(key => {
              const el = document.getElementById(`${section}-${key}`);
              if (el) {
                if (el.tagName === 'TEXTAREA') {
                  el.value = sectionData[key];
                  el.innerText = sectionData[key];
                } else if (el.tagName === 'IMG') {
                  el.src = sectionData[key];
                } else {
                  el.value = sectionData[key];
                }
              }
            });
          });
        }
      } catch (err) {
        console.error("Failed to load settings", err);
      }
    }

    async function saveSection(section, dataObj) {
      try {
        const res = await fetch('/api/settings/' + section, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dataObj)
        });
        const data = await res.json();
        if (data.success) {
          showToast(`Berhasil menyimpan pengaturan ${section}`, "green");
        } else {
          showToast(`Gagal menyimpan: ${data.message}`, "red");
        }
      } catch (err) {
        showToast("Terjadi kesalahan koneksi saat menyimpan.", "red");
      }
    }

