<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Apriprogram</title>
  <link rel="icon" href="/assets/logo/favicon.png" type="image/png">

  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <%- include('components/ui-scripts') %>
  <script>
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.classList.remove('dark');
    }

    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          fontFamily: { sans: ['Poppins', 'sans-serif'] },
          colors: {
            brand: {
              blue: "#3b82f6",
              dark: "#14151A",
              darker: "#0D0E12",
              card: "#1C1E26",
              border: "#2A2B36",
              input: "#14151A"
            }
          }
        }
      }
    };
  </script>
  <style>
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .dark ::-webkit-scrollbar-thumb { background: #2A2B36; }
    ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    .dark ::-webkit-scrollbar-thumb:hover { background: #3f3f4e; }

    .nav-item, .setting-nav { transition: all 0.2s ease-in-out; }
    .nav-item:hover, .nav-item.active, .setting-nav:hover, .setting-nav.active {
      background-color: #F5F5F5 !important;
      color: #0f172a !important;
    }
    .dark .nav-item:hover, .dark .nav-item.active, .dark .setting-nav:hover, .dark .setting-nav.active {
      background-color: #1C1E26 !important;
      color: #ffffff !important;
    }

    .file-upload-btn {
      position: relative;
      overflow: hidden;
    }
    .file-upload-btn input[type="file"] {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 100%;
      opacity: 0;
      cursor: pointer;
    }
  </style>
</head>
<body class="bg-[#F1F1F1] dark:bg-brand-dark text-slate-700 dark:text-slate-300 font-sans h-screen flex overflow-hidden selection:bg-brand-blue selection:text-white transition-colors duration-200">
  <%- include('partials/sidebar') %>

  <main class="flex-1 flex flex-col min-w-0 bg-[#F1F1F1] dark:bg-brand-dark">
    <%- include('partials/navbar') %>
    <div class="flex-1 overflow-y-auto p-6 md:p-8 scroll-smooth">
      <%- include('tabs/dashboard') %>
      <%- include('tabs/profile') %>
      <%- include('tabs/settings') %>
      <%- include('tabs/orders') %>
      <%- include('tabs/users') %>
      <%- include('tabs/pricelist') %>
      <%- include('tabs/contents') %>
      <%- include('tabs/content-form') %>
      <%- include('tabs/content-detail') %>
    </div>
  </main>

  <%- include('components/modal-user') %>
  <%- include('components/modal-order') %>
  <%- include('components/modal-detail') %>
  <%- include('components/modal-delete') %>
  <%- include('components/modal-pricelist') %>
  <%- include('components/modal-invoice') %>
  <%- include('components/modal-preview') %>

  <div id="toast" class="fixed top-6 left-1/2 -translate-x-1/2 hidden z-[100] min-w-[300px]">
    <div class="flex items-center gap-3">
      <div id="toast-icon" class="w-8 h-8 rounded-full flex items-center justify-center shrink-0"></div>
      <p id="toast-msg" class="font-medium"></p>
    </div>
  </div>

  <%- include('scripts/core') %>
  <%- include('scripts/dashboard-page') %>
  <%- include('scripts/users-page') %>
  <%- include('scripts/pricelist-page') %>
  <%- include('scripts/orders-page') %>
  <%- include('scripts/profile-page') %>
  <%- include('scripts/settings-page') %>
  <%- include('scripts/invoice-page') %>
  <%- include('scripts/invoice-download') %>
  <%- include('scripts/contents-page') %>
  <%- include('scripts/init') %>
</body>
</html>
