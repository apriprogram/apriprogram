    async function submitOrderForm(e) {
      if(e) e.preventDefault();
      try {
        const id = document.getElementById('order-id').value;
        const payload = {
          user_id: document.getElementById('order-user_id').value,
          project_name: document.getElementById('order-project_name').value,
          website_type: document.getElementById('order-website_type').value,
          domain_name: document.getElementById('order-domain_name').value,
          package_name: document.getElementById('order-package_name').value,
          package_price: document.getElementById('order-package_price').value,
          status: document.getElementById('order-status').value,
          target_date: document.getElementById('order-target_date').value,
          description: document.getElementById('order-description').value,
          features: document.getElementById('order-features').value,
          notes: document.getElementById('order-notes').value,
          reference_links: document.getElementById('order-reference_links').value,
          primary_color: document.getElementById('order-primary_color').value,
          secondary_color: document.getElementById('order-secondary_color').value,
          typography: document.getElementById('order-typography').value,
          design_style: document.getElementById('order-design_style').value,
          project_document: document.getElementById('order-project_document').value,
          payment_proof: document.getElementById('order-payment_proof').value
        };

        const method = id ? 'PUT' : 'POST';
        const url = id ? '/api/orders/' + id : '/api/orders';

        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
          showToast(data.message, "green");
          closeOrderModal();
          loadOrders();
        } else {
          showToast(data.message || "Terjadi kesalahan.", "red");
        }
      } catch (err) {
        console.error("Error submitting order form:", err);
        showToast("Gagal memproses form: " + err.message, "red");
      }
    }

    function renderAdminUploadedDocs() {
      const docInput = document.getElementById('order-project_document');
      const docDisplay = document.getElementById('project-doc-display');
      const val = docInput.value.trim();
      
      if (!val) {
        docDisplay.innerHTML = '<span class="text-slate-400 text-xs italic">Tidak ada dokumen.</span>';
        return;
      }
      
      const urls = val.split(',').filter(u => u.trim() !== '');
      if (urls.length === 0) {
        docDisplay.innerHTML = '<span class="text-slate-400 text-xs italic">Tidak ada dokumen.</span>';
        return;
      }
      
      docDisplay.innerHTML = `
        <div class="space-y-2 mt-2 max-h-[150px] overflow-y-auto px-1">
          ${urls.map((url, idx) => {
            const filename = url.substring(url.lastIndexOf('/') + 1);
            return `
              <div class="flex items-center justify-between bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-brand-border p-2 rounded-lg text-xs gap-2 relative z-20">
                <a href="${url}" target="_blank" class="hover:underline font-semibold text-brand-blue truncate max-w-[180px]">${filename}</a>
                <button type="button" class="text-red-500 hover:text-red-700 transition-colors p-1" onclick="removeAdminDoc(${idx}); event.stopPropagation();" title="Hapus Dokumen">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
              </div>
            `;
          }).join('')}
        </div>
      `;
    }

    function removeAdminDoc(idx) {
      const docInput = document.getElementById('order-project_document');
      const val = docInput.value.trim();
      if (!val) return;
      const urls = val.split(',').filter(u => u.trim() !== '');
      urls.splice(idx, 1);
      docInput.value = urls.join(',');
      renderAdminUploadedDocs();
    }

    async function uploadOrderFile(input, type) {
      if (!input.files || input.files.length === 0) return;
      
      const formData = new FormData();
      const fieldname = type === 'document' ? 'project_document' : 'payment_proof';
      for (let i = 0; i < input.files.length; i++) {
        formData.append(fieldname, input.files[i]);
      }

      const displayId = type === 'document' ? 'project-doc-display' : 'payment-proof-display';
      const hiddenInputId = type === 'document' ? 'order-project_document' : 'order-payment_proof';
      
      const displayEl = document.getElementById(displayId);
      const originalHtml = displayEl.innerHTML;
      displayEl.innerHTML = '<span class="text-slate-500 font-medium animate-pulse">Mengunggah...</span>';

      try {
        const uploadUrl = type === 'document' ? '/api/upload/document' : '/api/upload/payment';
        const res = await fetch(uploadUrl, {
          method: 'POST',
          body: formData
        });
        const data = await res.json();
        if (data.success) {
          const hiddenInput = document.getElementById(hiddenInputId);
          if (type === 'document') {
            const currentVal = hiddenInput.value.trim();
            hiddenInput.value = currentVal ? currentVal + ',' + data.url : data.url;
            renderAdminUploadedDocs();
          } else {
            hiddenInput.value = data.url;
            const isPdf = data.url.endsWith('.pdf');
            if (isPdf) {
              displayEl.innerHTML = `<a href="${data.url}" target="_blank" class="text-brand-blue hover:underline font-medium text-xs mt-2">Lihat PDF Bukti Bayar</a>`;
            } else {
              displayEl.innerHTML = `<a href="${data.url}" target="_blank" class="mt-2 block"><img src="${data.url}" class="h-16 w-auto rounded border border-slate-200 dark:border-brand-border object-contain" alt="Bukti"></a>`;
            }
          }
          showToast("Berkas berhasil diunggah.", "green");
        } else {
          displayEl.innerHTML = originalHtml;
          showToast(data.message || "Gagal mengunggah berkas.", "red");
        }
      } catch (err) {
        console.error("Upload error:", err);
        displayEl.innerHTML = originalHtml;
        showToast("Terjadi kesalahan saat mengunggah berkas.", "red");
      } finally {
        input.value = '';
      }
    }

    function deleteOrder(id) {
      openDeleteModal(id, 'order');
    }

    function openDeleteModal(id, type) {
      document.getElementById('delete-id').value = id;
      document.getElementById('delete-type').value = type;
      
      const modal = document.getElementById('delete-modal');
      const content = document.getElementById('delete-modal-content');
      modal.classList.remove('hidden');
      setTimeout(() => {
        modal.classList.remove('opacity-0');
        content.classList.remove('scale-95');
      }, 10);
    }

    function closeDeleteModal() {
      const modal = document.getElementById('delete-modal');
      const content = document.getElementById('delete-modal-content');
      modal.classList.add('opacity-0');
      content.classList.add('scale-95');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 200);
    }

    async function executeDelete() {
      const id = document.getElementById('delete-id').value;
      const type = document.getElementById('delete-type').value;
      const url = type === 'user' ? `/api/admin/users/${id}` : `/api/orders/${id}`;
      
      try {
        const res = await fetch(url, {
          method: 'DELETE',
          headers: { 
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          }
        });
        
        const contentType = res.headers.get('content-type');
        if (contentType && contentType.includes('application/json')) {
          const data = await res.json();
          if (data.success) {
            showToast(data.message || "Data berhasil dihapus.", "green");
            closeDeleteModal();
            if (type === 'user') {
              loadUsers();
            } else {
              loadOrders();
            }
          } else {
            showToast(data.message || "Gagal menghapus data.", "red");
          }
        } else {
          if (res.status === 403) {
            showToast("Akses ditolak. Anda bukan admin atau sesi telah berakhir.", "red");
          } else if (res.status === 401) {
            showToast("Sesi telah berakhir. Silakan login kembali.", "red");
            setTimeout(() => window.location.href = '/login', 2000);
          } else {
            showToast("Terjadi kesalahan server saat menghapus.", "red");
          }
        }
      } catch (err) {
        console.error("Delete error:", err);
        showToast("Gagal menghubungi server.", "red");
      }
    }

    // Initial load for dashboard stats
    loadUsers();
  </script>

