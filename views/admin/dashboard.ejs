              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
          </td>
        </tr>
      `).join('');
      
      if (paginated.length === 0) {
        tbody.innerHTML = `<tr><td colspan="7" class="py-8 text-center text-slate-500">Tidak ada data ditemukan.</td></tr>`;
      }

      document.getElementById('stat-orders').innerText = ordersData.length;
      document.getElementById('orders-info').innerText = `Menampilkan ${start + 1} hingga ${Math.min(start + limit, filtered.length)} dari ${filtered.length} data`;
      
      let controls = '';
      if (ordersPage > 1) controls += `<button onclick="ordersPage--; renderOrders()" class="px-3 py-1 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded hover:bg-slate-50 dark:hover:bg-brand-card">Prev</button>`;
      controls += `<span class="px-3 py-1 font-medium bg-slate-100 dark:bg-brand-card rounded">${ordersPage} / ${totalPages}</span>`;
