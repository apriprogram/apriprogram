        </div>
        <button type="button" onclick="closeOrderDetailModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <div class="overflow-y-auto flex-1 p-8">
        
        <div class="flex items-center justify-between mb-8">
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400">ID Pesanan: <span id="detail-id" class="text-brand-blue font-bold"></span></p>
            <div id="detail-status"></div>
        </div>

        <div class="space-y-8">
          <!-- Recipient / Requester Section (Klien & Proyek) -->
          <div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Recipient Contact Details</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Nama Klien (Email)</label>
                <div class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-900 dark:text-white text-sm" id="detail-client_name">-</div>
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Nama Proyek</label>
                <div class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-900 dark:text-white text-sm font-medium" id="detail-project_name">-</div>
              </div>
            </div>
          </div>
          
          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Layanan & Harga -->
          <div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Request Details</h4>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
              <div class="col-span-2">
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Jenis & Paket Website</label>
                <div class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-900 dark:text-white text-sm" id="detail-website_type_package">-</div>
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Nominal Harga</label>
                <div class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-900 dark:text-white text-sm font-bold" id="detail-package_price">-</div>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Domain Name</label>
                <div class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-900 dark:text-white text-sm text-brand-blue" id="detail-domain_name">-</div>
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Target Selesai</label>
                <div class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-900 dark:text-white text-sm" id="detail-target_date">-</div>
              </div>
            </div>
            
            <div class="mt-5">
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Description / Spesifikasi Lengkap</label>
              <div class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl text-slate-800 dark:text-slate-300 text-sm whitespace-pre-wrap" id="detail-description">-</div>
            </div>
          </div>

          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Document & Payment Proof -->
          <div>
            <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4">Support Documents</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Document Project</label>
                <div id="detail-project_document" class="flex items-center justify-center min-h-[100px] bg-white dark:bg-[#14151a] rounded-xl border border-dashed border-slate-300 dark:border-brand-border p-4 text-center">
                  <!-- Injected via JS -->
                </div>
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Bukti Pembayaran DP</label>
                <div id="detail-payment_proof" class="flex items-center justify-center min-h-[100px] bg-white dark:bg-[#14151a] rounded-xl border border-dashed border-slate-300 dark:border-brand-border p-4 text-center">
                  <!-- Injected via JS -->
                </div>
              </div>
            </div>
          </div>

        </div>

        <div class="pt-6 flex flex-wrap items-center justify-end gap-3 mt-8 border-t border-slate-100 dark:border-slate-800">
          <button type="button" onclick="closeOrderDetailModal()" class="px-8 py-2.5 bg-[#111827] dark:bg-brand-blue text-white text-sm font-bold rounded-xl hover:bg-black dark:hover:bg-blue-600 transition-colors shadow-lg shadow-black/10">Tutup</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Dark Mode Toggle Logic
    function toggleDarkMode() {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    }

    // Sidebar Toggle
    let sidebarOpen = true;
    document.getElementById('toggle-sidebar').addEventListener('click', () => {
      const sidebar = document.getElementById('sidebar');
      sidebarOpen = !sidebarOpen;
      if (sidebarOpen) {
        sidebar.classList.remove('-ml-64');
      } else {
        sidebar.classList.add('-ml-64');
      }
    });

    // Tab Switching Logic
    function switchTab(tabId) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.nav-item').forEach(el => {
        el.classList.remove('active');
      });
      
      document.getElementById(`tab-${tabId}`).classList.remove('hidden');
      const activeNav = document.getElementById(`nav-${tabId}`);
      activeNav.classList.add('active');
      
      const titles = { 'dashboard': 'Dasbor', 'settings': 'Pengaturan', 'users': 'Data Pengguna', 'orders': 'Pesanan Masuk' };
      document.getElementById('pageTitle').innerText = titles[tabId];

      if (tabId === 'users') loadUsers();
      if (tabId === 'settings') loadSettings();
      if (tabId === 'orders') loadOrders();
    }

    // Setting Form Navigation
    function showSettingSection(section) {
      document.querySelectorAll('.setting-form').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.setting-nav').forEach(el => {
        el.className = "setting-nav w-full text-left px-4 py-3 rounded-xl text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-brand-darker mb-1 transition-colors";
      });
      document.getElementById(`form-${section}`).classList.remove('hidden');
      const activeBtn = document.getElementById(`btn-${section}`);
      activeBtn.className = "setting-nav active w-full text-left px-4 py-3 rounded-xl text-sm font-medium bg-slate-100 dark:bg-brand-darker text-brand-blue dark:text-white mb-1 transition-colors";
    }

    // Upload Image Handler
    async function uploadImage(input, hiddenInputId, labelId) {
      if (!input.files || input.files.length === 0) return;
      const file = input.files[0];
      
      const formData = new FormData();
      formData.append('image', file);
      
      document.getElementById(labelId).innerText = "Mengunggah...";

      try {
        const res = await fetch('/api/admin/upload', {
          method: 'POST',
          body: formData
        });
        const data = await res.json();
        if (data.success) {
          document.getElementById(hiddenInputId).value = data.url;
          document.getElementById(labelId).innerText = file.name;
          showToast("Gambar berhasil diunggah. Klik 'Simpan' untuk menerapkan.", "green");
        } else {
          document.getElementById(labelId).innerText = "Gagal mengunggah";
          showToast(data.message || "Gagal mengunggah gambar.", "red");
        }
      } catch (err) {
        document.getElementById(labelId).innerText = "Error";
        showToast("Terjadi kesalahan saat mengunggah gambar.", "red");
      }
    }

    function showToast(message, color = "green") {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-msg');
      const toastIcon = document.getElementById('toast-icon');
      
      // Setup icon and colors
      if (color === "green") {
        toast.className = `fixed top-6 left-1/2 -translate-x-1/2 z-[100] min-w-[300px] p-4 rounded-2xl text-sm shadow-xl flex items-center justify-between border transition-all duration-300 transform translate-y-0 opacity-100 bg-white dark:bg-[#1C1E26] border-green-200 dark:border-green-500/20 text-slate-800 dark:text-white`;
        toastIcon.className = `w-8 h-8 rounded-full flex items-center justify-center shrink-0 bg-green-100 dark:bg-green-500/20 text-green-600 dark:text-green-400`;
        toastIcon.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>`;
      } else {
        toast.className = `fixed top-6 left-1/2 -translate-x-1/2 z-[100] min-w-[300px] p-4 rounded-2xl text-sm shadow-xl flex items-center justify-between border transition-all duration-300 transform translate-y-0 opacity-100 bg-white dark:bg-[#1C1E26] border-red-200 dark:border-red-500/20 text-slate-800 dark:text-white`;
        toastIcon.className = `w-8 h-8 rounded-full flex items-center justify-center shrink-0 bg-red-100 dark:bg-red-500/20 text-red-600 dark:text-red-400`;
        toastIcon.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>`;
      }
      
      toastMsg.innerText = message;
      
      // Auto hide
      setTimeout(() => { 
        toast.classList.replace('translate-y-0', '-translate-y-4');
        toast.classList.replace('opacity-100', 'opacity-0');
        setTimeout(() => {
          toast.className = "fixed top-6 left-1/2 -translate-x-1/2 hidden z-[100] min-w-[300px]";
        }, 300);
      }, 4000);
    }

    // User CRUD Logic
    function openUserModal(id = '', email = '', role = 'client') {
      document.getElementById('user-modal').classList.remove('hidden');
      setTimeout(() => {
        document.getElementById('user-modal').classList.remove('opacity-0');
        document.getElementById('user-modal-content').classList.remove('scale-95');
      }, 10);
      
      document.getElementById('user-id').value = id;
      document.getElementById('user-email').value = email;
      document.getElementById('user-role').value = role;
      document.getElementById('user-password').value = '';
      
      if (id) {
        document.getElementById('user-modal-title').innerText = 'Edit Pengguna';
        document.getElementById('user-password').required = false;
        document.getElementById('user-pass-note').innerText = '(Kosongkan jika tidak ingin diubah)';
      } else {
        document.getElementById('user-modal-title').innerText = 'Tambah Pengguna';
        document.getElementById('user-password').required = true;
        document.getElementById('user-pass-note').innerText = '(Wajib diisi)';
      }
    }

    function closeUserModal() {
      document.getElementById('user-modal').classList.add('opacity-0');
      document.getElementById('user-modal-content').classList.add('scale-95');
      setTimeout(() => {
        document.getElementById('user-modal').classList.add('hidden');
      }, 200);
    }

    document.getElementById('user-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('user-id').value;
      const email = document.getElementById('user-email').value;
      const role = document.getElementById('user-role').value;
      const password = document.getElementById('user-password').value;
      
      const method = id ? 'PUT' : 'POST';
      const url = id ? '/api/admin/users/' + id : '/api/admin/users';
      const body = { email, role };
      if (password) body.password = password;

      try {
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.success) {
          showToast(data.message, "green");
          closeUserModal();
          loadUsers();
        } else {
          showToast(data.message || "Terjadi kesalahan.", "red");
        }
      } catch (err) {
        showToast("Gagal menghubungi server.", "red");
      }
    });

    function deleteUser(id) {
      openDeleteModal(id, 'user');
    }

    // Global Data Arrays
    let usersData = [];
    let ordersData = [];
    let usersPage = 1;
    let ordersPage = 1;

    // Render Users Table
    function renderUsers() {
      const tbody = document.getElementById('users-table-body');
      const limit = parseInt(document.getElementById('users-limit').value);
      const search = document.getElementById('users-search').value.toLowerCase();
      
      const filtered = usersData.filter(u => u.email.toLowerCase().includes(search) || u.role.toLowerCase().includes(search));
      const totalPages = Math.ceil(filtered.length / limit) || 1;
      if (usersPage > totalPages) usersPage = totalPages;
      
      const start = (usersPage - 1) * limit;
      const paginated = filtered.slice(start, start + limit);
      
      tbody.innerHTML = paginated.map(u => `
        <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
          <td class="py-4 px-6 font-medium">#${u.id}</td>
          <td class="py-4 px-6 text-slate-900 dark:text-white font-medium">${u.email}</td>
          <td class="py-4 px-6">
            <span class="px-2.5 py-1 text-[11px] font-bold tracking-wider uppercase rounded-md ${u.role === 'super admin' || u.role === 'admin' ? 'bg-blue-100 dark:bg-[#3b82f6]/20 text-blue-700 dark:text-[#3b82f6]' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400'}">${u.role}</span>
          </td>
          <td class="py-4 px-6">${new Date(u.created_at).toLocaleDateString('id-ID')}</td>
          <td class="py-4 px-6 text-center flex justify-center gap-2">
            <button onclick="openUserModal(${u.id}, '${u.email}', '${u.role}')" class="p-2 bg-amber-100 dark:bg-amber-500/10 text-amber-600 dark:text-amber-500 hover:bg-amber-200 dark:hover:bg-amber-500/20 rounded-lg transition-colors" title="Edit">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
            </button>
            <button onclick="deleteUser(${u.id})" class="p-2 bg-red-100 dark:bg-red-500/10 text-red-600 dark:text-red-500 hover:bg-red-200 dark:hover:bg-red-500/20 rounded-lg transition-colors" title="Hapus">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
          </td>
        </tr>
      `).join('');
      
      if (paginated.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" class="py-8 text-center text-slate-500">Tidak ada data ditemukan.</td></tr>`;
      }

      document.getElementById('stat-users').innerText = usersData.length;
      document.getElementById('users-info').innerText = `Menampilkan ${start + 1} hingga ${Math.min(start + limit, filtered.length)} dari ${filtered.length} data`;
      
      let controls = '';
      if (usersPage > 1) controls += `<button onclick="usersPage--; renderUsers()" class="px-3 py-1 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded hover:bg-slate-50 dark:hover:bg-brand-card">Prev</button>`;
      controls += `<span class="px-3 py-1 font-medium bg-slate-100 dark:bg-brand-card rounded">${usersPage} / ${totalPages}</span>`;
      if (usersPage < totalPages) controls += `<button onclick="usersPage++; renderUsers()" class="px-3 py-1 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded hover:bg-slate-50 dark:hover:bg-brand-card">Next</button>`;
      document.getElementById('users-page-controls').innerHTML = controls;
    }

    function filterUsers() {
      usersPage = 1;
      renderUsers();
    }

    // Fetch Users
    async function loadUsers() {
      try {
        const res = await fetch('/api/admin/users');
        const data = await res.json();
        if (data.success) {
          usersData = data.users;
          renderUsers();
        }
      } catch (err) {
        console.error("Failed to load users", err);
      }
    }

    // Render Orders Table
    function getStatusBadgeHtml(status) {
      let bg, text, border, icon;
      switch(status) {
        case 'Pending DP':
          bg = 'bg-orange-100 dark:bg-orange-500/10';
          text = 'text-orange-700 dark:text-orange-500';
          border = 'border-orange-200 dark:border-orange-500/20';
          icon = '<svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
          break;
        case 'Proses':
          bg = 'bg-blue-100 dark:bg-blue-500/10';
          text = 'text-blue-700 dark:text-blue-500';
          border = 'border-blue-200 dark:border-blue-500/20';
          icon = '<svg class="w-3.5 h-3.5 mr-1.5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>';
          break;
        case 'Revisi':
          bg = 'bg-yellow-100 dark:bg-yellow-500/10';
          text = 'text-yellow-700 dark:text-yellow-500';
          border = 'border-yellow-200 dark:border-yellow-500/20';
          icon = '<svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>';
          break;
        case 'Selesai':
          bg = 'bg-green-100 dark:bg-green-500/10';
          text = 'text-green-700 dark:text-green-500';
          border = 'border-green-200 dark:border-green-500/20';
          icon = '<svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
          break;
        case 'Batal':
          bg = 'bg-red-100 dark:bg-red-500/10';
          text = 'text-red-700 dark:text-red-500';
          border = 'border-red-200 dark:border-red-500/20';
          icon = '<svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';
          break;
        default:
          bg = 'bg-slate-100 dark:bg-slate-500/10';
          text = 'text-slate-700 dark:text-slate-500';
          border = 'border-slate-200 dark:border-slate-500/20';
          icon = '<svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>';
      }
      return `<span class="inline-flex items-center px-3 py-1.5 text-[11px] font-bold uppercase tracking-wider rounded-lg border ${bg} ${text} ${border} shadow-sm whitespace-nowrap">${icon}${status}</span>`;
    }

    function renderOrders() {
      const tbody = document.getElementById('orders-table-body');
      const limit = parseInt(document.getElementById('orders-limit').value);
      const search = document.getElementById('orders-search').value.toLowerCase();
      
      const filtered = ordersData.filter(o => 
        (o.full_name || '').toLowerCase().includes(search) || 
        (o.project_name || '').toLowerCase().includes(search) || 
        (o.package_name || '').toLowerCase().includes(search)
      );
      const totalPages = Math.ceil(filtered.length / limit) || 1;
      if (ordersPage > totalPages) ordersPage = totalPages;
      
      const start = (ordersPage - 1) * limit;
      const paginated = filtered.slice(start, start + limit);
      
      tbody.innerHTML = paginated.map(o => `
        <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
          <td class="py-4 px-6 font-medium">#${o.id}</td>
          <td class="py-4 px-6">
            <div class="font-medium text-slate-900 dark:text-white">${o.full_name || o.email || 'Klien'}</div>
            <div class="text-[11px] text-slate-500 dark:text-slate-400 mt-1 uppercase tracking-wider">${o.project_name}</div>
          </td>
          <td class="py-4 px-6">
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">${o.website_type || '-'}</span>
          </td>
          <td class="py-4 px-6">
            <span class="px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider rounded-md bg-brand-blue/10 text-brand-blue">${o.package_name}</span>
          </td>
          <td class="py-4 px-6">
            ${getStatusBadgeHtml(o.status)}
          </td>
          <td class="py-4 px-6">${new Date(o.created_at).toLocaleDateString('id-ID')}</td>
          <td class="py-4 px-6 text-center flex justify-center gap-2">
            <button onclick='viewOrderDetail(${JSON.stringify(o).replace(/'/g, "&#39;")})' class="p-2 bg-blue-100 dark:bg-blue-500/10 text-brand-blue dark:text-blue-500 hover:bg-blue-200 dark:hover:bg-blue-500/20 rounded-lg transition-colors" title="Lihat Detail">
