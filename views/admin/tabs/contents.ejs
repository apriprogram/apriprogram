              <select id="contents-sort" class="pl-7 pr-6 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium">
                <option value="newest">Sort</option>
                <option value="oldest">Terlama</option>
              </select>
            </div>
            <div class="relative shrink-0">
              <svg class="w-3.5 h-3.5 text-slate-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"></path></svg>
              <select id="contents-limit" class="pl-7 pr-6 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium">
                <option value="10">10 Baris</option>
                <option value="20">20 Baris</option>
                <option value="30">30 Baris</option>
                <option value="50">50 Baris</option>
              </select>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-100 dark:bg-[#0D0E12] border-y border-slate-200 dark:border-brand-border text-slate-500 dark:text-slate-400 text-[9px] sm:text-[10px] font-bold uppercase tracking-widest">
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">No</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Judul Konten</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Target Audiens</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 text-center whitespace-nowrap">Status</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 text-center w-36 whitespace-nowrap">Aksi</th>
                </tr>
              </thead>
              <tbody id="contents-table-body" class="text-[10px] sm:text-xs whitespace-nowrap text-slate-600 dark:text-slate-300">
