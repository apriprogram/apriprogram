      <div id="tab-contents" class="tab-content hidden space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-5 gap-3">
          <div>
            <h3 class="text-lg sm:text-2xl font-semibold text-slate-900 dark:text-white">List Content</h3>
            <p class="text-[10px] sm:text-xs whitespace-nowrap text-slate-500 dark:text-slate-400 mt-1 font-medium">Kelola ide, draf, dan publikasi konten Anda.</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button onclick="openContentForm()" class="flex items-center gap-1.5 px-2.5 py-1.5 sm:px-4 sm:py-2 bg-brand-blue hover:bg-blue-600 text-white text-[10px] sm:text-xs font-medium rounded-lg transition-colors shrink-0">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
