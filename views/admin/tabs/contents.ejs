                <tr><td colspan="4" class="py-8 text-center text-slate-500">Memuat data...</td></tr>
              </tbody>
            </table>
            
            <div id="contents-pagination" class="py-2 px-3 sm:py-3 sm:px-4 border-t border-slate-200 dark:border-brand-border flex flex-row items-center justify-between w-full text-[10px] sm:text-sm text-slate-500 dark:text-slate-400 bg-slate-50/50 dark:bg-brand-card gap-2 sm:gap-4">
              <div class="flex items-center gap-2">
                <span>Menampilkan data konten</span>
              </div>
            </div>
          </div>
        </div>
