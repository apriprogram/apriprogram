<div id="tab-content-form" class="tab-content hidden pb-20">
  <!-- Sticky Save Button -->
  <div class="sticky top-4 sm:top-1 z-50 w-full pointer-events-none -mt-1 sm:-mt-4" style="height: 0;">
    <div class="absolute right-0 -top-4 sm:-top-5 pointer-events-auto">
      <button type="button" onclick="submitContentForm(event)" class="px-4 py-2 bg-brand-blue hover:bg-blue-600 text-white text-sm font-medium rounded-lg transition-colors shadow-sm inline-flex items-center justify-center gap-2 whitespace-nowrap">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
        Simpan Konten
      </button>
    </div>
  </div>

  <!-- Header -->
  <div class="flex items-center gap-3 border-b border-slate-200 dark:border-brand-border pb-4 mb-6 pr-36">
    <button type="button" onclick="switchTab('contents')" class="p-2 -ml-2 rounded-lg text-slate-500 hover:text-brand-blue hover:bg-brand-blue/10 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    </button>
    <h3 class="text-lg sm:text-2xl font-semibold text-slate-900 dark:text-white" id="content-form-title">Tambah Konten Baru</h3>
  </div>

  <form id="content-form" class="space-y-6 max-w-5xl mx-auto">
    <input type="hidden" id="content-id">
    
    <!-- Section 1: Ide Dasar -->
    <div class="bg-white dark:bg-brand-card p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-brand-border">
      <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-brand-blue flex items-center justify-center text-xs">1</span>
        Ide Dasar Konten
      </h4>
      <div class="space-y-4 sm:space-y-5">
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Judul Konten <span class="text-red-500">*</span></label>
          <input type="text" id="content-title" required placeholder="Masukkan judul singkat dan jelas yang menggambarkan inti ide konten." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Ringkasan Ide</label>
          <textarea id="content-idea_summary" rows="3" placeholder="Jelaskan ide konten dalam 2–5 kalimat. Apa yang ingin dibahas dan mengapa ide ini menarik?" class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
      </div>
    </div>

    <!-- Section 2: Konteks & Tujuan -->
    <div class="bg-white dark:bg-brand-card p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-brand-border">
      <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-brand-blue flex items-center justify-center text-xs">2</span>
        Konteks & Tujuan
      </h4>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5">
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Latar Belakang</label>
          <textarea id="content-background" rows="4" placeholder="Jelaskan alasan mengapa konten ini perlu dibuat. Apakah ada masalah, tren, atau kebutuhan pengguna yang melatarbelakanginya?" class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Permasalahan</label>
          <textarea id="content-problem" rows="4" placeholder="Tuliskan masalah utama yang dialami target audiens dan akan diselesaikan melalui konten ini." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Tujuan Konten</label>
          <textarea id="content-objective" rows="4" placeholder="Jelaskan hasil yang ingin dicapai, seperti memberikan edukasi, meningkatkan konversi, menjawab pertanyaan pengguna, atau meningkatkan traffic." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Target Audiens</label>
          <textarea id="content-target_audience" rows="4" placeholder="Siapa pembaca yang dituju? Jelaskan karakteristik, profesi, tingkat pengetahuan, atau kebutuhan mereka." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
      </div>
    </div>

    <!-- Section 3: Pendekatan -->
    <div class="bg-white dark:bg-brand-card p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-brand-border">
      <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-brand-blue flex items-center justify-center text-xs">3</span>
        Pendekatan Konten
      </h4>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5">
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Konsep Konten</label>
          <textarea id="content-concept" rows="4" placeholder="Jelaskan konsep utama penyampaian konten. Misalnya menggunakan pendekatan tutorial, storytelling, studi kasus, checklist, atau perbandingan." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Angle Konten</label>
          <textarea id="content-angle" rows="4" placeholder="Tuliskan sudut pandang yang membuat konten ini unik dibanding konten lain dengan topik serupa." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Value yang Diberikan</label>
          <input type="text" id="content-value_provided" placeholder="Manfaat apa yang akan diperoleh pembaca setelah membaca konten ini?" class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all">
        </div>
      </div>
    </div>

    <!-- Section 4: Kerangka Konten -->
    <div class="bg-white dark:bg-brand-card p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-brand-border">
      <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-brand-blue flex items-center justify-center text-xs">4</span>
        Kerangka & Draft
      </h4>
      <div class="space-y-4 sm:space-y-5">
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Opening</label>
          <textarea id="content-opening" rows="3" placeholder="Buat pembuka yang menarik perhatian pembaca, misalnya dengan pertanyaan, fakta, statistik, atau permasalahan umum." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Narasi Konten</label>
          <textarea id="content-narrative" rows="4" placeholder="Jelaskan alur penyampaian konten dari awal hingga akhir. Uraikan bagaimana setiap bagian saling terhubung agar mudah dipahami." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Outline</label>
          <textarea id="content-outline" rows="6" placeholder="Susun struktur konten dalam bentuk poin-poin atau daftar heading yang akan menjadi kerangka penulisan." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm font-mono transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Isi Konten</label>
          <textarea id="content-content_body" rows="12" placeholder="Tulis draft lengkap berdasarkan outline dan narasi. Gunakan bahasa yang sesuai dengan target audiens serta fokus pada penyelesaian masalah." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Call To Action (CTA)</label>
          <textarea id="content-cta" rows="2" placeholder="Tuliskan tindakan yang diharapkan dilakukan pembaca setelah membaca konten, misalnya menghubungi tim, mencoba layanan, membaca artikel lain, atau melakukan pembelian." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
      </div>
    </div>

    <!-- Section 5: Meta & Aset Tambahan -->
    <div class="bg-white dark:bg-brand-card p-4 sm:p-6 rounded-2xl border border-slate-200 dark:border-brand-border">
      <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
        <span class="w-6 h-6 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-brand-blue flex items-center justify-center text-xs">5</span>
        SEO & Informasi Tambahan
      </h4>
      <div class="space-y-4 sm:space-y-5">
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Keyword SEO</label>
          <input type="text" id="content-seo_keywords" placeholder="Masukkan kata kunci utama dan kata kunci pendukung yang menjadi target optimasi mesin pencari." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all">
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Referensi</label>
          <textarea id="content-references" rows="3" placeholder="Tambahkan sumber referensi, artikel, dokumentasi, atau tautan yang menjadi dasar penyusunan konten." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Asset Pendukung (Dokumen / Gambar)</label>
          <div class="relative border-2 border-dashed border-slate-300 dark:border-slate-600 rounded-xl p-6 text-center hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer group" onclick="document.getElementById('content-assets-input').click()">
            <input type="hidden" id="content-assets">
            <input type="file" id="content-assets-input" multiple onchange="uploadContentAssets(this)" class="hidden">
            <div class="flex flex-col items-center justify-center space-y-2">
              <svg class="w-8 h-8 text-slate-400 group-hover:text-brand-blue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
              <div class="text-sm font-semibold text-slate-700 dark:text-slate-300">Klik untuk unggah dokumen/gambar</div>
              <div class="text-xs text-slate-500">Mendukung format JPG, PNG, PDF, DOCX (Bisa pilih banyak file)</div>
            </div>
          </div>
          <!-- Area untuk menampilkan daftar asset yang sudah diunggah -->
          <div id="content-assets-display" class="mt-4 flex flex-col gap-2"></div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Catatan Khusus / Prompt AI</label>
          <textarea id="content-notes" rows="5" placeholder="Tambahkan informasi penting, ide tambahan, atau revisi yang perlu diperhatikan selama proses pembuatan konten.&#10;&#10;Contoh Prompt AI: Berdasarkan informasi yang telah diisi (judul, ringkasan ide, target audiens, konsep, dan tujuan), buatkan konsep konten yang lengkap meliputi narasi, outline, isi konten, keyword SEO, meta description, serta call to action yang relevan dan mudah dipahami." class="w-full px-4 py-3 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue focus:ring-1 focus:ring-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-all resize-y"></textarea>
        </div>
      </div>
    </div>
  </form>
</div>
