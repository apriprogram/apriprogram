<div id="tab-users" class="tab-content hidden space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-5 gap-3">
          <div>
            <h3 class="text-lg sm:text-2xl font-semibold text-slate-900 dark:text-white">Users</h3>
            <p class="text-[10px] sm:text-xs whitespace-nowrap text-slate-500 dark:text-slate-400 mt-1 font-normal">Pusat Akses &amp; Otoritas Sistem</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button onclick="downloadUsersExcel()" title="Download Excel" class="flex items-center gap-1.5 px-2.5 py-1.5 sm:px-3 sm:py-2 bg-transparent border border-emerald-400/30 dark:border-emerald-500/30 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50/30 dark:hover:bg-emerald-500/10 text-[10px] sm:text-xs font-semibold rounded-lg transition-colors">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM8.5 18l-2-3h1.2l1.3 2 1.3-2H11.5l-2 3H8.5zm3.5 0v-3h1v3h-1zm2 0v-3h2.5v.7H15v.6h1.7v.7H15V18h-1z"/></svg>
              <span class="hidden sm:inline">Excel</span>
            </button>
            <button onclick="downloadUsersPDF()" title="Download PDF" class="flex items-center gap-1.5 px-2.5 py-1.5 sm:px-3 sm:py-2 bg-transparent border border-red-400/30 dark:border-red-500/30 text-red-500 dark:text-red-400 hover:bg-red-50/30 dark:hover:bg-red-500/10 text-[10px] sm:text-xs font-semibold rounded-lg transition-colors">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM9.5 16.5c0 .3-.2.5-.5.5H7v-4h2c.3 0 .5.2.5.5v3zM8 13.5h-.5v1h.5c.1 0 .3-.1.3-.3v-.4c0-.2-.2-.3-.3-.3zm4.5 2.5c0 .8-.6 1-1.5 1H9.5v-4h1.5c.9 0 1.5.2 1.5 1v2zm-1-.3v-1.4c0-.1-.1-.3-.5-.3h-.5v2h.5c.4 0 .5-.2.5-.3zm4 .8h-.5v1H14v-4h2v.7h-1.5v1H16v.7h-1.5v.6z"/></svg>
              <span class="hidden sm:inline">PDF</span>
            </button>
            <button onclick="openUserModal()" class="flex items-center gap-1.5 px-2.5 py-1.5 sm:px-4 sm:py-2 bg-brand-blue hover:bg-blue-600 text-white text-[10px] sm:text-xs font-medium rounded-lg transition-colors shrink-0">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              Tambah
            </button>
          </div>
        </div>

        <div class="bg-white dark:bg-brand-card rounded-2xl border border-slate-200 dark:border-brand-border overflow-hidden">
          
          <!-- Table Controls -->
          <div class="flex items-center py-2 px-3 sm:py-3 sm:px-4 border-b border-slate-200 dark:border-brand-border gap-2 bg-slate-50/50 dark:bg-brand-card overflow-x-auto">
            <div class="relative group shrink-0">
              <svg class="w-3.5 h-3.5 text-slate-400 absolute left-2.5 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              <input type="text" id="users-search" onkeyup="filterUsers()" placeholder="Search" class="pl-7 pr-3 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue transition-all w-24 sm:w-28 focus:w-40 sm:focus:w-48 text-[11px] sm:text-xs shadow-sm">
            </div>
            <div class="relative shrink-0">
              <svg class="w-3.5 h-3.5 text-slate-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"></path></svg>
              <select id="users-sort" onchange="filterUsers()" class="pl-7 pr-6 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium shadow-sm">
                <option value="newest">Sort</option>
                <option value="oldest">Terlama</option>
              </select>
            </div>
            <div class="relative shrink-0">
              <svg class="w-3.5 h-3.5 text-slate-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"></path></svg>
              <select id="users-limit" onchange="filterUsers()" class="pl-7 pr-6 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium shadow-sm">
                <option value="10">10 Baris</option>
                <option value="20">20 Baris</option>
                <option value="30">30 Baris</option>
                <option value="50">50 Baris</option>
              </select>
            </div>
            <div class="relative shrink-0">
              <svg class="w-3.5 h-3.5 text-slate-400 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              <select id="users-filter" onchange="filterUsers()" class="pl-7 pr-6 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border border-dashed rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium shadow-sm">
                <option value="">Add Filter</option>
                <option value="client">Role: Client</option>
                <option value="super admin">Role: Super Admin</option>
              </select>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-100 dark:bg-[#0D0E12] border-y border-slate-200 dark:border-brand-border text-slate-500 dark:text-slate-400 text-[9px] sm:text-[10px] font-bold uppercase tracking-widest">
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 w-14 whitespace-nowrap">ID</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Pengguna</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Perusahaan</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">WhatsApp</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Role</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Alamat</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 whitespace-nowrap">Terdaftar</th>
                  <th class="py-1 px-2 sm:py-2.5 sm:px-3 text-center w-24 whitespace-nowrap">Aksi</th>
                </tr>
              </thead>
              <tbody id="users-table-body" class="text-[10px] sm:text-xs whitespace-nowrap text-slate-600 dark:text-slate-300">
                <!-- Data will be loaded via JS -->
              </tbody>
            </table>
            
            <div id="users-pagination" class="py-2 px-3 sm:py-3 sm:px-4 border-t border-slate-200 dark:border-brand-border flex flex-col sm:flex-row items-center justify-between text-[10px] sm:text-sm text-slate-500 dark:text-slate-400 bg-slate-50/50 dark:bg-brand-card gap-4">
              <!-- Pagination controls will be injected here -->
            </div>
          </div>
        </div>
      </div>
