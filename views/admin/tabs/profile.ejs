<!-- Profile Tab -->
<div id="tab-profile" class="tab-content hidden space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-8 gap-4">
    <div>
      <h3 class="text-lg sm:text-2xl font-semibold text-slate-900 dark:text-white">Profile Settings</h3>
      <p class="text-[10px] sm:text-xs text-slate-500 dark:text-slate-400 mt-1">Perbarui informasi dan data akun Anda.</p>
    </div>
  </div>

  <div class="bg-white dark:bg-brand-card rounded-2xl shadow-sm border border-slate-200 dark:border-brand-border p-6 max-w-3xl">
    <form id="profile-form" onsubmit="handleProfileSubmit(event, <%= user.id %>)" class="space-y-6">

      <!-- Avatar Upload Section -->
      <div class="flex items-center gap-5 pb-4 border-b border-slate-100 dark:border-brand-border">
        <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-file-input').click()">
          <div id="profile-avatar-preview" class="w-20 h-20 rounded-xl bg-gradient-to-br from-brand-blue to-blue-700 flex items-center justify-center text-white font-bold text-2xl border border-brand-blue/30 overflow-hidden">
            <% if (user.avatar) { %>
              <img src="<%= user.avatar %>" alt="Avatar" class="w-full h-full object-cover">
            <% } else { %>
              <span><%= (user.full_name || user.email || '?').substring(0, 2).toUpperCase() %></span>
            <% } %>
          </div>
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-black/50 rounded-xl flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <!-- Upload spinner -->
          <div id="avatar-upload-spinner" class="absolute inset-0 bg-black/60 rounded-xl items-center justify-center hidden">
            <svg class="animate-spin h-6 w-6 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold text-slate-900 dark:text-white"><%= user.full_name || user.email %></p>
          <p class="text-xs text-slate-500 mt-0.5">Super Admin</p>
          <button type="button" onclick="document.getElementById('avatar-file-input').click()" class="mt-2 text-xs text-brand-blue hover:underline flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
            Ganti Foto
          </button>
          <p class="text-[10px] text-slate-400 mt-0.5">JPG, PNG, WebP. Maks 2MB</p>
        </div>
        <!-- Hidden file input -->
        <input type="file" id="avatar-file-input" accept="image/jpeg,image/jpg,image/png,image/webp,image/gif" class="hidden" onchange="uploadAvatarFile(this)">
        <input type="hidden" id="profile-avatar" value="<%= user.avatar || '' %>">
      </div>

      <!-- Grid 2 kolom -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Nama Lengkap -->
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Nama Lengkap</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
            <input type="text" id="profile-fullname" value="<%= user.full_name || '' %>" placeholder="Nama lengkap Anda" class="pl-10 w-full bg-slate-50 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white rounded-lg focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue block p-2.5 outline-none transition-all text-sm">
          </div>
        </div>

        <!-- Email -->
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Alamat Email</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <input type="email" id="profile-email" value="<%= user.email %>" required class="pl-10 w-full bg-slate-50 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white rounded-lg focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue block p-2.5 outline-none transition-all text-sm">
          </div>
        </div>

        <!-- WhatsApp -->
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">WhatsApp</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <input type="text" id="profile-whatsapp" value="<%= user.whatsapp || '' %>" placeholder="+62..." class="pl-10 w-full bg-slate-50 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white rounded-lg focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue block p-2.5 outline-none transition-all text-sm">
          </div>
        </div>

        <!-- Perusahaan -->
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Perusahaan</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <input type="text" id="profile-company" value="<%= user.company || '' %>" placeholder="Nama perusahaan" class="pl-10 w-full bg-slate-50 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white rounded-lg focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue block p-2.5 outline-none transition-all text-sm">
          </div>
        </div>

        <!-- Alamat -->
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">Alamat</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <input type="text" id="profile-country" value="<%= user.country || '' %>" placeholder="Masukkan alamat lengkap..." class="pl-10 w-full bg-slate-50 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white rounded-lg focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue block p-2.5 outline-none transition-all text-sm">
          </div>
        </div>


      </div>


      <!-- Ganti Password -->
      <div class="pt-4 border-t border-slate-100 dark:border-brand-border">
        <h4 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-3">Ganti Kata Sandi <span class="text-xs text-slate-400 font-normal">(Opsional)</span></h4>
        <div class="max-w-md">
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            </div>
            <input type="password" id="profile-password" placeholder="Kata sandi baru..." class="pl-10 w-full bg-slate-50 dark:bg-brand-darker border border-slate-200 dark:border-brand-border text-slate-900 dark:text-white rounded-lg focus:ring-2 focus:ring-brand-blue/50 focus:border-brand-blue block p-2.5 outline-none transition-all text-sm">
          </div>
        </div>
      </div>

      <input type="hidden" id="profile-role" value="<%= user.role || 'admin' %>">

      <div class="pt-2 flex justify-end">
        <button type="submit" id="btn-save-profile" class="px-5 py-2.5 bg-brand-blue hover:bg-blue-600 text-white text-sm font-medium rounded-full transition-colors flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Simpan Perubahan
        </button>
      </div>
    </form>
  </div>
</div>

<script>
function updateAvatarPreview(url) {
  const preview = document.getElementById('profile-avatar-preview');
  const initials = document.getElementById('profile-avatar-initials');
  if (url) {
    preview.innerHTML = `<img src="${url}" alt="Avatar" class="w-full h-full object-cover">`;
  } else {
    const email = document.getElementById('profile-email').value;
    preview.innerHTML = `<span id="profile-avatar-initials">${(email || '?').substring(0, 2).toUpperCase()}</span>`;
  }
}
</script>
