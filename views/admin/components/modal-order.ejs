<!-- Order Modal -->
<div id="order-modal" class="fixed inset-0 bg-slate-900/45 z-[9999] hidden opacity-0 transition-opacity duration-300" onclick="if(event.target===this)closeOrderModal()">
  <div class="fixed right-0 top-0 h-screen w-full sm:max-w-[720px] bg-white dark:bg-brand-card border-l border-slate-200 dark:border-brand-border shadow-[-18px_0_60px_rgba(15,23,42,0.22)] overflow-hidden transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] flex flex-col rounded-none z-[10000]" id="order-modal-content">
    
    <!-- Modal Header -->
    <div class="flex items-center justify-between px-8 py-5 border-b border-slate-200 dark:border-brand-border shrink-0 bg-white dark:bg-brand-card">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 flex items-center justify-center border border-slate-200 dark:border-slate-700">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white leading-tight" id="order-modal-title">Edit Pesanan</h3>
          <p class="text-xs font-medium text-slate-500 mt-0.5">Kelola rincian pesanan, dokumen, dan status proyek</p>
        </div>
      </div>
      <button type="button" onclick="closeOrderModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
        <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    
    <div class="overflow-y-auto flex-1 p-8 bg-slate-50 dark:bg-[#0D0E12]">
      <form id="order-form" class="space-y-8">
        <input type="hidden" id="order-id">
        
        <!-- Section 1: Klien & Proyek -->
        <div class="bg-white dark:bg-[#14151a] p-5 rounded-2xl border border-slate-200 dark:border-brand-border">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            Informasi Klien & Proyek
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Klien (User)</label>
              <div class="relative">
                <select id="order-user_id" required class="w-full pl-4 pr-10 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors appearance-none">
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-slate-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Nama Proyek</label>
              <input type="text" id="order-project_name" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
          </div>
        </div>

        <!-- Section 2: Paket & Domain -->
        <div class="bg-white dark:bg-[#14151a] p-5 rounded-2xl border border-slate-200 dark:border-brand-border">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
            Detail Layanan
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Jenis Website</label>
              <input type="text" id="order-website_type" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Domain Name</label>
              <input type="text" id="order-domain_name" placeholder="www.example.com" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Paket Layanan</label>
              <input type="text" id="order-package_name" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Nominal Harga Paket</label>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500 font-medium text-sm">Rp</div>
                <input type="text" id="order-package_price" placeholder="5.000.000" class="w-full pl-9 pr-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Deskripsi & Spesifikasi -->
        <div class="bg-white dark:bg-[#14151a] p-5 rounded-2xl border border-slate-200 dark:border-brand-border">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            Deskripsi & Spesifikasi
          </h4>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Description / Spesifikasi Lengkap</label>
              <textarea id="order-description" rows="4" placeholder="Jelaskan kebutuhan proyek secara lengkap..." class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors resize-y"></textarea>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Fitur yang Diinginkan</label>
              <textarea id="order-features" rows="3" placeholder="List fitur yang dibutuhkan..." class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors resize-y"></textarea>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Link Referensi</label>
              <input type="text" id="order-reference_links" placeholder="https://contoh.com, https://referensi.com" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Catatan Tambahan</label>
              <textarea id="order-notes" rows="2" placeholder="Catatan lainnya untuk tim..." class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors resize-y"></textarea>
            </div>
          </div>
        </div>

        <!-- Section 4: Status & Waktu -->
        <div class="bg-white dark:bg-[#14151a] p-5 rounded-2xl border border-slate-200 dark:border-brand-border">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Status & Waktu
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Status Pesanan</label>
              <div class="relative">
                <select id="order-status" required class="w-full pl-4 pr-10 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors appearance-none">
                  <option value="Pending DP">Pending DP</option>
                  <option value="Proses">Proses</option>
                  <option value="Revisi">Revisi</option>
                  <option value="Selesai">Selesai</option>
                  <option value="Batal">Batal</option>
                </select>
                <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none text-slate-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Tgl Start Project</label>
              <input type="date" id="order-start_date" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Target Selesai</label>
              <input type="date" id="order-target_date" class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
            </div>
          </div>
        </div>

        <!-- Section 4: Dokumen & Pembayaran -->
        <div class="bg-white dark:bg-[#14151a] p-5 rounded-2xl border border-slate-200 dark:border-brand-border">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            Dokumen & Pembayaran
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Dokumen Proyek</label>
              <input type="hidden" id="order-project_document">
              <input type="file" id="order-project_document-input" multiple onchange="uploadOrderFile(this, 'document')" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-brand-blue/10 file:text-brand-blue hover:file:bg-brand-blue/20 transition-colors">
              <div class="mt-2 text-[10px] text-slate-400">Pilih file PDF/Word/Zip</div>
              <!-- Display area for uploaded docs (read by uploadOrderFile & renderAdminUploadedDocs) -->
              <div id="project-doc-display" class="mt-2"></div>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Bukti Pembayaran</label>
              <input type="hidden" id="order-payment_proof">
              <input type="file" id="order-payment_proof-input" onchange="uploadOrderFile(this, 'payment')" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-brand-blue/10 file:text-brand-blue hover:file:bg-brand-blue/20 transition-colors">
              <div class="mt-2 text-[10px] text-slate-400">Pilih file JPG/PNG/PDF</div>
              <!-- Display area for payment proof (read by uploadOrderFile) -->
              <div id="payment-proof-display" class="mt-2"></div>
            </div>
          </div>
        </div>

        <!-- Section 5: Preferensi Desain -->
        <div class="bg-white dark:bg-[#14151a] p-5 rounded-2xl border border-slate-200 dark:border-brand-border">
          <h4 class="text-sm font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>
            Preferensi Desain
          </h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Primary Color</label>
              <div class="flex items-center gap-3">
                <input type="color" id="order-primary_color" class="w-10 h-10 p-1 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg cursor-pointer">
                <span class="text-xs text-slate-500 font-medium font-mono" id="primary-color-val">#000000</span>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Secondary Color</label>
              <div class="flex items-center gap-3">
                <input type="color" id="order-secondary_color" class="w-10 h-10 p-1 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg cursor-pointer">
                <span class="text-xs text-slate-500 font-medium font-mono" id="secondary-color-val">#000000</span>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-700 dark:text-slate-300 mb-2">Design Style</label>
            <input type="text" id="order-design_style" placeholder="Minimalis, Modern..." class="w-full px-4 py-2.5 bg-slate-50 dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl focus:border-brand-blue outline-none text-slate-900 dark:text-white text-sm transition-colors">
          </div>
        </div>

        <!-- Form Actions -->
        <div class="pt-6 pb-2 flex flex-wrap items-center justify-end gap-3 mt-8">
          <button type="button" onclick="closeOrderModal()" class="px-6 py-2.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors shadow-sm">Batal</button>
          <button type="button" onclick="submitOrderForm(event)" class="px-6 py-2.5 bg-brand-blue hover:bg-blue-600 text-white text-sm font-bold rounded-xl transition-colors shadow-sm">Simpan Data</button>
        </div>
      </form>
    </div>
  </div>
</div>
