<div class="bg-white dark:bg-brand-card rounded-2xl border border-slate-200 dark:border-brand-border p-5 relative flex flex-col justify-center h-[140px]">
  <div class="absolute top-5 right-5 text-slate-800 dark:text-slate-300">
    <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <%- svgPath %>
    </svg>
  </div>
  
  <div class="flex items-end gap-2 mb-3">
    <h3 class="text-6xl font-medium text-slate-900 dark:text-white leading-none tracking-tighter" id="<%= idName %>">-</h3>
    <span class="text-xs font-semibold text-emerald-500 mb-1"><%= locals.trendText || '+0 bulan ini' %></span>
  </div>
  
  <p class="text-[15px] font-medium text-slate-900 dark:text-slate-200"><%= title %></p>
</div>