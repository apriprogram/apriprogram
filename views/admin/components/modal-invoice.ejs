<!-- Invoice Modal (Side Panel Kanan) -->
<div id="invoice-modal" class="fixed inset-0 bg-slate-900/45 z-[9999] hidden opacity-0 transition-opacity duration-300" onclick="if(event.target===this)closeInvoiceModal()">
  <div class="fixed right-0 top-0 h-screen w-full sm:max-w-[1000px] bg-white dark:bg-brand-card border-l border-slate-200 dark:border-brand-border shadow-[-18px_0_60px_rgba(15,23,42,0.22)] overflow-hidden transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] flex flex-col rounded-none z-[10000]" id="invoice-modal-content">
    
    <!-- Modal Header -->
    <div class="flex items-center justify-between px-4 sm:px-6 py-3 sm:py-4 border-b border-slate-200 dark:border-brand-border shrink-0 bg-white dark:bg-brand-card">
      <div class="flex items-center gap-2 sm:gap-3">
        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-blue-100 dark:bg-blue-500/15 text-blue-600 dark:text-blue-400 flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <div>
          <h3 class="text-sm sm:text-base font-bold text-slate-900 dark:text-white leading-tight">Buat Invoice</h3>
          <p class="text-[10px] sm:text-[11px] font-medium text-slate-500 hidden sm:block">Generate invoice untuk pesanan klien</p>
        </div>
      </div>
      <div class="flex items-center gap-1.5 sm:gap-2">
        <button type="button" onclick="downloadInvoiceJPG()" title="Download JPG" class="flex items-center gap-1.5 px-2.5 py-1.5 sm:px-3 sm:py-2 bg-transparent border border-emerald-400/30 dark:border-emerald-500/30 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50/30 dark:hover:bg-emerald-500/10 text-[10px] sm:text-xs font-semibold rounded-lg transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          <span class="hidden sm:inline">JPG</span>
        </button>
        <button type="button" onclick="downloadInvoicePDF()" title="Download PDF" class="flex items-center gap-1.5 px-2.5 py-1.5 sm:px-3 sm:py-2 bg-transparent border border-red-400/30 dark:border-red-500/30 text-red-500 dark:text-red-400 hover:bg-red-50/30 dark:hover:bg-red-500/10 text-[10px] sm:text-xs font-semibold rounded-lg transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          <span class="hidden sm:inline">PDF</span>
        </button>
        <button type="button" onclick="saveInvoiceData()" id="invoice-save-btn" class="px-4 py-2 bg-brand-blue hover:bg-blue-600 text-white text-sm font-medium rounded-lg transition-colors shadow-sm inline-flex items-center justify-center gap-2 whitespace-nowrap">
          <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
          Simpan
        </button>
        <button type="button" onclick="closeInvoiceModal()" class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors p-1.5 sm:p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg ml-0.5">
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
    </div>

    <!-- Mobile Tabs: switch between form and preview on small screens -->
    <div class="flex lg:hidden border-b border-slate-200 dark:border-brand-border shrink-0 bg-white dark:bg-brand-card">
      <button id="inv-tab-form" onclick="switchInvoiceTab('form')" class="flex-1 py-2.5 text-xs font-bold text-brand-blue border-b-2 border-brand-blue transition-all">Form Input</button>
      <button id="inv-tab-preview" onclick="switchInvoiceTab('preview')" class="flex-1 py-2.5 text-xs font-bold text-slate-400 border-b-2 border-transparent transition-all">Preview Invoice</button>
    </div>

    <!-- Body: Split layout on desktop, tabbed on mobile -->
    <div class="flex flex-col lg:flex-row-reverse flex-1 min-h-0">

      <!-- Form Panel (right on desktop, tabbed on mobile) -->
      <div id="inv-panel-form" class="w-full lg:w-[420px] border-l border-slate-200 dark:border-brand-border overflow-y-auto p-4 sm:p-5 shrink-0 bg-slate-50 dark:bg-[#14151a] flex-1 lg:flex-none">
        <input type="hidden" id="invoice-order-id">

        <div class="space-y-4">
          <!-- Invoice Number & Date -->
          <div>
            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2.5">Info Invoice</label>
            <div class="space-y-2.5">
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">No. Invoice</label>
                <input type="text" id="inv-number" placeholder="INV-2026-001" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
              <div class="grid grid-cols-2 gap-2">
                <div>
                  <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Tgl. Terbit</label>
                  <input type="date" id="inv-issue-date" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
                </div>
                <div>
                  <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Tgl. Jatuh Tempo</label>
                  <input type="date" id="inv-due-date" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
                </div>
              </div>
            </div>
          </div>

          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Client Info -->
          <div>
            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2.5">Info Klien</label>
            <div class="space-y-2.5">
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Nama Klien / Perusahaan</label>
                <input type="text" id="inv-client-name" placeholder="Nama Klien" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Email Klien</label>
                <input type="text" id="inv-client-email" placeholder="email@client.com" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">WhatsApp / Telepon</label>
                <input type="text" id="inv-client-phone" placeholder="+62 xxx-xxxx-xxxx" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
            </div>
          </div>

          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Service Items -->
          <div>
            <div class="flex items-center justify-between mb-2.5">
              <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Item Layanan</label>
              <button type="button" onclick="addInvoiceItem()" class="px-4 py-2 bg-brand-blue hover:bg-blue-600 text-white text-sm font-medium rounded-lg transition-colors shadow-sm inline-flex items-center justify-center gap-2 whitespace-nowrap">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
                Tambah Item
              </button>
            </div>
            <div id="invoice-items-list" class="space-y-2"></div>
          </div>

          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Discount & Tax -->
          <div>
            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2.5">Diskon & Pajak</label>
            <div class="grid grid-cols-2 gap-2">
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Diskon (Rp)</label>
                <input type="number" id="inv-discount" value="0" min="0" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">PPN (%)</label>
                <input type="number" id="inv-tax" value="0" min="0" max="100" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
            </div>
          </div>

          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Bank / Payment Info -->
          <div>
            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2.5">Info Pembayaran</label>
            <div class="space-y-2.5">
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Nama Bank</label>
                <input type="text" id="inv-bank-name" placeholder="BCA, Mandiri, BNI..." class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">Nama Rekening</label>
                <input type="text" id="inv-bank-account-name" placeholder="Nama Pemilik Rekening" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
              <div>
                <label class="block text-xs font-semibold text-slate-700 dark:text-slate-300 mb-1">No. Rekening</label>
                <input type="text" id="inv-bank-account-number" placeholder="123-456-7890" class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
              </div>
            </div>
          </div>

          <div class="border-t border-dashed border-slate-200 dark:border-slate-700"></div>

          <!-- Notes -->
          <div>
            <label class="block text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2.5">Catatan</label>
            <textarea id="inv-notes" rows="6" placeholder="Terima kasih atas kepercayaan Anda..." class="w-full px-3 py-2 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors resize-y" oninput="updateInvoicePreview()"></textarea>
          </div>
        </div>
      </div>

      <!-- Preview Panel (left on desktop, tabbed on mobile) -->
      <div id="inv-panel-preview" class="hidden lg:flex flex-1 overflow-y-auto p-4 sm:p-5 bg-slate-100 dark:bg-[#0D0E12] items-start justify-center">
        <div class="w-full max-w-[540px]">
          <!-- Preview label -->
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Preview Invoice</span>
            <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700"></div>
          </div>
          <!-- Invoice Document: scale down on mobile -->
          <div class="invoice-preview-wrapper">
            <div id="invoice-preview" class="bg-white border border-slate-200 overflow-hidden">
              <!-- Invoice content will be rendered by JS -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* Scale down invoice preview on mobile so it fits the screen width */
@media (max-width: 1023px) {
  .invoice-preview-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  #invoice-preview {
    transform-origin: top left;
    width: 540px; /* fixed invoice width */
    transform: scale(0.62);
    margin-bottom: calc((540px * 0.62 - 540px));
  }
  #inv-panel-preview {
    overflow-y: auto !important;
    flex: 1 1 0%;
  }
}
</style>

<script>
function switchInvoiceTab(tab) {
  const formPanel = document.getElementById('inv-panel-form');
  const previewPanel = document.getElementById('inv-panel-preview');
  const tabForm = document.getElementById('inv-tab-form');
  const tabPreview = document.getElementById('inv-tab-preview');

  if (tab === 'form') {
    formPanel.classList.remove('hidden');
    formPanel.style.display = '';
    previewPanel.classList.add('hidden');
    previewPanel.style.display = 'none';
    tabForm.classList.add('text-brand-blue', 'border-brand-blue');
    tabForm.classList.remove('text-slate-400', 'border-transparent');
    tabPreview.classList.remove('text-brand-blue', 'border-brand-blue');
    tabPreview.classList.add('text-slate-400', 'border-transparent');
  } else {
    formPanel.classList.add('hidden');
    formPanel.style.display = 'none';
    previewPanel.classList.remove('hidden');
    previewPanel.style.display = 'flex';
    previewPanel.style.flexDirection = 'column';
    previewPanel.style.overflowY = 'auto';
    tabPreview.classList.add('text-brand-blue', 'border-brand-blue');
    tabPreview.classList.remove('text-slate-400', 'border-transparent');
    tabForm.classList.remove('text-brand-blue', 'border-brand-blue');
    tabForm.classList.add('text-slate-400', 'border-transparent');
  }
}
</script>

