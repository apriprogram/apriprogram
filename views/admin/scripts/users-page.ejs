<script>
let usersPage = 1;

function downloadUsersPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'landscape' });
  doc.setFontSize(14);
  doc.text('Data Users - Apriprogram', 14, 15);
  doc.setFontSize(9);
  doc.text(`Diekspor pada: ${new Date().toLocaleString('id-ID')}`, 14, 22);

  const rows = usersData.map((u, i) => [
    i + 1,
    u.full_name || '-',
    u.email || '-',
    u.role || '-',
    u.company || '-',
    u.whatsapp || '-',
    u.country || '-',
    u.created_at ? new Date(u.created_at).toLocaleDateString('id-ID') : '-'
  ]);

  doc.autoTable({
    startY: 27,
    head: [['No', 'Nama', 'Email', 'Role', 'Perusahaan', 'WhatsApp', 'Alamat', 'Terdaftar']],
    body: rows,
    theme: 'striped',
    headStyles: { fillColor: [59, 130, 246], fontSize: 8, fontStyle: 'bold' },
    bodyStyles: { fontSize: 7.5 },
    alternateRowStyles: { fillColor: [248, 250, 252] },
    margin: { left: 14, right: 14 }
  });

  doc.save(`users_${new Date().toISOString().slice(0,10)}.pdf`);
  showToast('PDF berhasil diunduh!', 'green');
}

function downloadUsersExcel() {
  const data = [
    ['No', 'Nama Lengkap', 'Email', 'Role', 'Perusahaan', 'WhatsApp', 'Alamat', 'Terdaftar'],
    ...usersData.map((u, i) => [
      i + 1,
      u.full_name || '-',
      u.email || '-',
      u.role || '-',
      u.company || '-',
      u.whatsapp || '-',
      u.country || '-',
      u.created_at ? new Date(u.created_at).toLocaleDateString('id-ID') : '-'
    ])
  ];

  const ws = XLSX.utils.aoa_to_sheet(data);
  ws['!cols'] = [{ wch: 5 }, { wch: 20 }, { wch: 25 }, { wch: 12 }, { wch: 20 }, { wch: 15 }, { wch: 20 }, { wch: 14 }];
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Users');
  XLSX.writeFile(wb, `users_${new Date().toISOString().slice(0,10)}.xlsx`);
  showToast('Excel berhasil diunduh!', 'green');
}

function openUserModal(id = '', email = '', role = 'client', fullname = '', whatsapp = '', company = '', country = '', avatar = '') {
  document.getElementById('user-modal').classList.remove('hidden');
  setTimeout(() => {
    document.getElementById('user-modal').classList.remove('opacity-0');
    document.getElementById('user-modal-content').classList.remove('scale-95');
  }, 10);

  document.getElementById('user-id').value = id;
  document.getElementById('user-email').value = email;
  document.getElementById('user-role').value = role;
  document.getElementById('user-password').value = '';
  document.getElementById('user-fullname').value = fullname || '';
  document.getElementById('user-whatsapp').value = whatsapp || '';
  document.getElementById('user-company').value = company || '';
  document.getElementById('user-country').value = country || '';
  document.getElementById('user-avatar').value = avatar || '';

  // Update modal avatar preview
  const previewEl = document.getElementById('modal-avatar-preview');
  const initialsEl = document.getElementById('modal-avatar-initials');
  const labelEl = document.getElementById('modal-avatar-label');
  if (avatar) {
    previewEl.innerHTML = `<img src="${avatar}" alt="Avatar" class="w-full h-full object-cover">`;
    if (labelEl) labelEl.innerText = 'Foto sudah diunggah';
  } else {
    const init = (fullname || email || '?').substring(0, 2).toUpperCase();
    previewEl.innerHTML = `<span id="modal-avatar-initials">${init}</span>`;
    if (labelEl) labelEl.innerText = 'Pilih foto...';
  }
  const fileInput = document.getElementById('modal-avatar-file');
  if (fileInput) fileInput.value = '';

  if (id) {
    document.getElementById('user-modal-title').innerText = 'Edit Pengguna';
    document.getElementById('user-password').required = false;
    document.getElementById('user-pass-note').innerText = '(Kosongkan jika tidak ingin diubah)';
  } else {
    document.getElementById('user-modal-title').innerText = 'Tambah Pengguna';
    document.getElementById('user-password').required = true;
    document.getElementById('user-pass-note').innerText = '(Wajib diisi)';
  }
}

function closeUserModal() {
  document.getElementById('user-modal').classList.add('opacity-0');
  document.getElementById('user-modal-content').classList.add('scale-95');
  setTimeout(() => document.getElementById('user-modal').classList.add('hidden'), 200);
}

async function uploadModalAvatar(input) {
  if (!input.files || !input.files[0]) return;
  const file = input.files[0];
  const label = document.getElementById('modal-avatar-label');
  if (label) label.innerText = 'Mengunggah...';

  try {
    let uploadFile = file;
    if (file.size > 2 * 1024 * 1024) {
      uploadFile = await compressImage(file);
    }
    const formData = new FormData();
    formData.append('avatar', uploadFile);
    const res = await fetch('/api/upload/avatar', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.success) {
      document.getElementById('user-avatar').value = data.url;
      const preview = document.getElementById('modal-avatar-preview');
      preview.innerHTML = `<img src="${data.url}" alt="Avatar" class="w-full h-full object-cover">`;
      if (label) label.innerText = file.name;
      showToast('Foto berhasil diunggah.', 'green');
    } else {
      showToast(data.message || 'Gagal mengunggah foto.', 'red');
      if (label) label.innerText = 'Pilih foto...';
    }
  } catch (err) {
    showToast('Terjadi kesalahan saat mengunggah.', 'red');
    if (label) label.innerText = 'Pilih foto...';
  } finally {
    input.value = '';
  }
}

function initUserForm() {
  const form = document.getElementById('user-form');
  if (!form) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('user-id').value;
    const email = document.getElementById('user-email').value;
    const role = document.getElementById('user-role').value;
    const password = document.getElementById('user-password').value;
    const full_name = document.getElementById('user-fullname').value;
    const whatsapp = document.getElementById('user-whatsapp').value;
    const company = document.getElementById('user-company').value;
    const country = document.getElementById('user-country').value;
    const avatar = document.getElementById('user-avatar').value;

    const method = id ? 'PUT' : 'POST';
    const url = id ? `/api/admin/users/${id}` : '/api/admin/users';
    const body = { email, role, full_name, whatsapp, company, country, avatar };
    if (password) body.password = password;

    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (data.success) {
        showToast(data.message, 'green');
        closeUserModal();
        loadUsers();
        loadDashboardStats();
      } else {
        showToast(data.message || 'Terjadi kesalahan.', 'red');
      }
    } catch (err) {
      showToast('Gagal menghubungi server.', 'red');
    }
  });
}

function deleteUser(id) {
  openDeleteModal(id, 'user');
}

function renderUsers() {
  const tbody = document.getElementById('users-table-body');
  const limitEl = document.getElementById('users-limit');
  const searchEl = document.getElementById('users-search');
  const sortEl = document.getElementById('users-sort');
  const filterEl = document.getElementById('users-filter');
  if (!tbody || !limitEl || !searchEl) return;

  const limit = parseInt(limitEl.value, 10) || 10;
  const search = searchEl.value.toLowerCase();
  const sort = sortEl ? sortEl.value : 'newest';
  const roleFilter = filterEl ? filterEl.value.toLowerCase() : '';

  let filtered = usersData.filter(u => {
    const matchSearch = (u.email || '').toLowerCase().includes(search) ||
                        (u.role || '').toLowerCase().includes(search) ||
                        (u.full_name || '').toLowerCase().includes(search) ||
                        (u.company || '').toLowerCase().includes(search) ||
                        (u.whatsapp || '').toLowerCase().includes(search) ||
                        (u.country || '').toLowerCase().includes(search);
    const matchRole = roleFilter === '' || (u.role || '').toLowerCase() === roleFilter;
    return matchSearch && matchRole;
  });

  if (sort === 'oldest') {
    filtered.sort((a, b) => new Date(a.created_at || 0) - new Date(b.created_at || 0));
  } else {
    // Newest
    filtered.sort((a, b) => new Date(b.created_at || 0) - new Date(a.created_at || 0));
  }

  const totalPages = Math.ceil(filtered.length / limit) || 1;
  if (usersPage > totalPages) usersPage = totalPages;

  const start = (usersPage - 1) * limit;
  const paginated = filtered.slice(start, start + limit);

  tbody.innerHTML = paginated.map((u, index) => {
    const sequentialId = start + index + 1;
    const initials = (u.full_name || u.email || '?').substring(0, 2).toUpperCase();
    const avatarHtml = u.avatar
      ? `<img src="${u.avatar}" alt="Avatar" class="w-7 h-7 sm:w-8 sm:h-8 rounded-md object-cover border border-slate-200 dark:border-brand-border">`
      : `<div class="w-7 h-7 sm:w-8 sm:h-8 rounded-md bg-gradient-to-br from-brand-blue to-blue-700 flex items-center justify-center text-white font-bold text-[9px] sm:text-[10px] border border-brand-blue/30">${initials}</div>`;
    return `
    <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 font-medium whitespace-nowrap text-[10px] sm:text-xs">${sequentialId}</td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 whitespace-nowrap">
        <div class="flex items-center gap-2">
          ${avatarHtml}
          <div>
            <p class="text-[11px] sm:text-xs font-semibold text-slate-900 dark:text-white">${u.full_name || '-'}</p>
            <p class="text-[10px] text-slate-500 dark:text-slate-400">${u.email || '-'}</p>
          </div>
        </div>
      </td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 whitespace-nowrap text-[10px] sm:text-xs text-slate-600 dark:text-slate-400">${u.company || '-'}</td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 whitespace-nowrap text-[10px] sm:text-xs text-slate-600 dark:text-slate-400">${u.whatsapp || '-'}</td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 whitespace-nowrap text-[10px] sm:text-xs">
        <span class="px-1.5 py-0.5 sm:px-2 sm:py-0.5 text-[9px] sm:text-[10px] font-bold tracking-wider uppercase rounded ${u.role === 'super admin' || u.role === 'admin' ? 'bg-blue-100 dark:bg-[#3b82f6]/20 text-blue-700 dark:text-[#3b82f6]' : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400'}">${u.role || '-'}</span>
      </td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 whitespace-nowrap text-[10px] sm:text-xs text-slate-500">${u.country || '-'}</td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 whitespace-nowrap text-[10px] sm:text-xs text-slate-500">${u.created_at ? new Date(u.created_at).toLocaleDateString('id-ID') : '-'}</td>
      <td class="py-1.5 px-2 sm:py-2 sm:px-3 text-center whitespace-nowrap">
        <div class="flex justify-center gap-1.5">
          ${getActionButtonHtml('edit', `openUserModal(${u.id}, ${jsStringLiteral(u.email)}, ${jsStringLiteral(u.role || 'client')}, ${jsStringLiteral(u.full_name || '')}, ${jsStringLiteral(u.whatsapp || '')}, ${jsStringLiteral(u.company || '')}, ${jsStringLiteral(u.country || '')}, ${jsStringLiteral(u.avatar || '')})`, 'Edit')}
          ${getActionButtonHtml('delete', `deleteUser(${u.id})`, 'Hapus')}
        </div>
      </td>
    </tr>
  `}).join('');

  if (paginated.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8" class="py-8 text-center text-slate-500">Tidak ada data ditemukan.</td></tr>';
  }

  const paginationEl = document.getElementById('users-pagination');
  if (paginationEl) {
    let pageOptions = '';
    for (let i = 1; i <= totalPages; i++) {
      pageOptions += `<option value="${i}" ${i === usersPage ? 'selected' : ''}>${i} / ${totalPages}</option>`;
    }
    
    paginationEl.innerHTML = `
      <div class="flex items-center gap-3 w-full sm:w-auto justify-center sm:justify-start">
        <span class="text-[11px] sm:text-xs text-slate-600 dark:text-slate-400 font-medium">Rows per page</span>
        <div class="relative">
          <select onchange="document.getElementById('users-limit').value = this.value; filterUsers()" class="pl-3 pr-7 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium shadow-sm">
            <option value="10" ${limit === 10 ? 'selected' : ''}>10</option>
            <option value="25" ${limit === 25 ? 'selected' : ''}>25</option>
            <option value="50" ${limit === 50 ? 'selected' : ''}>50</option>
          </select>
          <svg class="w-3.5 h-3.5 text-slate-400 absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path></svg>
        </div>
      </div>

      <div class="flex items-center gap-4 sm:gap-6 w-full sm:w-auto justify-center sm:justify-end mt-2 sm:mt-0">
        <div class="flex items-center gap-3">
          <span class="text-[11px] sm:text-xs text-slate-600 dark:text-slate-400 font-medium">Page</span>
          <div class="relative">
            <select onchange="usersPage = parseInt(this.value); renderUsers()" class="pl-3 pr-7 py-1.5 bg-white dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-slate-700 dark:text-slate-300 focus:outline-none focus:border-brand-blue appearance-none cursor-pointer text-[11px] sm:text-xs font-medium shadow-sm">
               ${pageOptions}
            </select>
            <svg class="w-3.5 h-3.5 text-slate-400 absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path></svg>
          </div>
        </div>
        
        <div class="flex items-center rounded-lg border border-slate-200 dark:border-brand-border bg-white dark:bg-[#14151a] shadow-sm overflow-hidden shrink-0">
          <button onclick="usersPage = 1; renderUsers()" ${usersPage === 1 ? 'disabled' : ''} class="px-2.5 py-1.5 border-r border-slate-200 dark:border-brand-border text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path></svg>
          </button>
          <button onclick="usersPage--; renderUsers()" ${usersPage === 1 ? 'disabled' : ''} class="px-2.5 py-1.5 border-r border-slate-200 dark:border-brand-border text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
          </button>
          <button onclick="usersPage++; renderUsers()" ${usersPage === totalPages ? 'disabled' : ''} class="px-2.5 py-1.5 border-r border-slate-200 dark:border-brand-border text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </button>
          <button onclick="usersPage = ${totalPages}; renderUsers()" ${usersPage === totalPages ? 'disabled' : ''} class="px-2.5 py-1.5 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
          </button>
        </div>
      </div>
    `;
  }
}

function filterUsers() {
  usersPage = 1;
  renderUsers();
}

async function loadUsers() {
  try {
    const res = await fetch('/api/admin/users');
    const data = await res.json();
    if (data.success) {
      usersData = data.users || [];
      const badge = document.getElementById('badge-users');
      if (badge) {
        badge.innerText = usersData.length;
        if (usersData.length > 0) {
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      }
      renderUsers();
    }
  } catch (err) {
    console.error('Failed to load users', err);
  }
}

</script>