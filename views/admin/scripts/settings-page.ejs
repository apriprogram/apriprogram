<script>
const settingFields = {
  navbar: ['logo_text', 'logo_image', 'link1_text', 'link2_text', 'link3_text', 'link4_text', 'link5_text'],
  hero: ['title_main', 'title_gradient', 'subtitle', 'cta_text', 'cta_link', 'backgrounds_data'],
  services: ['title', 'subtitle', 'button_text', 'button_link'],
  projects: ['title', 'subtitle'],
  timeline: ['title', 'subtitle'],
  faq: ['title', 'subtitle', 'button_text', 'button_link'],
  cta: ['title', 'subtitle', 'button_text', 'button_link'],
  footer: ['description', 'copyright']
};

function updateImagePreview(prefix) {
  let url = '';
  if (prefix === 'navbar-logo') {
    const el = document.getElementById('navbar-logo_image');
    if (el) url = el.value;
  } else {
    const el = document.getElementById(`${prefix}-image`);
    if (el) url = el.value;
  }
  const container = document.getElementById(`${prefix}-preview-container`);
  const img = document.getElementById(`${prefix}-preview`);
  if (container && img) {
    if (url && url.trim() !== '') {
      img.src = url;
      container.classList.remove('hidden');
    } else {
      img.src = '';
      container.classList.add('hidden');
    }
  }
}

let servicesData = [];
let navbarLinks = [];

function renderNavbarLinks() {
  const container = document.getElementById('navbarLinksList');
  if (!container) return;
  
  if (navbarLinks.length === 0) {
    container.innerHTML = '<p class="text-[10px] sm:text-xs text-slate-500 text-center py-4 bg-slate-50 dark:bg-brand-dark rounded-xl border border-dashed border-slate-200 dark:border-brand-border">Belum ada menu navigasi.</p>';
  } else {
    container.innerHTML = navbarLinks.map((link, index) => `
      <div class="flex gap-2 items-center bg-slate-50 dark:bg-brand-dark p-2 rounded-xl border border-slate-200 dark:border-brand-border">
        <div class="flex-1">
          <input type="text" placeholder="Teks Menu (cth: Layanan)" value="${link.text}" onchange="updateNavbarLink(${index}, 'text', this.value)" class="w-full px-3 py-1.5 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg focus:border-brand-blue outline-none text-slate-900 dark:text-white text-xs mb-2">
          <input type="text" placeholder="Link/ID (cth: #services)" value="${link.url}" onchange="updateNavbarLink(${index}, 'url', this.value)" class="w-full px-3 py-1.5 bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-lg focus:border-brand-blue outline-none text-slate-900 dark:text-white text-xs">
        </div>
        <button type="button" onclick="removeNavbarLink(${index})" class="w-8 h-8 rounded-lg bg-red-100 text-red-500 hover:bg-red-500 hover:text-white dark:bg-red-500/10 dark:hover:bg-red-500/20 flex items-center justify-center shrink-0 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
      </div>
    `).join('');
  }
  
  const hiddenInput = document.getElementById('navbar-nav_links_data');
  if (hiddenInput) {
    hiddenInput.value = JSON.stringify(navbarLinks);
  }
}

function addNavbarLink() {
  navbarLinks.push({ text: '', url: '' });
  renderNavbarLinks();
}

function updateNavbarLink(index, field, value) {
  if (navbarLinks[index]) {
    navbarLinks[index][field] = value;
    document.getElementById('navbar-nav_links_data').value = JSON.stringify(navbarLinks);
  }
}

function removeNavbarLink(index) {
  navbarLinks.splice(index, 1);
  renderNavbarLinks();
}


function showSettingSection(section) {
  document.querySelectorAll('.setting-form').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.setting-nav').forEach(el => {
    el.className = 'setting-nav w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-50 dark:hover:bg-brand-darker mb-0.5 transition-colors';
  });

  const form = document.getElementById(`form-${section}`);
  const activeBtn = document.getElementById(`btn-${section}`);
  if (form) form.classList.remove('hidden');
  if (activeBtn) {
    activeBtn.className = 'setting-nav active w-full text-left px-3 py-2.5 rounded-lg text-sm font-medium bg-slate-100 dark:bg-brand-darker text-brand-blue dark:text-white mb-0.5 transition-colors';
  }
}

async function loadSettings() {
  try {
    const res = await fetch('/api/settings');
    const data = await res.json();
    if (!data.success) return;

    Object.keys(data.settings || {}).forEach(section => {
      const sectionData = data.settings[section] || {};
      Object.keys(sectionData).forEach(key => {
        const el = document.getElementById(`${section}-${key}`);
        if (!el) return;
        if (el.tagName === 'IMG') el.src = sectionData[key];
        else el.value = sectionData[key] || '';

        if (section === 'hero' && key === 'backgrounds_data' && sectionData[key]) {
          try {
            heroBackgrounds = JSON.parse(sectionData[key]);
            if (!Array.isArray(heroBackgrounds)) heroBackgrounds = [];
            renderHeroBackgrounds();
          } catch(e) {
            heroBackgrounds = [];
          }
        }
        
        if (section === 'navbar' && key === 'nav_links_data' && sectionData[key]) {
          try {
            navbarLinks = JSON.parse(sectionData[key]);
            if (!Array.isArray(navbarLinks)) navbarLinks = [];
            renderNavbarLinks();
          } catch(e) {
            navbarLinks = [];
          }
        }
      });
    });
    updateImagePreview('navbar-logo');
  } catch (err) {
    console.error('Failed to load settings', err);
  }
}

async function saveSection(section, settings) {
  try {
    const res = await fetch('/api/admin/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ section, settings })
    });
    const data = await res.json();
    if (data.success) {
      showToast(`Berhasil menyimpan pengaturan ${section}`, 'green');
    } else {
      showToast(`Gagal menyimpan: ${data.message}`, 'red');
    }
  } catch (err) {
    showToast('Terjadi kesalahan koneksi saat menyimpan.', 'red');
  }
}

function collectSettings(section) {
  return (settingFields[section] || []).reduce((result, key) => {
    const el = document.getElementById(`${section}-${key}`);
    result[key] = el ? el.value : '';
    return result;
  }, {});
}

function initSettingsForms() {
  Object.keys(settingFields).forEach(section => {
    const form = document.getElementById(`form-${section}`);
    if (!form) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      saveSection(section, collectSettings(section));
    });
  });
}

async function loadServices() {
  try {
    const res = await fetch('/api/admin/services');
    const data = await res.json();
    if (data.success) {
      servicesData = data.services || [];
      renderServicesTable();
    }
  } catch (err) {
    console.error('Failed to load services', err);
  }
}

function renderServicesTable() {
  const tbody = document.getElementById('services-table-body');
  if (!tbody) return;

  if (servicesData.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" class="py-8 text-center text-slate-400">Belum ada data service.</td></tr>';
    return;
  }

  tbody.innerHTML = servicesData.map(s => `
    <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs">
        <div class="flex items-center gap-3">
          ${s.image ? `<img src="${s.image}" class="w-10 h-10 rounded-lg object-cover shrink-0 border border-slate-200 dark:border-brand-border" onerror="this.style.display='none'">` : '<div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0"></div>'}
          <div>
            <div class="font-medium text-slate-900 dark:text-white text-sm">${s.title || '-'}</div>
            <div class="text-[11px] text-slate-400 font-mono">${s.slug || ''}</div>
          </div>
        </div>
      </td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-sm text-slate-500 whitespace-nowrap">${s.category || '-'}</td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${s.status === 'active' ? 'bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-green-400 border-green-200/50 dark:border-green-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${s.status || 'active'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${s.featured === 'featured' ? 'bg-amber-100 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-200/50 dark:border-amber-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${s.featured || '-'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-center whitespace-nowrap"><div class="flex justify-center gap-2">${getActionButtonHtml('edit', `openServiceModal(${jsStringLiteral(s.slug)})`, 'Edit')}${getActionButtonHtml('delete', `deleteService(${jsStringLiteral(s.slug)})`, 'Hapus')}</div></td>
    </tr>
  `).join('');
}

function openServiceModal(slug = '') {
  const modal = document.getElementById('service-modal');
  const content = document.getElementById('service-modal-content');
  document.getElementById('service-modal-title').textContent = slug ? 'Edit Service' : 'Tambah Service';

  ['title', 'slug', 'category', 'short_description', 'description', 'image', 'button_text', 'button_link', 'sort_order', 'meta_title', 'meta_description', 'publish_date'].forEach(field => {
    const el = document.getElementById(`service-${field}`);
    if (el) el.value = field === 'button_text' ? 'Read details' : field === 'button_link' ? '#contact' : field === 'sort_order' ? '1' : '';
  });
  document.getElementById('service-status').value = 'active';
  document.getElementById('service-featured').value = 'featured';
  document.getElementById('service-original-key').value = '';

  if (slug) {
    const svc = servicesData.find(s => s.slug === slug);
    if (svc) {
      document.getElementById('service-original-key').value = slug;
      Object.keys(svc).forEach(field => {
        const el = document.getElementById(`service-${field}`);
        if (el && svc[field] !== undefined && svc[field] !== null) el.value = svc[field];
      });
      document.getElementById('service-status').value = svc.status || 'active';
      document.getElementById('service-featured').value = svc.featured || 'featured';
    }
  }

  document.getElementById('service-title').oninput = function() {
    if (!document.getElementById('service-original-key').value) {
      document.getElementById('service-slug').value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }
  };

  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.remove('opacity-0');
    content.classList.remove('translate-x-full');
  }, 10);
  updateImagePreview('service');
}

function closeServiceModal() {
  const modal = document.getElementById('service-modal');
  const content = document.getElementById('service-modal-content');
  modal.classList.add('opacity-0');
  content.classList.add('translate-x-full');
  setTimeout(() => modal.classList.add('hidden'), 300);
}

async function saveServiceItem() {
  const value = id => document.getElementById(`service-${id}`).value;
  const payload = {
    original_key: document.getElementById('service-original-key').value,
    title: value('title'),
    slug: value('slug'),
    category: value('category'),
    short_description: value('short_description'),
    description: value('description'),
    image: value('image'),
    button_text: value('button_text'),
    button_link: value('button_link'),
    sort_order: value('sort_order'),
    status: value('status'),
    featured: value('featured'),
    meta_title: value('meta_title'),
    meta_description: value('meta_description'),
    publish_date: document.getElementById('service-publish_date') ? value('publish_date') : null
  };

  if (!payload.title || !payload.slug) {
    showToast('Judul dan Slug wajib diisi!', 'red');
    return;
  }

  try {
    const res = await fetch('/api/admin/services', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showToast('Service berhasil disimpan!', 'green');
      closeServiceModal();
      loadServices();
    } else {
      showToast(data.message || 'Gagal menyimpan.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function deleteService(slug) {
  if (!confirm(`Hapus service "${slug}"?`)) return;
  try {
    const res = await fetch(`/api/admin/services/${slug}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      showToast('Service dihapus.', 'green');
      loadServices();
    } else {
      showToast(data.message || 'Gagal menghapus.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function uploadServiceImage(input) {
  const file = input.files[0];
  if (!file) return;

  const fd = new FormData();
  fd.append('image', file);
  try {
    const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.success) {
      document.getElementById('service-image').value = data.url;
      showToast('Gambar diupload!', 'green');
      updateImagePreview('service');
    } else {
      showToast(data.message || 'Gagal upload.', 'red');
    }
  } catch (err) {
    showToast('Gagal upload.', 'red');
  } finally {
    input.value = '';
  }
}

async function uploadNavbarLogo(input) {
  const file = input.files[0];
  if (!file) return;

  const fd = new FormData();
  fd.append('image', file);
  try {
    const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.success) {
      document.getElementById('navbar-logo_image').value = data.url;
      showToast('Logo berhasil diupload!', 'green');
      updateImagePreview('navbar-logo');
    } else {
      showToast(data.message || 'Gagal upload logo.', 'red');
    }
  } catch (err) {
    showToast('Gagal upload logo.', 'red');
  } finally {
    input.value = '';
  }
}

let projectsData = [];

async function loadProjects() {
  try {
    const res = await fetch('/api/admin/projects');
    const data = await res.json();
    if (data.success) {
      projectsData = data.projects || [];
      renderProjectsTable();
    }
  } catch (err) {
    console.error('Failed to load projects', err);
  }
}

function renderProjectsTable() {
  const tbody = document.getElementById('projects-table-body');
  if (!tbody) return;

  if (projectsData.length === 0) {
    tbody.innerHTML = '<tr><td colspan="5" class="py-8 text-center text-slate-400">Belum ada data project.</td></tr>';
    return;
  }

  tbody.innerHTML = projectsData.map(p => `
    <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs">
        <div class="flex items-center gap-3">
          ${p.image ? `<img src="${p.image}" class="w-10 h-10 rounded-lg object-cover shrink-0 border border-slate-200 dark:border-brand-border" onerror="this.style.display='none'">` : '<div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0"></div>'}
          <div>
            <div class="font-medium text-slate-900 dark:text-white text-sm">${p.title || '-'}</div>
            <div class="text-[11px] text-slate-400 font-mono">${p.slug || ''}</div>
          </div>
        </div>
      </td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-sm text-slate-500 whitespace-nowrap">${p.category || '-'}</td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${p.status === 'active' ? 'bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-green-400 border-green-200/50 dark:border-green-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${p.status || 'active'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${p.featured === 'featured' ? 'bg-amber-100 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-200/50 dark:border-amber-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${p.featured || '-'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-center whitespace-nowrap"><div class="flex justify-center gap-2">${getActionButtonHtml('edit', `openProjectModal('${p.slug}')`, 'Edit')}${getActionButtonHtml('delete', `deleteProject('${p.slug}')`, 'Hapus')}</div></td>
    </tr>
  `).join('');
}

function openProjectModal(slug = '') {
  const modal = document.getElementById('project-modal');
  const content = document.getElementById('project-modal-content');
  document.getElementById('project-modal-title').textContent = slug ? 'Edit Project' : 'Tambah Project';

  ['title', 'slug', 'client_name', 'category', 'short_description', 'description', 'image', 'image_alt', 'technology_stack', 'project_url', 'detail_url', 'button_text', 'sort_order', 'meta_title', 'meta_description'].forEach(field => {
    const el = document.getElementById(`project-${field}`);
    if (el) el.value = field === 'button_text' ? 'Lihat detail' : field === 'sort_order' ? '1' : '';
  });
  document.getElementById('project-status').value = 'active';
  document.getElementById('project-featured').value = 'featured';
  document.getElementById('project-original-key').value = '';

  if (slug) {
    const proj = projectsData.find(p => p.slug === slug);
    if (proj) {
      document.getElementById('project-original-key').value = slug;
      Object.keys(proj).forEach(field => {
        const el = document.getElementById(`project-${field}`);
        if (el && proj[field] !== undefined && proj[field] !== null) el.value = proj[field];
      });
      document.getElementById('project-status').value = proj.status || 'active';
      document.getElementById('project-featured').value = proj.featured || 'featured';
    }
  }

  document.getElementById('project-title').oninput = function() {
    if (!document.getElementById('project-original-key').value) {
      document.getElementById('project-slug').value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }
  };

  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.remove('opacity-0');
    content.classList.remove('translate-x-full');
  }, 10);
  updateImagePreview('project');
}

function closeProjectModal() {
  const modal = document.getElementById('project-modal');
  const content = document.getElementById('project-modal-content');
  modal.classList.add('opacity-0');
  content.classList.add('translate-x-full');
  setTimeout(() => modal.classList.add('hidden'), 300);
}

