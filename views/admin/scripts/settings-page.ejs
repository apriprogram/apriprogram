    const res = await fetch('/api/admin/timeline', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showToast('Timeline berhasil disimpan!', 'green');
      closeTimelineModal();
      loadTimelines();
    } else {
      showToast(data.message || 'Gagal menyimpan.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function deleteTimeline(slug) {
  if (!confirm(`Hapus timeline "${slug}"?`)) return;
  try {
    const res = await fetch(`/api/admin/timeline/${slug}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      showToast('Timeline dihapus.', 'green');
      loadTimelines();
    } else {
      showToast(data.message || 'Gagal menghapus.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function uploadTimelineImage(input) {
  const file = input.files[0];
  if (!file) return;

  const fd = new FormData();
  fd.append('image', file);
  try {
    const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.success) {
      document.getElementById('timeline-image').value = data.url;
      showToast('Gambar diupload!', 'green');
    } else {
      showToast(data.message || 'Gagal upload.', 'red');
    }
  } catch (err) {
    showToast('Gagal upload.', 'red');
  } finally {
    input.value = '';
  }
}
</script>