// --- Hero Backgrounds Logic ---

let heroBackgrounds = [];

function renderHeroBackgrounds() {
  const container = document.getElementById('hero-backgrounds-container');
  const hiddenInput = document.getElementById('hero-backgrounds_data');
  if(!container || !hiddenInput) return;

  hiddenInput.value = JSON.stringify(heroBackgrounds);

  if (heroBackgrounds.length === 0) {
    container.innerHTML = '<div class="col-span-full text-center py-4 text-xs text-slate-500">Belum ada background.</div>';
    return;
  }

  container.innerHTML = heroBackgrounds.map((bgUrl, index) => `
    <div class="relative group rounded-lg overflow-hidden border border-slate-200 dark:border-brand-border h-24 sm:h-32">
      <img src="${bgUrl}" class="w-full h-full object-cover">
      <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
        <button type="button" onclick="removeHeroBackground(${index})" class="text-white bg-red-500 hover:bg-red-600 rounded-full p-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
      </div>
    </div>
  `).join('');
}

function removeHeroBackground(index) {
  heroBackgrounds.splice(index, 1);
  renderHeroBackgrounds();
}

async function uploadHeroBackground(input) {
  if (!input.files || input.files.length === 0) return;
  const file = input.files[0];
  const formData = new FormData();
  formData.append('image', file);

  try {
    const res = await fetch('/api/admin/upload', { method: 'POST', body: formData });
    const data = await res.json();
    if (data.success && data.url) {
      heroBackgrounds.push(data.url);
      renderHeroBackgrounds();
    } else {
      showToast('Gagal upload gambar', 'red');
    }
  } catch (err) {
    showToast('Terjadi kesalahan', 'red');
  } finally {
    input.value = '';
  }
}


// --- Timeline Logic ---

let timelinesData = [];

async function loadTimelines() {
  try {
    const res = await fetch('/api/admin/timeline');
    const data = await res.json();
    if (data.success) {
      timelinesData = data.data || [];
      renderTimelinesTable();
    }
  } catch (err) {
    console.error('Failed to load timelines', err);
  }
}

function renderTimelinesTable() {
  const tbody = document.getElementById('timeline-table-body');
  if (!tbody) return;

  if (timelinesData.length === 0) {
    tbody.innerHTML = '<tr><td colspan="4" class="py-8 text-center text-slate-400">Belum ada data timeline.</td></tr>';
    return;
  }

  tbody.innerHTML = timelinesData.sort((a,b)=>a.sort_order - b.sort_order).map(t => `
    <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs">
        <span class="font-bold text-slate-900 dark:text-white">Step ${t.step_number || '-'}</span>
      </td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs">
        <div class="flex items-center gap-3">
          ${t.image ? `<img src="${t.image}" class="w-10 h-10 rounded-lg object-cover shrink-0 border border-slate-200 dark:border-brand-border" onerror="this.style.display='none'">` : '<div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0"></div>'}
          <div>
            <div class="font-medium text-slate-900 dark:text-white text-sm">${t.title || '-'}</div>
            <div class="text-[11px] text-slate-400 font-mono">${t.slug || ''}</div>
          </div>
        </div>
      </td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${t.status === 'active' ? 'bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-green-400 border-green-200/50 dark:border-green-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${t.status || 'active'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-center whitespace-nowrap"><div class="flex justify-center gap-2">${getActionButtonHtml('edit', `openTimelineModal('${t.slug}')`, 'Edit')}${getActionButtonHtml('delete', `deleteTimeline('${t.slug}')`, 'Hapus')}</div></td>
    </tr>
  `).join('');
}

function openTimelineModal(slug = '') {
  const modal = document.getElementById('timeline-modal');
  const content = document.getElementById('timeline-modal-content');
  document.getElementById('timeline-modal-title').textContent = slug ? 'Edit Timeline' : 'Tambah Timeline';

  ['step_number', 'step_label', 'icon', 'title', 'slug', 'short_description', 'description', 'image', 'image_alt', 'layout_position', 'button_text', 'button_link', 'sort_order', 'meta_title', 'meta_description'].forEach(field => {
    const el = document.getElementById(`timeline-${field}`);
    if (el) el.value = field === 'sort_order' ? '1' : field === 'layout_position' ? 'left' : '';
  });
  document.getElementById('timeline-status').value = 'active';
  document.getElementById('timeline-original-key').value = '';

  if (slug) {
    const tItem = timelinesData.find(t => t.slug === slug);
    if (tItem) {
      document.getElementById('timeline-original-key').value = slug;
      Object.keys(tItem).forEach(field => {
        const el = document.getElementById(`timeline-${field}`);
        if (el && tItem[field] !== undefined && tItem[field] !== null) el.value = tItem[field];
      });
      document.getElementById('timeline-status').value = tItem.status || 'active';
    }
  }

  document.getElementById('timeline-title').oninput = function() {
    if (!document.getElementById('timeline-original-key').value) {
      document.getElementById('timeline-slug').value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }
  };

  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.remove('opacity-0');
    content.classList.remove('translate-x-full');
  }, 10);
  updateImagePreview('timeline');
}

function closeTimelineModal() {
  const modal = document.getElementById('timeline-modal');
  const content = document.getElementById('timeline-modal-content');
  modal.classList.add('opacity-0');
  content.classList.add('translate-x-full');
  setTimeout(() => modal.classList.add('hidden'), 300);
}

async function saveTimelineItem() {
  const value = id => document.getElementById(`timeline-${id}`).value;
  const payload = {
    original_key: document.getElementById('timeline-original-key').value,
    step_number: value('step_number'),
    step_label: value('step_label'),
    icon: value('icon'),
    title: value('title'),
    slug: value('slug'),
    short_description: value('short_description'),
    description: value('description'),
    image: value('image'),
    image_alt: value('image_alt'),
    layout_position: value('layout_position'),
    button_text: value('button_text'),
    button_link: value('button_link'),
    sort_order: value('sort_order'),
    status: value('status'),
    meta_title: value('meta_title'),
    meta_description: value('meta_description')
  };

  if (!payload.title || !payload.slug) {
    showToast('Title dan Slug wajib diisi!', 'red');
    return;
  }

  try {
    const res = await fetch('/api/admin/timeline', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showToast('Timeline berhasil disimpan!', 'green');
      closeTimelineModal();
      loadTimelines();
    } else {
      showToast(data.message || 'Gagal menyimpan.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

// --- FAQ Logic ---

let faqsData = [];

async function loadFaqs() {
  try {
    const res = await fetch('/api/admin/faq');
    const data = await res.json();
    if (data.success) {
      faqsData = data.data || [];
      renderFaqsTable();
    }
  } catch (err) {
    console.error('Failed to load faqs', err);
  }
}

function renderFaqsTable() {
  const tbody = document.getElementById('faq-table-body');
  if (!tbody) return;

  if (faqsData.length === 0) {
    tbody.innerHTML = '<tr><td colspan="4" class="py-8 text-center text-slate-400">Belum ada data FAQ.</td></tr>';
    return;
  }

  tbody.innerHTML = faqsData.map(f => `
    <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-sm text-slate-900 dark:text-white font-medium break-words whitespace-normal max-w-[200px] sm:max-w-[300px]"><div class="line-clamp-2">${f.question || '-'}</div></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-xs text-slate-600 dark:text-slate-400">${f.sort_order || 0}</td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${f.status === 'active' ? 'bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-green-400 border-green-200/50 dark:border-green-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${f.status || 'active'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-center whitespace-nowrap"><div class="flex justify-center gap-2">${getActionButtonHtml('edit', `openFaqModal('${f.slug}')`, 'Edit')}${getActionButtonHtml('delete', `deleteFaqItem('${f.slug}')`, 'Hapus')}</div></td>
    </tr>
  `).join('');
}

function openFaqModal(slug = '') {
  const modal = document.getElementById('faq-modal');
  const content = document.getElementById('faq-modal-content');
  document.getElementById('faq-modal-title').textContent = slug ? 'Edit FAQ' : 'Tambah FAQ';

  ['slug', 'question', 'answer', 'sort_order'].forEach(field => {
    const el = document.getElementById(`faqitem-${field}`);
    if (el) el.value = field === 'sort_order' ? '1' : '';
  });
  document.getElementById('faqitem-status').value = 'active';
  document.getElementById('faqitem-original-key').value = '';

  if (slug) {
    const fItem = faqsData.find(f => f.slug === slug);
    if (fItem) {
      document.getElementById('faqitem-original-key').value = slug;
      Object.keys(fItem).forEach(field => {
        const el = document.getElementById(`faqitem-${field}`);
        if (el && fItem[field] !== undefined && fItem[field] !== null) el.value = fItem[field];
      });
      document.getElementById('faqitem-status').value = fItem.status || 'active';
    }
  }

  document.getElementById('faqitem-question').oninput = function() {
    if (!document.getElementById('faqitem-original-key').value) {
      document.getElementById('faqitem-slug').value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }
  };

  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.remove('opacity-0');
    content.classList.remove('translate-x-full');
  }, 10);
}

function closeFaqModal() {
  const modal = document.getElementById('faq-modal');
  const content = document.getElementById('faq-modal-content');
  modal.classList.add('opacity-0');
  content.classList.add('translate-x-full');
  setTimeout(() => modal.classList.add('hidden'), 300);
}

async function saveFaqItem() {
  const value = id => document.getElementById(`faqitem-${id}`).value;
  const payload = {
    original_key: value('original-key'),
    slug: value('slug'),
    question: value('question'),
    answer: value('answer'),
    sort_order: value('sort_order'),
    status: value('status')
  };

  if (!payload.question) {
    showToast('Pertanyaan wajib diisi!', 'red');
    return;
  }

  try {
    const res = await fetch('/api/admin/faq', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showToast('FAQ berhasil disimpan!', 'green');
      closeFaqModal();
      loadFaqs();
    } else {
      showToast(data.message || 'Gagal menyimpan.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function deleteFaqItem(slug) {
  if (!confirm(`Hapus FAQ ini?`)) return;
  try {
    const res = await fetch(`/api/admin/faq/${slug}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      showToast('FAQ dihapus.', 'green');
      loadFaqs();
    } else {
      showToast(data.message || 'Gagal menghapus.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function deleteTimeline(slug) {
  if (!confirm(`Hapus timeline "${slug}"?`)) return;
  try {
    const res = await fetch(`/api/admin/timeline/${slug}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) {
      showToast('Timeline dihapus.', 'green');
      loadTimelines();
    } else {
      showToast(data.message || 'Gagal menghapus.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  }
}

async function uploadTimelineImage(input) {
  const file = input.files[0];
  if (!file) return;

  const fd = new FormData();
  fd.append('image', file);
  try {
    const res = await fetch('/api/admin/upload', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.success) {
      document.getElementById('timeline-image').value = data.url;
      showToast('Gambar diupload!', 'green');
      updateImagePreview('timeline');
    } else {
      showToast(data.message || 'Gagal upload.', 'red');
    }
  } catch (err) {
    showToast('Gagal upload.', 'red');
  } finally {
    input.value = '';
  }
}
</script>