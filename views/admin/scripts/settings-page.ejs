// --- Timeline Logic ---

let timelinesData = [];

async function loadTimelines() {
  try {
    const res = await fetch('/api/admin/timeline');
    const data = await res.json();
    if (data.success) {
      timelinesData = data.data || [];
      renderTimelinesTable();
    }
  } catch (err) {
    console.error('Failed to load timelines', err);
  }
}

function renderTimelinesTable() {
  const tbody = document.getElementById('timeline-table-body');
  if (!tbody) return;

  if (timelinesData.length === 0) {
    tbody.innerHTML = '<tr><td colspan="4" class="py-8 text-center text-slate-400">Belum ada data timeline.</td></tr>';
    return;
  }

  tbody.innerHTML = timelinesData.sort((a,b)=>a.sort_order - b.sort_order).map(t => `
    <tr class="border-b border-slate-200 dark:border-brand-border hover:bg-slate-50 dark:hover:bg-[#1a1c23] transition-colors">
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs">
        <span class="font-bold text-slate-900 dark:text-white">Step ${t.step_number || '-'}</span>
      </td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs">
        <div class="flex items-center gap-3">
          ${t.image ? `<img src="${t.image}" class="w-10 h-10 rounded-lg object-cover shrink-0 border border-slate-200 dark:border-brand-border" onerror="this.style.display='none'">` : '<div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-800 shrink-0"></div>'}
          <div>
            <div class="font-medium text-slate-900 dark:text-white text-sm">${t.title || '-'}</div>
            <div class="text-[11px] text-slate-400 font-mono">${t.slug || ''}</div>
          </div>
        </div>
      </td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 whitespace-nowrap text-[10px] sm:text-xs"><span class="inline-flex px-2 py-0.5 rounded-full text-[9px] sm:text-[10px] font-bold uppercase tracking-wider border ${t.status === 'active' ? 'bg-green-100 dark:bg-green-500/10 text-green-600 dark:text-green-400 border-green-200/50 dark:border-green-500/20' : 'bg-slate-100 dark:bg-slate-500/10 text-slate-500 dark:text-slate-400 border-slate-200/50 dark:border-slate-500/20'}">${t.status || 'active'}</span></td>
      <td class="py-1.5 px-2 sm:py-3 sm:px-5 text-center whitespace-nowrap"><div class="flex justify-center gap-2">${getActionButtonHtml('edit', `openTimelineModal('${t.slug}')`, 'Edit')}${getActionButtonHtml('delete', `deleteTimeline('${t.slug}')`, 'Hapus')}</div></td>
    </tr>
  `).join('');
}

function openTimelineModal(slug = '') {
  const modal = document.getElementById('timeline-modal');
  const content = document.getElementById('timeline-modal-content');
  document.getElementById('timeline-modal-title').textContent = slug ? 'Edit Timeline' : 'Tambah Timeline';

  ['step_number', 'step_label', 'icon', 'title', 'slug', 'short_description', 'description', 'image', 'image_alt', 'layout_position', 'button_text', 'button_link', 'sort_order', 'meta_title', 'meta_description'].forEach(field => {
    const el = document.getElementById(`timeline-${field}`);
    if (el) el.value = field === 'sort_order' ? '1' : field === 'layout_position' ? 'left' : '';
  });
  document.getElementById('timeline-status').value = 'active';
  document.getElementById('timeline-original-key').value = '';

  if (slug) {
    const tItem = timelinesData.find(t => t.slug === slug);
    if (tItem) {
      document.getElementById('timeline-original-key').value = slug;
      Object.keys(tItem).forEach(field => {
        const el = document.getElementById(`timeline-${field}`);
        if (el && tItem[field] !== undefined && tItem[field] !== null) el.value = tItem[field];
      });
      document.getElementById('timeline-status').value = tItem.status || 'active';
    }
  }

  document.getElementById('timeline-title').oninput = function() {
    if (!document.getElementById('timeline-original-key').value) {
      document.getElementById('timeline-slug').value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    }
  };

  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.remove('opacity-0');
    content.classList.remove('translate-x-full');
  }, 10);
}

function closeTimelineModal() {
  const modal = document.getElementById('timeline-modal');
  const content = document.getElementById('timeline-modal-content');
  modal.classList.add('opacity-0');
  content.classList.add('translate-x-full');
  setTimeout(() => modal.classList.add('hidden'), 300);
}

