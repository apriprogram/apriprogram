<script>
// ====== INVOICE LOGIC ======

let currentInvoiceOrder = null;
let invoiceItemsCount = 0;

function openInvoiceModal(orderId) {
  const order = ordersData.find(o => Number(o.id) === Number(orderId));
  if (!order) {
    showToast('Data pesanan tidak ditemukan.', 'red');
    return;
  }
  currentInvoiceOrder = order;

  // Open modal
  const modal = document.getElementById('invoice-modal');
  const panel = document.getElementById('invoice-modal-content');
  if (!modal || !panel) return;
  modal.classList.remove('hidden');
  panel.classList.add('translate-x-full');
  requestAnimationFrame(() => {
    modal.classList.remove('opacity-0');
    panel.classList.remove('translate-x-full');
  });

  // Populate form from order data
  populateInvoiceForm(order);
}

function closeInvoiceModal() {
  const modal = document.getElementById('invoice-modal');
  const panel = document.getElementById('invoice-modal-content');
  if (!modal || !panel) return;
  modal.classList.add('opacity-0');
  panel.classList.add('translate-x-full');
  setTimeout(() => modal.classList.add('hidden'), 500);
}

function populateInvoiceForm(order) {
  document.getElementById('invoice-order-id').value = order.id;

  let invoiceData = null;
  if (order.invoice_data) {
    try {
      invoiceData = typeof order.invoice_data === 'string' ? JSON.parse(order.invoice_data) : order.invoice_data;
    } catch (e) {
      console.error('Failed to parse invoice_data', e);
    }
  }

  // Setup items
  invoiceItemsCount = 0;
  document.getElementById('invoice-items-list').innerHTML = '';
  
  if (invoiceData && invoiceData.items && invoiceData.items.length > 0) {
    invoiceData.items.forEach(item => {
      addInvoiceItem(item.name, item.qty, item.price);
    });
  } else {
    const price = parseFloat((order.package_price || '0').replace(/[^0-9.]/g, '')) || 0;
    const itemName = [order.package_name, order.website_type, order.project_name].filter(Boolean).join(' - ') || 'Jasa Pembuatan Website';
    addInvoiceItem(itemName, 1, price);
  }

  // Basic Info
  const now = new Date();
  const today = now.toISOString().split('T')[0];
  const due = new Date(now.getTime() + 14 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
  
  document.getElementById('inv-number').value = invoiceData?.invoice_number || `INV-${now.getFullYear()}-${String(order.id).padStart(4, '0')}`;
  document.getElementById('inv-issue-date').value = invoiceData?.issue_date || today;
  document.getElementById('inv-due-date').value = invoiceData?.due_date || due;

  const user = usersData.find(u => Number(u.id) === Number(order.user_id));
  document.getElementById('inv-client-name').value = invoiceData?.client_name || order.full_name || (user ? (user.full_name || user.email) : '') || order.email || '';
  document.getElementById('inv-client-email').value = invoiceData?.client_email || order.email || (user ? user.email : '') || '';
  document.getElementById('inv-client-phone').value = invoiceData?.client_phone || order.whatsapp || (user ? user.whatsapp : '') || '';

  document.getElementById('inv-notes').value = invoiceData?.notes || 'Terima kasih atas kepercayaan Anda kepada Apriprogram.\nPembayaran harap dilakukan sebelum tanggal jatuh tempo.\nUntuk pertanyaan, silakan hubungi kami.';

  // Bank Info
  if (invoiceData && invoiceData.bank_name) {
    document.getElementById('inv-bank-name').value = invoiceData.bank_name;
    document.getElementById('inv-bank-account-name').value = invoiceData.bank_account_name;
    document.getElementById('inv-bank-account-number').value = invoiceData.bank_account_number;
    updateInvoicePreview();
  } else {
    (async () => {
      try {
        const settingsRes = await fetch('/api/settings');
        const settingsData = await settingsRes.json();
        const paySettings = (settingsData.success && settingsData.settings && settingsData.settings.payment) ? settingsData.settings.payment : {};
        document.getElementById('inv-bank-name').value = paySettings.bank_name || '';
        document.getElementById('inv-bank-account-name').value = paySettings.account_name || '';
        document.getElementById('inv-bank-account-number').value = paySettings.account_number || '';
        updateInvoicePreview();
      } catch (e) {
        document.getElementById('inv-bank-name').value = '';
        document.getElementById('inv-bank-account-name').value = '';
        document.getElementById('inv-bank-account-number').value = '';
      }
    })();
  }

  // Load discount & tax
  document.getElementById('inv-discount').value = order.discount || invoiceData?.discount || '0';
  document.getElementById('inv-tax').value = order.tax_pct || invoiceData?.tax_pct || '0';

  updateInvoicePreview();
}

function addInvoiceItem(name = '', qty = 1, price = 0) {
  invoiceItemsCount++;
  const idx = invoiceItemsCount;
  const list = document.getElementById('invoice-items-list');

  const item = document.createElement('div');
  item.id = `inv-item-${idx}`;
  item.className = 'bg-white dark:bg-[#1C1E26] border border-slate-200 dark:border-brand-border rounded-xl p-3 relative';
  item.innerHTML = `
    <button type="button" onclick="removeInvoiceItem(${idx})" class="absolute top-2 right-2 w-5 h-5 rounded-full bg-red-100 dark:bg-red-500/20 text-red-500 hover:bg-red-200 dark:hover:bg-red-500/40 flex items-center justify-center transition-colors text-xs">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <div class="space-y-2 pr-6">
      <div>
        <label class="block text-[10px] font-semibold text-slate-500 mb-0.5">Nama Item</label>
        <input type="text" id="inv-item-name-${idx}" value="${name}" placeholder="Nama layanan..." class="w-full px-2.5 py-1.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
      </div>
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="block text-[10px] font-semibold text-slate-500 mb-0.5">Qty</label>
          <input type="number" id="inv-item-qty-${idx}" value="${qty}" min="1" class="w-full px-2.5 py-1.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-slate-500 mb-0.5">Harga (Rp)</label>
          <input type="number" id="inv-item-price-${idx}" value="${price}" min="0" class="w-full px-2.5 py-1.5 bg-slate-50 dark:bg-[#14151a] border border-slate-200 dark:border-brand-border rounded-lg text-xs text-slate-900 dark:text-white focus:border-brand-blue outline-none transition-colors" oninput="updateInvoicePreview()">
        </div>
      </div>
    </div>
  `;
  list.appendChild(item);
  updateInvoicePreview();
}

function removeInvoiceItem(idx) {
  const el = document.getElementById(`inv-item-${idx}`);
  if (el) el.remove();
  updateInvoicePreview();
}

function getInvoiceItems() {
  const items = [];
  const list = document.getElementById('invoice-items-list');
  if (!list) return items;
  const itemDivs = list.querySelectorAll('[id^="inv-item-"]');
  itemDivs.forEach(div => {
    const idx = div.id.replace('inv-item-', '');
    const nameEl = document.getElementById(`inv-item-name-${idx}`);
    const qtyEl = document.getElementById(`inv-item-qty-${idx}`);
    const priceEl = document.getElementById(`inv-item-price-${idx}`);
    if (nameEl && qtyEl && priceEl) {
      const name = nameEl.value.trim();
      const qty = parseFloat(qtyEl.value) || 1;
      const price = parseFloat(priceEl.value) || 0;
      items.push({ name, qty, price, amount: qty * price });
    }
  });
  return items;
}

function formatRupiah(amount) {
  return 'Rp ' + Number(amount || 0).toLocaleString('id-ID');
}

function formatDate(dateStr) {
  if (!dateStr) return '-';
  const d = new Date(dateStr);
  if (isNaN(d)) return dateStr;
  return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
}

function updateInvoicePreview() {
  const number = document.getElementById('inv-number')?.value || '-';
  const issueDate = document.getElementById('inv-issue-date')?.value || '';
  const dueDate = document.getElementById('inv-due-date')?.value || '';
  const clientName = document.getElementById('inv-client-name')?.value || '-';
  const clientEmail = document.getElementById('inv-client-email')?.value || '-';
  const clientPhone = document.getElementById('inv-client-phone')?.value || '';
  const bankName = document.getElementById('inv-bank-name')?.value || '-';
  const bankAccName = document.getElementById('inv-bank-account-name')?.value || '-';
  const bankAccNum = document.getElementById('inv-bank-account-number')?.value || '-';
  const notes = document.getElementById('inv-notes')?.value || '';
  const discount = parseFloat(document.getElementById('inv-discount')?.value) || 0;
  const taxPct = parseFloat(document.getElementById('inv-tax')?.value) || 0;

  const items = getInvoiceItems();
  const subtotal = items.reduce((sum, it) => sum + it.amount, 0);
  const taxAmount = Math.round(subtotal * taxPct / 100);
  const total = subtotal - discount + taxAmount;

  const itemRows = items.map(it => `
    <tr style="border-bottom: 1px solid #f1f5f9;">
      <td style="padding: 10px 12px; font-size: 11.5px; color: #1e293b; font-weight: 500;">${it.name || '-'}</td>
      <td style="padding: 10px 12px; text-align: center; font-size: 11.5px; color: #475569; white-space: nowrap;">${it.qty}</td>
      <td style="padding: 10px 12px; text-align: right; font-size: 11.5px; color: #475569; white-space: nowrap;">${formatRupiah(it.price)}</td>
      <td style="padding: 10px 12px; text-align: right; font-size: 11.5px; color: #1e293b; font-weight: 600; white-space: nowrap;">${formatRupiah(it.amount)}</td>
    </tr>
  `).join('');

  const order = currentInvoiceOrder || {};

  const html = `
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <div style="font-family: 'Poppins', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background: #fff; min-height: 700px; width: 600px; max-width: 100%; box-sizing: border-box;">
      <!-- Header Brand -->
      <div style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); padding: 28px 32px; display: flex; align-items: center; justify-content: space-between;">
        <div style="display: flex; align-items: center; gap: 12px; height: 100%;">
          <div style="width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;">
            <img src="/assets/logo/apriprogram.png" style="max-width: 100%; max-height: 100%; object-fit: contain;" alt="Logo">
          </div>
          <div style="display: flex; flex-direction: column; justify-content: center;">
            <div style="color: #fff; font-size: 16px; font-weight: 600; letter-spacing: -0.3px; line-height: 1.2;">Apriprogram</div>
            <div style="color: #94a3b8; font-size: 10.5px; font-weight: 500; line-height: 1.2; margin-top: 2px;">Web Development Agency</div>
          </div>
        </div>
        <div style="text-align: right; display: flex; flex-direction: column; justify-content: center; height: 100%;">
          <div style="color: #fff; font-size: 22px; font-weight: 600; letter-spacing: -1px; line-height: 1.2;">INVOICE</div>
          <div style="color: #60a5fa; font-size: 12px; font-weight: 600; margin-top: 2px; line-height: 1.2;">${number}</div>
        </div>
      </div>

      <!-- Dates row -->
      <div style="background: #f8fafc; border-bottom: 1px solid #e2e8f0; padding: 14px 32px; display: flex; gap: 32px;">
        <div>
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 3px;">Tanggal Terbit</div>
          <div style="font-size: 12px; font-weight: 600; color: #1e293b;">${formatDate(issueDate)}</div>
        </div>
        <div>
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 3px;">Jatuh Tempo</div>
          <div style="font-size: 12px; font-weight: 600; color: #ef4444;">${formatDate(dueDate)}</div>
        </div>
        <div style="display: flex; flex-direction: column; justify-content: center;">
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 3px;">Status</div>
          <div style="font-size: 12px; font-weight: 700; color: #f59e0b;">
            ${order.status || 'Pending DP'}
          </div>
        </div>
      </div>

      <!-- Billed From / To -->
      <div style="padding: 22px 32px; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; border-bottom: 1px solid #f1f5f9;">
        <div>
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px;">Dari</div>
          <div style="font-size: 13px; font-weight: 600; color: #0f172a; margin-bottom: 4px;">Apriprogram</div>
          <div style="font-size: 11px; color: #64748b; line-height: 1.7;">apriprogram@gmail.com<br>Indonesia</div>
        </div>
        <div>
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px;">Tagih Kepada</div>
          <div style="font-size: 13px; font-weight: 600; color: #0f172a; margin-bottom: 4px;">${clientName}</div>
          <div style="font-size: 11px; color: #64748b; line-height: 1.7;">${clientEmail}${clientPhone ? '<br>' + clientPhone : ''}</div>
        </div>
      </div>

      <!-- Project Info -->
      ${order.project_name ? `
      <div style="padding: 12px 32px; background: #eff6ff; border-bottom: 1px solid #dbeafe; display: flex; align-items: center; gap: 8px;">
        <svg width="14" height="14" fill="none" stroke="#3b82f6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        <span style="font-size: 11px; font-weight: 600; color: #1d4ed8; line-height: 1.2; position: relative; top: -1.5px;">Proyek: ${order.project_name}${order.domain_name ? ' • ' + order.domain_name : ''}</span>
      </div>
      ` : ''}

      <!-- Items Table -->
      <div style="padding: 20px 32px 0;">
        <table style="width: 100%; border-collapse: collapse; margin-bottom: 0;">
          <thead>
            <tr style="background: #1e293b;">
              <th style="padding: 10px 12px; text-align: left; font-size: 10px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; border-top-left-radius: 8px; border-bottom-left-radius: 8px;">Item / Layanan</th>
              <th style="padding: 10px 12px; text-align: center; font-size: 10px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px;">Qty</th>
              <th style="padding: 10px 12px; text-align: right; font-size: 10px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px;">Harga</th>
              <th style="padding: 10px 12px; text-align: right; font-size: 10px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; border-top-right-radius: 8px; border-bottom-right-radius: 8px;">Jumlah</th>
            </tr>
          </thead>
          <tbody>
            ${itemRows || '<tr><td colspan="4" style="padding: 16px 12px; text-align:center; color:#94a3b8; font-size:11px;">Belum ada item</td></tr>'}
          </tbody>
        </table>
      </div>

      <!-- Totals -->
      <div style="padding: 0 32px 20px; display: flex; justify-content: flex-end;">
        <div style="min-width: 220px; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; margin-top: 8px;">
          <div style="display: flex; justify-content: space-between; padding: 10px 16px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
            <span style="font-size: 11px; color: #64748b; font-weight: 500;">Subtotal</span>
            <span style="font-size: 11px; color: #1e293b; font-weight: 600;">${formatRupiah(subtotal)}</span>
          </div>
          ${discount > 0 ? `
          <div style="display: flex; justify-content: space-between; padding: 10px 16px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
            <span style="font-size: 11px; color: #64748b; font-weight: 500;">Diskon</span>
            <span style="font-size: 11px; color: #ef4444; font-weight: 600;">- ${formatRupiah(discount)}</span>
          </div>
          ` : ''}
          ${taxPct > 0 ? `
          <div style="display: flex; justify-content: space-between; padding: 10px 16px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
            <span style="font-size: 11px; color: #64748b; font-weight: 500;">PPN (${taxPct}%)</span>
            <span style="font-size: 11px; color: #1e293b; font-weight: 600;">${formatRupiah(taxAmount)}</span>
          </div>
          ` : ''}
          <div style="display: flex; justify-content: space-between; padding: 12px 16px; background: #1e293b;">
            <span style="font-size: 13px; color: #e2e8f0; font-weight: 600;">Total</span>
            <span style="font-size: 14px; color: #60a5fa; font-weight: 600;">${formatRupiah(total)}</span>
          </div>
        </div>
      </div>

      <!-- Bank Info & Notes -->
      <div style="padding: 20px 32px; background: #f8fafc; border-top: 1px solid #e2e8f0; display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
        <div>
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px;">Info Pembayaran</div>
          <div style="font-size: 11px; font-weight: 600; color: #1e293b; margin-bottom: 3px;">Bank ${bankName}</div>
          <div style="font-size: 10.5px; color: #64748b; margin-bottom: 1px;">a/n: ${bankAccName}</div>
          <div style="font-size: 11.5px; font-weight: 600; color: #3b82f6; letter-spacing: 0.5px;">${bankAccNum}</div>
        </div>
        <div>
          <div style="font-size: 9.5px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px;">Catatan</div>
          <div style="font-size: 10.5px; color: #64748b; line-height: 1.7; white-space: pre-wrap;">${notes}</div>
        </div>
      </div>

      <!-- Footer -->
      <div style="padding: 14px 32px; background: #0f172a; display: flex; align-items: center; justify-content: center; min-height: 40px;">
        <div style="font-size: 10px; color: #475569; line-height: 1;">Dokumen ini digenerate oleh sistem Apriprogram • ${new Date().toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</div>
      </div>
    </div>
  `;

  const preview = document.getElementById('invoice-preview');
  if (preview) preview.innerHTML = html;
}


async function saveInvoiceData() {
  const orderId = document.getElementById('invoice-order-id')?.value;
  if (!orderId) {
    showToast('Order ID tidak ditemukan.', 'red');
    return;
  }

  const invoiceData = {
    invoice_number: document.getElementById('inv-number')?.value || '',
    issue_date: document.getElementById('inv-issue-date')?.value || '',
    due_date: document.getElementById('inv-due-date')?.value || '',
    client_name: document.getElementById('inv-client-name')?.value || '',
    client_email: document.getElementById('inv-client-email')?.value || '',
    client_phone: document.getElementById('inv-client-phone')?.value || '',
    bank_name: document.getElementById('inv-bank-name')?.value || '',
    bank_account_name: document.getElementById('inv-bank-account-name')?.value || '',
    bank_account_number: document.getElementById('inv-bank-account-number')?.value || '',
    notes: document.getElementById('inv-notes')?.value || '',
    discount: parseFloat(document.getElementById('inv-discount')?.value) || 0,
    tax_pct: parseFloat(document.getElementById('inv-tax')?.value) || 0,
    items: getInvoiceItems()
  };

  const btn = document.getElementById('invoice-save-btn');
  if (btn) { btn.disabled = true; btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" class="opacity-25"></circle><path fill="currentColor" d="M4 12a8 8 0 018-8v8z" class="opacity-75"></path></svg> Menyimpan...'; }

  try {
    const res = await fetch(`/api/orders/${orderId}/invoice`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(invoiceData)
    });
    const data = await res.json();
    if (data.success) {
      showToast('Invoice berhasil disimpan!', 'green');
      loadOrders();
    } else {
      showToast(data.message || 'Gagal menyimpan invoice.', 'red');
    }
  } catch (err) {
    showToast('Gagal menghubungi server.', 'red');
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg> Simpan'; }
  }
}
</script>
