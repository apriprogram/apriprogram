<!DOCTYPE html>
<html lang="id" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="8I6QUAg1wwrproClJ91FGsSoDu0CkLSbdtIz1yxXrRY" />
  <title>Login - Apriprogram</title>
  <link rel="icon" href="/assets/logo/favicon.png" type="image/png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          fontFamily: { sans: ['Poppins', 'sans-serif'] },
          colors: {
            brand: { blue: "#243CFF", cyan: "#22D3EE" }
          }
        }
      }
    };
  </script>
</head>
<body class="bg-[#0a0a0a] text-white flex flex-col min-h-screen relative font-sans">
  
  <!-- Back to Home -->
  <a href="/" class="absolute top-6 left-6 text-sm text-slate-400 hover:text-white flex items-center gap-2 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    Back to Home
  </a>

  <div class="flex-1 flex flex-col items-center justify-center p-4 sm:p-6 mt-12 sm:mt-0">
    <!-- Header -->
    <div class="text-center mb-6 sm:mb-8">
      <img src="/assets/logo/apriprogram.png" alt="Logo" class="h-8 sm:h-10 mx-auto mb-4 sm:mb-6" onerror="this.style.display='none'">
      <h1 id="pageTitle" class="text-2xl sm:text-3xl font-semibold text-white mb-2 tracking-tight">Get Started</h1>
      <p id="pageSubtitle" class="text-xs sm:text-sm text-slate-400">Create an account to order and access our solutions</p>
    </div>

    <!-- Main Card -->
    <div class="w-full max-w-md bg-[#121212] border border-white/5 rounded-2xl sm:rounded-[1.5rem] p-5 sm:p-8">
      
      <!-- Tabs -->
      <div class="relative flex p-1 bg-[#1a1a1a] rounded-full mb-6 sm:mb-8">
        <!-- Sliding Indicator -->
        <div id="tabIndicator" class="absolute top-1 bottom-1 left-1 w-[calc(50%-0.25rem)] bg-[#2a2a2a] rounded-full shadow-sm transition-transform duration-300 ease-out"></div>
        <button id="tabLogin" class="relative z-10 flex-1 text-xs sm:text-sm font-medium py-2 sm:py-2.5 rounded-full text-slate-400 hover:text-white transition-colors">Login</button>
        <button id="tabRegister" class="relative z-10 flex-1 text-xs sm:text-sm font-medium py-2 sm:py-2.5 rounded-full text-white transition-colors">Register</button>
      </div>

      <!-- Login Form -->
      <form id="loginForm" class="hidden space-y-4 sm:space-y-5 transition-all duration-300 transform opacity-0 scale-95">
        <div id="errorMsg" class="hidden bg-red-500/10 text-red-500 p-3 rounded-xl text-xs sm:text-sm text-center border border-red-500/20"></div>
        
        <div class="space-y-3 sm:space-y-4">
          <div>
            <label class="block text-[10px] sm:text-xs font-medium mb-1.5 text-slate-400">Email Address</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 sm:pl-4 flex items-center pointer-events-none">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <input type="email" id="email" required placeholder="name@company.com" class="w-full pl-9 sm:pl-11 pr-4 py-2.5 sm:py-3.5 bg-[#1a1a1a] border border-white/5 rounded-xl focus:ring-1 focus:ring-white/20 focus:border-white/20 outline-none transition-all text-xs sm:text-sm text-white placeholder-slate-500">
            </div>
          </div>
          <div>
            <div class="flex justify-between items-center mb-1.5">
              <label class="block text-[10px] sm:text-xs font-medium text-slate-400">Password</label>
              <a href="#" class="text-[10px] sm:text-[11px] text-slate-400 hover:text-white transition-colors">Forgot Password?</a>
            </div>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 sm:pl-4 flex items-center pointer-events-none">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              </div>
              <input type="password" id="password" required placeholder="••••••••" class="w-full pl-9 sm:pl-11 pr-4 py-2.5 sm:py-3.5 bg-[#1a1a1a] border border-white/5 rounded-xl focus:ring-1 focus:ring-white/20 focus:border-white/20 outline-none transition-all text-xs sm:text-sm text-white placeholder-slate-500">
            </div>
          </div>
        </div>
        
        <button type="submit" class="w-full py-2.5 sm:py-3.5 bg-white hover:bg-slate-100 text-black text-xs sm:text-sm font-semibold rounded-xl transition-all flex justify-center items-center gap-2 mt-5 sm:mt-6">
          <span>Sign In</span>
          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </button>

        <div class="relative my-5 sm:my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-white/5"></div>
          </div>
          <div class="relative flex justify-center text-[10px] sm:text-[11px]">
            <span class="px-2 bg-[#121212] text-slate-500">Or continue with</span>
          </div>
        </div>

        <a href="/api/auth/google" class="w-full py-2.5 sm:py-3 bg-[#1a1a1a] hover:bg-[#222] border border-white/5 text-white text-xs sm:text-sm font-medium rounded-xl transition-all flex justify-center items-center gap-2">
          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </a>
      </form>

      <!-- Register Form -->
      <form id="registerForm" class="space-y-4 sm:space-y-5 transition-all duration-300 transform opacity-0 scale-95">
        <div id="regErrorMsg" class="hidden bg-red-500/10 text-red-500 p-3 rounded-xl text-xs sm:text-sm text-center border border-red-500/20"></div>
        <div id="regSuccessMsg" class="hidden bg-green-500/10 text-green-500 p-3 rounded-xl text-xs sm:text-sm text-center border border-green-500/20"></div>
        
        <div class="space-y-3 sm:space-y-4">
          <div>
            <label class="block text-[10px] sm:text-xs font-medium mb-1.5 text-slate-400">Full Name</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 sm:pl-4 flex items-center pointer-events-none">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
              </div>
              <input type="text" id="regFullName" required placeholder="John Doe" class="w-full pl-9 sm:pl-11 pr-4 py-2.5 sm:py-3.5 bg-[#1a1a1a] border border-white/5 rounded-xl focus:ring-1 focus:ring-white/20 focus:border-white/20 outline-none transition-all text-xs sm:text-sm text-white placeholder-slate-500">
            </div>
          </div>
          <div>
            <label class="block text-[10px] sm:text-xs font-medium mb-1.5 text-slate-400">WhatsApp Number</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 sm:pl-4 flex items-center pointer-events-none">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <input type="text" id="regWhatsapp" required placeholder="08123456789" class="w-full pl-9 sm:pl-11 pr-4 py-2.5 sm:py-3.5 bg-[#1a1a1a] border border-white/5 rounded-xl focus:ring-1 focus:ring-white/20 focus:border-white/20 outline-none transition-all text-xs sm:text-sm text-white placeholder-slate-500">
            </div>
          </div>
          <div>
            <label class="block text-[10px] sm:text-xs font-medium mb-1.5 text-slate-400">Email Address</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 sm:pl-4 flex items-center pointer-events-none">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <input type="email" id="regEmail" required placeholder="name@company.com" class="w-full pl-9 sm:pl-11 pr-4 py-2.5 sm:py-3.5 bg-[#1a1a1a] border border-white/5 rounded-xl focus:ring-1 focus:ring-white/20 focus:border-white/20 outline-none transition-all text-xs sm:text-sm text-white placeholder-slate-500">
            </div>
          </div>
          <div>
            <label class="block text-[10px] sm:text-xs font-medium mb-1.5 text-slate-400">Password</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 sm:pl-4 flex items-center pointer-events-none">
                <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              </div>
              <input type="password" id="regPassword" required placeholder="••••••••" class="w-full pl-9 sm:pl-11 pr-4 py-2.5 sm:py-3.5 bg-[#1a1a1a] border border-white/5 rounded-xl focus:ring-1 focus:ring-white/20 focus:border-white/20 outline-none transition-all text-xs sm:text-sm text-white placeholder-slate-500">
            </div>
          </div>
        </div>
        
        <button type="submit" class="w-full py-2.5 sm:py-3.5 bg-white hover:bg-slate-100 text-black text-xs sm:text-sm font-semibold rounded-xl transition-all flex justify-center items-center gap-2 mt-5 sm:mt-6">
          <span>Start Your Journey</span>
          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </button>

        <div class="relative my-5 sm:my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-white/5"></div>
          </div>
          <div class="relative flex justify-center text-[10px] sm:text-[11px]">
            <span class="px-2 bg-[#121212] text-slate-500">Or continue with</span>
          </div>
        </div>

        <a href="/api/auth/google" class="w-full py-2.5 sm:py-3 bg-[#1a1a1a] hover:bg-[#222] border border-white/5 text-white text-xs sm:text-sm font-medium rounded-xl transition-all flex justify-center items-center gap-2">
          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </a>
      </form>
    </div>

    <!-- Footer Switcher -->
    <div id="footerText" class="mt-6 sm:mt-8 text-xs sm:text-sm text-slate-500">
      Already have an account? <a href="#" id="toggleLink" class="text-white font-medium hover:underline">Log in here</a>
    </div>
  </div>

  <script>
    const loginForm = document.getElementById('loginForm');
    const registerForm = document.getElementById('registerForm');
    const tabLogin = document.getElementById('tabLogin');
    const tabRegister = document.getElementById('tabRegister');
    const pageTitle = document.getElementById('pageTitle');
    const pageSubtitle = document.getElementById('pageSubtitle');
    const toggleLink = document.getElementById('toggleLink');
    const footerText = document.getElementById('footerText');

    function showLogin() {
      // Animate out register
      registerForm.classList.remove('opacity-100', 'scale-100');
      registerForm.classList.add('opacity-0', 'scale-95');
      
      setTimeout(() => {
        registerForm.classList.add('hidden');
        loginForm.classList.remove('hidden');
        
        setTimeout(() => {
          loginForm.classList.remove('opacity-0', 'scale-95');
          loginForm.classList.add('opacity-100', 'scale-100');
        }, 20);
      }, 150);
      
      document.getElementById('tabIndicator').style.transform = 'translateX(0)';
      tabLogin.classList.add('text-white');
      tabLogin.classList.remove('text-slate-400');
      tabRegister.classList.remove('text-white');
      tabRegister.classList.add('text-slate-400');
      
      pageTitle.innerText = "Welcome Back";
      pageSubtitle.innerText = "Sign in to manage your products and services";
      footerText.innerHTML = 'Don\'t have an account? <a href="#" onclick="showRegister(event)" class="text-white font-medium hover:underline">Register now</a>';
    }

    function showRegister(e) {
      if(e) e.preventDefault();
      // Animate out login
      loginForm.classList.remove('opacity-100', 'scale-100');
      loginForm.classList.add('opacity-0', 'scale-95');
      
      setTimeout(() => {
        loginForm.classList.add('hidden');
        registerForm.classList.remove('hidden');
        
        setTimeout(() => {
          registerForm.classList.remove('opacity-0', 'scale-95');
          registerForm.classList.add('opacity-100', 'scale-100');
        }, 20);
      }, 150);
      
      document.getElementById('tabIndicator').style.transform = 'translateX(100%)';
      tabRegister.classList.add('text-white');
      tabRegister.classList.remove('text-slate-400');
      tabLogin.classList.remove('text-white');
      tabLogin.classList.add('text-slate-400');
      
      pageTitle.innerText = "Get Started";
      pageSubtitle.innerText = "Create an account to order and access our solutions";
      footerText.innerHTML = 'Already have an account? <a href="#" onclick="showLogin(event)" class="text-white font-medium hover:underline">Log in here</a>';
    }

    tabLogin.addEventListener('click', () => showLogin());
    tabRegister.addEventListener('click', () => showRegister());
    toggleLink.addEventListener('click', (e) => showLogin(e));

    // Handle Login Submit
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;
      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span>Processing...</span>';
      btn.disabled = true;

      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });
        const data = await res.json();
        
        if (data.success) {
          window.location.href = data.redirectUrl;
        } else {
          document.getElementById('errorMsg').textContent = data.message;
          document.getElementById('errorMsg').classList.remove('hidden');
          btn.innerHTML = originalText;
          btn.disabled = false;
        }
      } catch (err) {
        document.getElementById('errorMsg').textContent = 'Network error occurred.';
        document.getElementById('errorMsg').classList.remove('hidden');
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });

    // Handle Register Submit
    registerForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('regEmail').value;
      const password = document.getElementById('regPassword').value;
      const full_name = document.getElementById('regFullName').value;
      const whatsapp = document.getElementById('regWhatsapp').value;

      const btn = e.target.querySelector('button[type="submit"]');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span>Processing...</span>';
      btn.disabled = true;

      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, full_name, whatsapp })
        });
        const data = await res.json();
        
        if (data.success) {
          document.getElementById('regSuccessMsg').textContent = "Registration successful! Redirecting...";
          document.getElementById('regSuccessMsg').classList.remove('hidden');
          document.getElementById('regErrorMsg').classList.add('hidden');
          setTimeout(() => {
            if (data.redirectUrl) window.location.href = data.redirectUrl;
            else window.location.href = '/';
          }, 1500);
        } else {
          document.getElementById('regErrorMsg').textContent = data.message;
          document.getElementById('regErrorMsg').classList.remove('hidden');
          document.getElementById('regSuccessMsg').classList.add('hidden');
        }
      } catch (err) {
        document.getElementById('regErrorMsg').textContent = 'Network error occurred.';
        document.getElementById('regErrorMsg').classList.remove('hidden');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });

    // Default view
    const urlParams = new URLSearchParams(window.location.search);
    if(urlParams.get('type') === 'register') {
      showRegister();
    } else {
      showLogin(); 
    }
  </script>
</body>
</html>
