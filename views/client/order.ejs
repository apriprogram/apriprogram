<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pesan Website - Apriprogram</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script>
    // Theme setup to prevent FOUC
    if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          fontFamily: { sans: ['Poppins', 'sans-serif'] },
          colors: { brand: { blue: "#243CFF", cyan: "#22D3EE", card: "#0a111f", border: "rgba(255,255,255,0.05)" } }
        }
      }
    };
  </script>
</head>
<body class="bg-slate-50 dark:bg-[#050b14] text-slate-900 dark:text-white min-h-screen flex flex-col">

  <!-- Header -->
  <header class="w-full bg-white dark:bg-brand-card border-b border-slate-200 dark:border-brand-border py-4 px-6 flex items-center justify-between sticky top-0 z-50">
    <div class="flex items-center gap-3">
      <img src="/assets/logo/apriprogram.png" alt="Logo" class="h-8" onerror="this.style.display='none'">
      <span class="font-semibold text-lg">Pemesanan Website</span>
    </div>
    <div class="flex items-center gap-4">
      <div class="text-sm text-slate-500 dark:text-slate-400 hidden sm:block">Halo, <%= user.email %></div>
      <button id="themeToggle" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/5 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-blue" aria-label="Toggle Dark Mode">
        <svg id="themeIconDark" class="w-5 h-5 text-slate-600 dark:text-slate-300 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
        <svg id="themeIconLight" class="w-5 h-5 text-slate-600 dark:text-slate-300 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
      </button>
      <a href="/logout" class="text-sm font-medium text-red-500 hover:text-red-600 transition-colors">Logout</a>
    </div>
  </header>

  <main class="flex-grow max-w-6xl w-full mx-auto p-6 lg:py-10">
    
    <!-- Steps Indicator -->
    <div class="mb-14 relative w-full px-2 sm:px-6">
      <!-- Background Line -->
      <div class="absolute left-6 right-6 top-5 -translate-y-1/2 h-1 bg-slate-200 dark:bg-brand-border z-0 rounded-full"></div>
      <!-- Progress Line -->
      <div id="progress-bar" class="absolute left-6 top-5 -translate-y-1/2 h-1 bg-brand-blue z-0 rounded-full transition-all duration-500 ease-in-out" style="width: 0%; max-width: calc(100% - 3rem);"></div>
      
      <div class="relative z-10 flex justify-between items-center w-full">
        <div class="relative flex flex-col items-center step-indicator" data-step="1">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-brand-blue text-white ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10">1</div>
          <span class="absolute top-14 text-xs font-medium text-brand-blue whitespace-nowrap text-center">Jenis Web</span>
        </div>
        <div class="relative flex flex-col items-center step-indicator" data-step="2">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-slate-200 dark:bg-slate-800 text-slate-400 ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10">2</div>
          <span class="absolute top-14 text-xs font-medium text-slate-500 dark:text-slate-500 whitespace-nowrap text-center">Paket</span>
        </div>
        <div class="relative flex flex-col items-center step-indicator" data-step="3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-slate-200 dark:bg-slate-800 text-slate-400 ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10">3</div>
          <span class="absolute top-14 text-xs font-medium text-slate-500 dark:text-slate-500 whitespace-nowrap text-center">Briefing</span>
        </div>
        <div class="relative flex flex-col items-center step-indicator" data-step="4">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-slate-200 dark:bg-slate-800 text-slate-400 ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10">4</div>
          <span class="absolute top-14 text-xs font-medium text-slate-500 dark:text-slate-500 whitespace-nowrap text-center">Desain</span>
        </div>
        <div class="relative flex flex-col items-center step-indicator" data-step="5">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-slate-200 dark:bg-slate-800 text-slate-400 ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10">5</div>
          <span class="absolute top-14 text-xs font-medium text-slate-500 dark:text-slate-500 whitespace-nowrap text-center">Ringkasan</span>
        </div>
      </div>
    </div>

    <!-- Forms Container -->
    <div class="bg-white dark:bg-brand-card rounded-2xl border border-slate-200 dark:border-brand-border p-6 sm:p-10">
      <form id="orderForm">
        
        <!-- STEP 1: Jenis Website -->
        <div class="step-content block" id="step1">
          <h2 class="text-2xl font-semibold mb-2">Pilih Jenis Website</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">Pilih kategori yang paling sesuai dengan kebutuhan proyek Anda.</p>
          
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4" id="websiteTypeGrid">
            <!-- JS will populate options here -->
          </div>
          <input type="hidden" id="website_type" required>
          <p id="err-step1" class="text-red-500 text-sm mt-3 hidden">Pilih salah satu jenis website terlebih dahulu.</p>
        </div>

        <!-- STEP 2: Pilih Paket -->
        <div class="step-content hidden" id="step2">
          <h2 class="text-2xl font-semibold mb-2">Pilih Paket Website</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">Pilih paket yang sesuai dengan fitur dan budget yang Anda inginkan.</p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="packagesGrid">
            <!-- JS will populate pricing cards here based on selected website type -->
          </div>
          <input type="hidden" id="package_name" required>
          <p id="err-step2" class="text-red-500 text-sm mt-3 hidden">Pilih salah satu paket terlebih dahulu.</p>
        </div>

        <!-- STEP 3: Isi Brief & Upload -->
        <div class="step-content hidden" id="step3">
          <h2 class="text-2xl font-semibold mb-2">Brief Proyek</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">Ceritakan lebih detail tentang website yang ingin Anda buat.</p>
          
          <div class="space-y-5">
            <div>
              <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Nama Proyek / Website *</label>
              <input type="text" id="project_name" required class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500">
            </div>
            <div>
              <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Deskripsi Singkat *</label>
              <textarea id="description" rows="3" required class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500" placeholder="Tujuan website ini untuk apa?"></textarea>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Fitur yang Dibutuhkan</label>
              <textarea id="features" rows="2" class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500" placeholder="Contoh: Live Chat, Kalkulator Harga, dll."></textarea>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Target Penyelesaian (Opsional)</label>
                <input type="date" id="target_date" class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white">
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Upload Document Project</label>
              <div class="w-full border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl bg-slate-50 dark:bg-[#0a111f] p-8 text-center hover:bg-slate-100 dark:hover:bg-white/5 transition-colors cursor-pointer relative mt-2 group" id="dropzone">
                 <input type="file" id="fileUpload" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip,.rar" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                 <div class="mb-3">
                   <div class="w-12 h-12 bg-slate-200 dark:bg-slate-800 text-slate-500 rounded-full flex items-center justify-center mx-auto shadow-sm group-hover:scale-110 transition-transform">
                     <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path></svg>
                   </div>
                 </div>
                 <h4 class="text-sm font-semibold text-slate-700 dark:text-slate-200 mb-1">Choose a file or drag & drop it here.</h4>
                 <p class="text-xs text-slate-500 dark:text-slate-400 mb-4">txt, docx, pdf, jpeg, xlsx, zip - Up to 50MB</p>
                 <button type="button" class="px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-semibold text-slate-700 dark:text-slate-200 pointer-events-none shadow-sm">Browse files</button>
              </div>
              <input type="hidden" id="uploadedFileUrl">
              <div id="uploadStatus" class="mt-3 space-y-2"></div>
            </div>
          </div>
        </div>

        <!-- STEP 4: Desain & Referensi -->
        <div class="step-content hidden" id="step4">
          <h2 class="text-2xl font-semibold mb-2">Tema & Referensi Desain</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">Bantu kami memahami selera visual Anda.</p>
          
          <div class="space-y-5">
            <div>
              <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Link Website Referensi (Bila Ada)</label>
              <textarea id="reference_links" rows="2" class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500" placeholder="Sebutkan link website yang Anda jadikan contoh/inspirasi..."></textarea>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Warna Utama</label>
                <input type="color" id="primary_color" value="#243CFF" class="w-full h-12 rounded-xl cursor-pointer bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 p-1">
              </div>
              <div>
                <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Gaya Desain</label>
                <select id="design_style" class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white">
                  <option value="Modern Minimalis">Modern Minimalis</option>
                  <option value="Elegan & Mewah">Elegan & Mewah</option>
                  <option value="Ceria & Colorful">Ceria & Colorful</option>
                  <option value="Korporat Profesional">Korporat Profesional</option>
                  <option value="Bebas / Terserah Tim">Bebas / Terserah Tim</option>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-2 text-slate-800 dark:text-slate-200">Catatan Tambahan Terkait Desain</label>
              <textarea id="notes" rows="2" class="w-full px-4 py-3 bg-white dark:bg-[#0a111f] border border-slate-300 dark:border-slate-700 rounded-xl focus:ring-2 focus:ring-brand-blue focus:border-brand-blue outline-none text-sm transition-all text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-500" placeholder="Contoh: Tolong buatkan animasi saat scroll..."></textarea>
            </div>
          </div>
        </div>

        <!-- STEP 5: Ringkasan & Pembayaran -->
        <div class="step-content hidden" id="step5">
          <h2 class="text-2xl font-semibold mb-2">Ringkasan Pesanan</h2>
          <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">Review pesanan Anda sebelum melanjutkan ke pembayaran DP.</p>
          
          <div class="bg-slate-50 dark:bg-[#050b14] p-5 rounded-xl border border-slate-200 dark:border-white/10 mb-6 space-y-3 text-sm">
            <div class="flex justify-between border-b border-slate-200 dark:border-white/5 pb-2">
              <span class="text-slate-500 dark:text-slate-400">Jenis Website:</span>
              <strong id="summary-type"></strong>
            </div>
            <div class="flex justify-between border-b border-slate-200 dark:border-white/5 pb-2">
              <span class="text-slate-500 dark:text-slate-400">Nama Proyek:</span>
              <strong id="summary-name"></strong>
            </div>
            <div class="flex justify-between pb-2">
              <span class="text-slate-500 dark:text-slate-400">Paket:</span>
              <strong id="summary-package" class="text-brand-blue"></strong>
            </div>
          </div>

          <div class="bg-blue-50 dark:bg-brand-blue/10 border border-blue-200 dark:border-brand-blue/30 p-5 rounded-xl mb-6">
            <h3 class="font-semibold text-blue-800 dark:text-blue-300 mb-2">Instruksi Pembayaran DP (Down Payment)</h3>
            <p class="text-sm text-blue-700 dark:text-blue-400 mb-4">Untuk memulai pengerjaan, silakan lakukan pembayaran DP sebagai tanda jadi keseriusan.</p>
            <div class="font-mono text-lg font-semibold text-slate-900 dark:text-white">BCA - 1234567890</div>
            <div class="text-sm text-slate-600 dark:text-slate-300 mb-4">a.n PT Apriprogram Teknologi</div>
            
            <hr class="border-blue-200 dark:border-brand-blue/20 my-4">
            
            <label class="block text-sm font-semibold mb-2 text-blue-800 dark:text-blue-300">Upload Bukti Pembayaran *</label>
            <input type="file" id="paymentProofUpload" accept="image/*,.pdf" class="block w-full text-sm text-slate-500 dark:text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-100 file:text-blue-700 dark:file:bg-brand-blue/20 dark:file:text-brand-blue hover:file:bg-blue-200 transition-colors border border-blue-200 dark:border-brand-blue/30 rounded-lg bg-white dark:bg-[#0a111f] focus:ring-2 focus:ring-brand-blue">
            <input type="hidden" id="paymentProofUrl">
            <p id="paymentUploadStatus" class="text-xs text-green-600 mt-2 hidden font-semibold">Bukti pembayaran berhasil diunggah!</p>
          </div>

          <p class="text-xs text-slate-500 dark:text-slate-400">Dengan menekan tombol "Kirim Pesanan", Anda menyetujui syarat & ketentuan layanan kami. Tim Apriprogram akan segera memproses pesanan Anda dan mengabari via WhatsApp/Email.</p>
        </div>

        <!-- Navigation Buttons -->
        <div class="mt-8 flex justify-between items-center pt-5 border-t border-slate-200 dark:border-brand-border">
          <button type="button" id="btnPrev" class="hidden px-6 py-2.5 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 font-medium rounded-xl transition-colors">Kembali</button>
          <button type="button" id="btnNext" class="px-6 py-2.5 bg-brand-blue hover:bg-blue-600 text-white font-medium rounded-xl transition-colors ml-auto">Lanjutkan</button>
          <button type="submit" id="btnSubmit" class="hidden px-6 py-2.5 bg-brand-cyan hover:bg-cyan-500 text-slate-900 font-semibold rounded-xl transition-colors ml-auto flex items-center gap-2">Kirim Pesanan & Selesai</button>
        </div>

      </form>
    </div>
  </main>

  <!-- Success Modal -->
  <div id="successModal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity">
    <div class="bg-white dark:bg-brand-card w-full max-w-sm rounded-2xl p-8 text-center border border-slate-200 dark:border-brand-border">
      <div class="w-20 h-20 bg-green-100 dark:bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-5">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
      </div>
      <h3 class="text-2xl font-semibold mb-2">Pesanan Diterima!</h3>
      <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">Terima kasih! Tim kami akan segera meninjau brief Anda dan menghubungi Anda secepatnya.</p>
      <a href="/" class="block w-full py-3 bg-brand-blue text-white rounded-xl font-medium">Kembali ke Beranda</a>
    </div>
  </div>

  <!-- File Viewer Modal -->
  <div id="fileViewerModal" class="fixed inset-0 bg-slate-900/90 backdrop-blur-sm z-[60] flex items-center justify-center hidden opacity-0 transition-opacity p-4 duration-300">
    <div class="bg-white dark:bg-[#0a111f] w-full max-w-4xl rounded-2xl overflow-hidden flex flex-col max-h-[90vh] border border-slate-200 dark:border-slate-700 shadow-2xl scale-95 transform transition-transform duration-300" id="fileViewerContainer">
      <div class="p-4 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-800/50">
        <h3 id="fileViewerTitle" class="font-semibold text-slate-800 dark:text-white truncate">View File</h3>
        <button type="button" onclick="closeFileViewer()" class="text-slate-500 hover:text-red-500 transition-colors p-1 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="p-4 overflow-auto flex-1 flex items-center justify-center min-h-[300px] relative">
        <div id="fileViewerContent" class="w-full h-full flex items-center justify-center"></div>
      </div>
    </div>
  </div>

  <!-- Top Center Toast Notification -->
  <div id="toastNotification" class="fixed top-5 left-1/2 -translate-x-1/2 bg-red-500 text-white px-6 py-3 rounded-full shadow-2xl z-[100] flex items-center gap-3 transform -translate-y-20 opacity-0 transition-all duration-300 pointer-events-none">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <span class="font-semibold text-sm">Silakan unggah bukti pembayaran Anda terlebih dahulu.</span>
  </div>

  <script>
    // Constants
    // Constants & Pricing Data
    const websiteTypes = [
      "Website Sekolah", "Website Kampus/Universitas", "Website Kursus & Bimbingan Belajar", "Website LPK",
      "Website Desa", "Website Profil Perusahaan", "Website Kantor Hukum", "Website Bank", "Undangan Digital"
    ];

    const pricingData = {
      "Website Sekolah": [
        { name: "Paket Standard", price: "Rp. 4.000.000", target: "Cocok untuk SD, SMP, SMA, dan SMK yang membutuhkan website profil institusi.", isPopular: false, duration: "Estimasi pengerjaan: 15 - 30 hari kerja",
          features: ["Panel Admin (CMS)", "Login Admin", "Profil Sekolah & Sejarah", "Visi & Misi", "Informasi Guru & Staff", "Informasi Program & Ekstrakurikuler", "Berita, Artikel & Pengumuman", "Galeri Foto/Video", "Formulir Kontak", "Page Builder", "Integrasi WhatsApp", "Integrasi Google Maps", "Responsive (Mobile & Desktop)", "Desain Website Profesional & Modern", "SEO Dasar"] },
        { name: "Paket Profesional", price: "Rp. 8.000.000", target: "Cocok untuk sekolah yang membutuhkan sistem informasi dan layanan akademik yang lebih lengkap.", isPopular: true, duration: "Estimasi pengerjaan: 30 - 60 hari kerja",
          features: ["Semua fitur Standard, ditambah:", "Sistem PPDB (Penerimaan Peserta Didik Baru)", "Portal Siswa", "Portal Guru", "Download Dokumen & Formulir", "Dashboard Statistik Pengunjung", "Dashboard Laporan & Statistik", "Integrasi Pembayaran SPP", "Multi User Admin", "Role & Permission Management", "Backup Database Berkala"] },
        { name: "Paket Premium", price: "Rp. 15.000.000+", target: "Cocok untuk sekolah yang membutuhkan sistem akademik terintegrasi.", isPopular: false, duration: "Estimasi pengerjaan: 60 - 90 hari kerja",
          features: ["Semua fitur Profesional, ditambah:", "E-Learning", "Absensi Online", "E-Rapor", "Jadwal Pelajaran Online", "Portal Orang Tua/Wali Murid", "Integrasi Pembayaran SPP", "Notifikasi Email & WhatsApp", "Dashboard Akademik", "Sistem Akademik Sesuai Kebutuhan", "SSL Premium & Security Hardening", "Fitur Kustom Sesuai Kebutuhan Sekolah"] }
      ],
