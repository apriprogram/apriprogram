    ];

    function renderPricing(type) {
      const grid = document.getElementById('packagesGrid');
      grid.innerHTML = '';
      const packages = pricingData[type] || defaultPricing;
      
      // Dinamis grid: jika hanya 2 paket, pakai 2 kolom di tengah agar tidak ada ruang kosong
      if (packages.length === 2) {
        grid.className = "grid grid-cols-1 md:grid-cols-2 max-w-4xl mx-auto gap-6 w-full";
      } else {
        grid.className = "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6";
      }
      
      packages.forEach(pkg => {
        const isPopular = pkg.isPopular;
        const cardClass = isPopular 
          ? 'package-card border-2 border-brand-blue bg-blue-50 dark:bg-[#0a0f1a] rounded-2xl p-6 sm:p-8 cursor-pointer relative transition-all transform hover:-translate-y-1'
          : 'package-card border border-slate-200 dark:border-white/10 bg-white dark:bg-[#111111] rounded-2xl p-6 sm:p-8 cursor-pointer transition-all transform hover:-translate-y-1';
        
        const badgeHTML = isPopular ? `<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand-blue text-white text-[10px] sm:text-xs font-semibold px-4 py-1.5 rounded-full uppercase tracking-wider whitespace-nowrap">POPULAR / BEST VALUE</div>` : '';
        const btnClass = isPopular ? 'bg-brand-blue text-white w-full py-3 rounded-lg font-semibold mt-6 mb-8 hover:bg-blue-600 transition-colors' : 'bg-transparent border border-slate-300 dark:border-white/20 text-slate-800 dark:text-white w-full py-3 rounded-lg font-semibold mt-6 mb-8 hover:bg-slate-100 dark:hover:bg-white/5 transition-colors';
        
        const featuresHTML = pkg.features.map(f => `
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">${f}</span>
          </li>
        `).join('');

        const html = `
          <div class="${cardClass}" data-pkg="${pkg.name}">
            ${badgeHTML}
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">${pkg.name}</h3>
            <p class="text-xs text-slate-500 dark:text-[#a0a0a0] h-10 mb-6">${pkg.target}</p>
            <div class="text-3xl font-extrabold text-slate-900 dark:text-white mb-2">${pkg.price}</div>
            
            <button type="button" class="select-pkg-btn ${btnClass}">Pilih Paket</button>
            
            <ul class="space-y-4 mb-8">
              ${featuresHTML}
            </ul>
            <div class="flex items-start gap-3 mt-auto pt-6 border-t border-slate-100 dark:border-white/10">
               <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
               <span class="text-sm text-slate-600 dark:text-slate-300">${pkg.duration}</span>
            </div>
          </div>
        `;
        grid.insertAdjacentHTML('beforeend', html);
      });

      // Bind events to new cards
      document.querySelectorAll('.package-card').forEach(card => {
        card.addEventListener('click', (e) => {
          document.querySelectorAll('.package-card').forEach(el => el.classList.remove('ring-2', 'ring-brand-blue'));
          card.classList.add('ring-2', 'ring-brand-blue');
          document.getElementById('package_name').value = card.getAttribute('data-pkg');
          document.getElementById('err-step2').classList.add('hidden');
          
          // Auto advance ONLY if the user clicked the 'Pilih Paket' button
          if (e.target.closest('.select-pkg-btn')) {
            document.getElementById('btnNext').click();
          }
        });
      });
    }

    // Initialize Website Types
    const gridType = document.getElementById('websiteTypeGrid');
    websiteTypes.forEach(type => {
      const div = document.createElement('div');
      div.className = "type-card border border-slate-200 dark:border-slate-800 rounded-xl p-4 text-center cursor-pointer hover:border-brand-blue hover:bg-blue-50 dark:hover:bg-brand-blue/10 dark:bg-white/5 transition-colors text-slate-900 dark:text-white";
      div.innerText = type;
      div.onclick = () => {
        document.querySelectorAll('.type-card').forEach(el => el.classList.remove('border-brand-blue', 'bg-blue-50', 'dark:bg-brand-blue/10'));
        div.classList.add('border-brand-blue', 'bg-blue-50', 'dark:bg-brand-blue/10');
        document.getElementById('website_type').value = type;
        document.getElementById('err-step1').classList.add('hidden');
        renderPricing(type); // Render dynamic pricing cards!
      };
      gridType.appendChild(div);
    });

    // File Upload Handler with Drag & Drop styling
    const dropzone = document.getElementById('dropzone');
    const fileUpload = document.getElementById('fileUpload');
    
    fileUpload.addEventListener('dragenter', () => dropzone.classList.add('border-brand-blue', 'bg-blue-50', 'dark:bg-brand-blue/10'));
    fileUpload.addEventListener('dragleave', () => dropzone.classList.remove('border-brand-blue', 'bg-blue-50', 'dark:bg-brand-blue/10'));
    fileUpload.addEventListener('drop', () => dropzone.classList.remove('border-brand-blue', 'bg-blue-50', 'dark:bg-brand-blue/10'));

    fileUpload.addEventListener('change', async (e) => {
      const files = e.target.files;
      if (!files || files.length === 0) return;
      
      const formData = new FormData();
      for (let i = 0; i < files.length; i++) {
        formData.append("files", files[i]);
      }
      
      const btnNext = document.getElementById('btnNext');
      btnNext.innerText = "Mengunggah...";
      btnNext.disabled = true;

      try {
        const res = await fetch('/api/upload/document', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) {
          // Append URLs to hidden input (comma separated if multiple uploads occur)
          const currentUrls = document.getElementById('uploadedFileUrl').value;
          document.getElementById('uploadedFileUrl').value = currentUrls ? currentUrls + ',' + data.url : data.url;
          
          const uploadedUrls = data.url.split(',');

          // Render uploaded files UI
          const statusContainer = document.getElementById('uploadStatus');
          for (let i = 0; i < files.length; i++) {
            const fileRow = document.createElement('div');
            fileRow.className = "flex items-center justify-between bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 p-3 rounded-lg shadow-sm";
            fileRow.innerHTML = `
              <div class="flex items-center gap-3 overflow-hidden">
                <svg class="w-5 h-5 text-brand-blue shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <div class="truncate text-sm font-semibold text-slate-700 dark:text-slate-300">${files[i].name}</div>
              </div>
              <div class="flex items-center gap-2">
                <button type="button" class="text-blue-500 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 transition-colors p-1" onclick="viewUploadedFile('${uploadedUrls[i]}', '${files[i].name}')" title="Lihat File">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                </button>
                <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </div>
            `;
            statusContainer.appendChild(fileRow);
          }
        } else {
          alert("Gagal mengunggah file.");
        }
      } catch (err) {
        alert("Terjadi kesalahan koneksi saat unggah.");
      } finally {
        btnNext.innerText = "Lanjutkan";
        btnNext.disabled = false;
        fileUpload.value = ''; // Reset input to allow uploading same files again
      }
    });

    // Navigation Logic
    let currentStep = 1;
    const totalSteps = 5;

    const btnPrev = document.getElementById('btnPrev');
    const btnNext = document.getElementById('btnNext');
    const btnSubmit = document.getElementById('btnSubmit');

    // Payment Proof Upload Handler
    document.getElementById('paymentProofUpload').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      
      const formData = new FormData();
      formData.append("files", file);
      
      btnSubmit.innerHTML = "Mengunggah...";
      btnSubmit.disabled = true;

      try {
        const res = await fetch('/api/upload/payment', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) {
          document.getElementById('paymentProofUrl').value = data.url;
          document.getElementById('paymentUploadStatus').classList.remove('hidden');
        } else {
          alert("Gagal mengunggah bukti pembayaran.");
        }
      } catch (err) {
        alert("Terjadi kesalahan koneksi saat unggah bukti pembayaran.");
      } finally {
        btnSubmit.innerHTML = "Kirim Pesanan & Selesai";
        btnSubmit.disabled = false;
      }
    });

    function updateUI() {
      // Show/Hide steps
      for (let i = 1; i <= totalSteps; i++) {
        document.getElementById(`step${i}`).classList.toggle('hidden', i !== currentStep);
      }
      
      // Update Progress & Indicators
      const progress = ((currentStep - 1) / (totalSteps - 1)) * 100;
      document.getElementById('progress-bar').style.width = `${progress}%`;
      
      document.querySelectorAll('.step-indicator').forEach(ind => {
        const stepNum = parseInt(ind.getAttribute('data-step'));
        const circle = ind.querySelector('div');
        const text = ind.querySelector('span');
        
        if (stepNum <= currentStep) {
          circle.className = "w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-brand-blue text-white ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10";
          text.className = "absolute top-14 text-xs font-medium text-brand-blue whitespace-nowrap text-center";
        } else {
          circle.className = "w-10 h-10 rounded-full flex items-center justify-center font-semibold text-sm bg-slate-200 dark:bg-slate-800 text-slate-400 ring-4 ring-slate-50 dark:ring-[#050b14] shadow-sm transition-colors duration-500 relative z-10";
          text.className = "absolute top-14 text-xs font-medium text-slate-500 dark:text-slate-500 whitespace-nowrap text-center";
        }
      });

      // Show/Hide Buttons
      btnPrev.classList.toggle('hidden', currentStep === 1);
      if (currentStep === totalSteps) {
        btnNext.classList.add('hidden');
        btnSubmit.classList.remove('hidden');
        
        // Populate Summary
        document.getElementById('summary-type').innerText = document.getElementById('website_type').value;
        document.getElementById('summary-package').innerText = document.getElementById('package_name').value;
        document.getElementById('summary-name').innerText = document.getElementById('project_name').value;
      } else {
        btnNext.classList.remove('hidden');
        btnSubmit.classList.add('hidden');
      }
    }

    function validateStep() {
      if (currentStep === 1 && !document.getElementById('website_type').value) {
        document.getElementById('err-step1').classList.remove('hidden'); return false;
      }
      if (currentStep === 2 && !document.getElementById('package_name').value) {
        document.getElementById('err-step2').classList.remove('hidden'); return false;
      }
      if (currentStep === 3) {
        if (!document.getElementById('project_name').value || !document.getElementById('description').value) {
          document.getElementById('project_name').reportValidity();
          document.getElementById('description').reportValidity();
          return false;
        }
      }
      return true;
    }

    btnNext.addEventListener('click', () => {
      if (validateStep() && currentStep < totalSteps) {
        currentStep++;
        updateUI();
        window.scrollTo(0,0);
      }
    });

    btnPrev.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        updateUI();
        window.scrollTo(0,0);
      }
    });

    document.getElementById('orderForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const paymentProofUrl = document.getElementById('paymentProofUrl').value;
      if (!paymentProofUrl) {
        showToastNotification();
        return;
      }
      
      btnSubmit.innerHTML = "Memproses...";
      btnSubmit.disabled = true;

      const payload = {
        website_type: document.getElementById('website_type').value,
        package_name: document.getElementById('package_name').value,
        project_name: document.getElementById('project_name').value,
        description: document.getElementById('description').value,
        features: document.getElementById('features').value,
        target_date: document.getElementById('target_date').value,
        notes: document.getElementById('notes').value,
        files: document.getElementById('uploadedFileUrl').value ? document.getElementById('uploadedFileUrl').value.split(',') : [],
        project_document: document.getElementById('uploadedFileUrl').value || '',
        reference_links: document.getElementById('reference_links').value,
        primary_color: document.getElementById('primary_color').value,
        design_style: document.getElementById('design_style').value,
        payment_proof: paymentProofUrl
      };

      try {
        const res = await fetch('/api/orders', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
          const modal = document.getElementById('successModal');
          modal.classList.remove('hidden');
          setTimeout(() => modal.classList.remove('opacity-0'), 10);
        } else {
          alert(data.message || "Gagal menyimpan pesanan.");
        }
      } catch(err) {
        alert("Kesalahan jaringan.");
      } finally {
        btnSubmit.innerHTML = "Kirim Pesanan & Selesai";
        btnSubmit.disabled = false;
      }
    });

  </script>
  <script>
    // Theme Toggle Logic
    const themeToggleBtn = document.getElementById('themeToggle');
    const themeIconDark = document.getElementById('themeIconDark');
    const themeIconLight = document.getElementById('themeIconLight');

    function updateThemeIcon() {
      if (document.documentElement.classList.contains('dark')) {
        themeIconLight.classList.remove('hidden');
        themeIconDark.classList.add('hidden');
      } else {
        themeIconDark.classList.remove('hidden');
        themeIconLight.classList.add('hidden');
      }
    }
    
    // Initial icon state
    updateThemeIcon();

    themeToggleBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      if (document.documentElement.classList.contains('dark')) {
        localStorage.theme = 'dark';
      } else {
        localStorage.theme = 'light';
      }
      updateThemeIcon();
    });

    // Modal Viewer Functions
    function showToastNotification() {
      const toast = document.getElementById('toastNotification');
      toast.classList.remove('-translate-y-20', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      
      setTimeout(() => {
        toast.classList.remove('translate-y-0', 'opacity-100');
        toast.classList.add('-translate-y-20', 'opacity-0');
      }, 3000);
    }

    function viewUploadedFile(url, name) {
      const modal = document.getElementById('fileViewerModal');
      const container = document.getElementById('fileViewerContainer');
      const title = document.getElementById('fileViewerTitle');
      const content = document.getElementById('fileViewerContent');
      
      title.innerText = name;
      content.innerHTML = ''; // clear previous
      
      const ext = url.split('.').pop().toLowerCase();
      if (['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'].includes(ext)) {
        content.innerHTML = `<img src="${url}" class="max-w-full max-h-[70vh] object-contain rounded-lg shadow-md" alt="${name}">`;
      } else if (ext === 'pdf') {
        content.innerHTML = `<iframe src="${url}" class="w-full h-[70vh] rounded-lg shadow-md border-0"></iframe>`;
      } else {
        content.innerHTML = `
          <div class="text-center">
            <svg class="w-16 h-16 text-slate-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            <p class="text-slate-600 dark:text-slate-300 mb-4">Pratinjau tidak tersedia untuk format file ini.</p>
            <a href="${url}" target="_blank" class="px-6 py-2 bg-brand-blue text-white rounded-lg font-semibold hover:bg-blue-600 transition-colors inline-block">Unduh File</a>
          </div>`;
      }
      
      modal.classList.remove('hidden');
      // small delay to allow display:block to apply before animating opacity/transform
      setTimeout(() => {
        modal.classList.remove('opacity-0');
        container.classList.remove('scale-95');
        container.classList.add('scale-100');
      }, 10);
    }
    
    function closeFileViewer() {
      const modal = document.getElementById('fileViewerModal');
      const container = document.getElementById('fileViewerContainer');
      
      modal.classList.add('opacity-0');
      container.classList.remove('scale-100');
      container.classList.add('scale-95');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        document.getElementById('fileViewerContent').innerHTML = '';
      }, 300);
    }
  </script>
</body>
</html>
