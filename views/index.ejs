    </section>
  </main>

  <footer class="border-t border-white/5 bg-[#0a0a0a] py-16">
    <div class="mx-auto flex flex-col items-center text-center gap-6 max-w-lg px-4 sm:px-6 lg:px-8">
      <a href="#home" class="flex items-center justify-center gap-2 sm:gap-3">
        <img src="/assets/logo/apriprogram.png" alt="Apriprogram Logo" class="h-6 sm:h-8 w-auto" />
        <span class="text-lg sm:text-xl font-medium tracking-tight text-white">Apriprogram</span>
      </a>
      <p class="text-sm leading-relaxed text-[#a0a0a0]" id="dyn-footer-description">
        Membantu perusahaan, agensi, dan startup menciptakan ekosistem digital terbaik yang modern dan fungsional.
      </p>
    </div>
    <div class="mx-auto mt-16 max-w-[85%] px-4 text-sm text-[#a0a0a0] sm:px-6 lg:px-8 border-t border-white/5 pt-8 text-center sm:text-left flex flex-col sm:flex-row justify-between items-center gap-4">
      <p id="dyn-footer-copyright">2026 &copy; Apriprogram. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </footer>

  <script>
    const html = document.documentElement;
    const toggleBtn = document.getElementById('darkModeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const mainHeader = document.getElementById('mainHeader');

    // Header scroll effect
    window.addEventListener('scroll', () => {
      if (window.scrollY > 60) {
        mainHeader.classList.add('header-scrolled');
      } else {
        mainHeader.classList.remove('header-scrolled');
      }
    });

    // Init theme based on localstorage
    if (localStorage.theme === 'light') {
      html.classList.remove('dark');
      sunIcon.classList.add('hidden');
      moonIcon.classList.remove('hidden');
    } else {
      html.classList.add('dark');
    }

    toggleBtn.addEventListener('click', () => {
      if (html.classList.contains('dark')) {
        html.classList.remove('dark');
        localStorage.theme = 'light';
        sunIcon.classList.add('hidden');
        moonIcon.classList.remove('hidden');
      } else {
        html.classList.add('dark');
        localStorage.theme = 'dark';
        moonIcon.classList.add('hidden');
        sunIcon.classList.remove('hidden');
      }
    });

    // Mobile Menu Script
    const mobileMenuButton = document.getElementById('mobileMenuButton');
    const mobileMenu = document.getElementById('mobileMenu');
    if(mobileMenuButton && mobileMenu) {
      const mobileNavLinks = mobileMenu.querySelectorAll('a');

      mobileMenuButton.addEventListener('click', () => {
        mobileMenu.classList.toggle('opacity-0');
        mobileMenu.classList.toggle('scale-95');
        mobileMenu.classList.toggle('pointer-events-none');
        
        mobileMenu.classList.toggle('opacity-100');
        mobileMenu.classList.toggle('scale-100');
        mobileMenu.classList.toggle('pointer-events-auto');
      });

      mobileNavLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
          mobileMenu.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
        });
      });
    }

    // Animated script to toggle FAQ is now bound dynamically in renderFaq function

    // Scroll typing and fade animation for carousel cards
    const cards = document.querySelectorAll('.carousel-card');
    const observerOptions = {
      root: document.getElementById('productCarousel'), // observe inside carousel
      threshold: 0.6 // trigger when 60% visible
    };
    
    // Fallback if root isn't perfect
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const fadeElems = entry.target.querySelectorAll('.fade-element');
          fadeElems.forEach(el => {
            el.classList.remove('opacity-0', 'translate-y-4');
          });
        } else {
          // Reset animation when scrolled away
          const fadeElems = entry.target.querySelectorAll('.fade-element');
          fadeElems.forEach(el => {
            el.classList.add('opacity-0', 'translate-y-4');
          });
        }
      });
    }, observerOptions);
    cards.forEach(card => observer.observe(card));

    // Scrollspy for Navbar links
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('nav a[data-nav-link]');
    
    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;
        if (scrollY >= (sectionTop - 150)) {
          current = section.getAttribute('id');
        }
      });

      navLinks.forEach(link => {
        link.classList.remove('text-white');
        link.classList.add('text-slate-300');
        if (link.getAttribute('href').includes(current)) {
          link.classList.remove('text-slate-300');
          link.classList.add('text-white');
        }
      });
    });
    });


    // Content Reveal Animation
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
          // revealObserver.unobserve(entry.target); // Optional: animate only once
        }
      });
    }, { threshold: 0.1 });

    const contentElements = document.querySelectorAll('main h1, main h2, main h3, main p, main img, main .rounded-2xl, main a, footer img, footer p, footer a, footer span, footer h3');
    
    let delayCounter = 0;
    contentElements.forEach((el, index) => {
      if (!el.classList.contains('fade-element') && !el.closest('header') && !el.classList.contains('no-reveal')) {
        el.classList.add('reveal-element');
        el.style.transitionDelay = `${(index % 6) * 100}ms`;
        revealObserver.observe(el);
      }
    });


    function escapeServiceHtml(value) {
      return String(value || '').replace(/[&<>'"]/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[char]));
    }

    function formatServicePublishDate(value) {
      if (!value) return '';
      const parsed = new Date(value);
      if (Number.isNaN(parsed.getTime())) return value;
      return parsed.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }


    function renderServiceCarousel(serviceItems) {
      const carousel = document.getElementById('newServiceCarousel');
      if (!carousel || !serviceItems || serviceItems.length === 0) return;
      const activeServices = serviceItems
        .filter(service => (service.status || 'active') === 'active')
        .sort((a, b) => (Number(a.sort_order) || 0) - (Number(b.sort_order) || 0));
      if (activeServices.length === 0) return;
      carousel.innerHTML = activeServices.map(service => `
        <div class="shrink-0 w-[85vw] md:w-[45vw] lg:w-[23vw] snap-start flex flex-col gap-4 sm:gap-6 cursor-pointer group">
          <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-xl sm:rounded-2xl overflow-hidden bg-slate-100 dark:bg-[#1a1a1a]">
            <img src="${escapeServiceHtml(service.image)}" alt="${escapeServiceHtml(service.title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 no-reveal" />
          </div>
          <div class="flex flex-col gap-1.5">
            <h3 class="text-lg sm:text-[1.35rem] font-normal text-slate-900 dark:text-white leading-snug">${escapeServiceHtml(service.title)}</h3>
            <p class="text-xs sm:text-[13px] text-slate-500 dark:text-[#a0a0a0] mt-1 sm:mt-2 tracking-wide">${escapeServiceHtml(formatServicePublishDate(service.publish_date))} &nbsp;&nbsp; ${escapeServiceHtml(service.category)}</p>
            <a href="${escapeServiceHtml(service.button_link || '#contact')}" class="text-xs sm:text-sm font-medium text-slate-900 dark:text-white group-hover:underline mt-1 flex items-center gap-1">${escapeServiceHtml(service.button_text || 'Read details')} &gt;</a>
          </div>
        </div>
      `).join('') + '<div class="shrink-0 w-1"></div>';
    }

    function renderProjectCarousel(projectItems) {
      const carousel = document.getElementById('productCarousel');
      if (!carousel || !projectItems || projectItems.length === 0) return;
      const activeProjects = projectItems
        .filter(project => (project.status || 'active') === 'active')
        .sort((a, b) => (Number(a.sort_order) || 0) - (Number(b.sort_order) || 0));
      if (activeProjects.length === 0) return;
      
      carousel.innerHTML = activeProjects.map(project => `
        <div class="shrink-0 w-[85vw] md:w-[50vw] lg:w-[45vw] snap-start flex flex-col gap-6 carousel-card">
          <div class="relative w-full aspect-[4/3] sm:aspect-video rounded-xl sm:rounded-[2rem] overflow-hidden bg-slate-100 dark:bg-[#1a1a1a]">
            <img src="${escapeServiceHtml(project.image)}" alt="${escapeServiceHtml(project.image_alt || project.title)}" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-5 left-5 sm:bottom-10 sm:left-10">
              <h3 class="text-xl sm:text-4xl font-semibold text-white tracking-tight">${escapeServiceHtml(project.title)}</h3>
            </div>
          </div>
          <div class="flex flex-col gap-2 pl-2">
            <h4 class="text-lg font-semibold text-slate-900 dark:text-white fade-element translate-y-4 transition-all duration-700">${escapeServiceHtml(project.title)}</h4>
            <p class="text-slate-600 dark:text-[#a0a0a0] text-sm max-w-sm leading-relaxed fade-element translate-y-4 transition-all duration-700 delay-150">
              ${escapeServiceHtml(project.short_description)}
            </p>
            <a href="${escapeServiceHtml(project.detail_url || project.project_url || '#')}" class="text-sm font-semibold text-slate-900 dark:text-white hover:text-brand-blue transition-colors mt-2 flex items-center gap-1 fade-element translate-y-4 transition-all duration-700 delay-300">
              ${escapeServiceHtml(project.button_text || 'Lihat detail')} <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
          </div>
        </div>
      `).join('') + '<div class="shrink-0 w-1"></div>';

      setTimeout(() => {
        const elements = carousel.querySelectorAll('.fade-element');
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('opacity-100', 'translate-y-0');
                entry.target.classList.remove('opacity-0', 'translate-y-4');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });
          
          elements.forEach(el => {
            el.classList.add('opacity-0');
            observer.observe(el);
          });
        } else {
          elements.forEach(el => {
            el.classList.add('opacity-100', 'translate-y-0');
            el.classList.remove('opacity-0', 'translate-y-4');
          });
        }
      }, 100);
    }

    function renderTimeline(timelineItems) {
      const container = document.getElementById('timelineContainer');
      if (!container || !timelineItems || timelineItems.length === 0) return;
      const activeItems = timelineItems.filter(t => t.status === 'active').sort((a,b) => (Number(a.sort_order) || 0) - (Number(b.sort_order) || 0));
      
      container.innerHTML = activeItems.map((t, index) => {
        const isLeft = index % 2 === 0;
        return `
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
            <div class="${isLeft ? 'order-2 lg:order-1' : 'order-2 lg:order-2'} flex items-center justify-center relative">
               <img src="${escapeServiceHtml(t.image)}" alt="${escapeServiceHtml(t.image_alt || t.title)}" class="w-full h-auto object-cover rounded-2xl border border-slate-200 dark:border-[#222222]" onerror="this.style.display='none'"/>
            </div>
            <div class="${isLeft ? 'order-1 lg:order-2 lg:ml-auto' : 'order-1 lg:order-1 lg:mr-auto'} flex flex-col gap-3 sm:gap-5 max-w-lg mx-auto lg:mx-0">
              <div class="flex items-center gap-2 text-xs sm:text-sm font-semibold text-slate-500 dark:text-[#a0a0a0]">
                ${t.icon || ''}
                ${escapeServiceHtml(t.step_label || `Step ${t.step_number}`)}
              </div>
              <h3 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-slate-900 dark:text-white leading-tight">${escapeServiceHtml(t.title)}</h3>
              <p class="text-sm sm:text-base text-slate-600 dark:text-[#a0a0a0] leading-relaxed">
                ${escapeServiceHtml(t.description || t.short_description)}
              </p>
              ${t.button_link ? `
              <a href="${escapeServiceHtml(t.button_link)}" class="text-xs sm:text-sm font-medium text-brand-blue hover:text-blue-600 mt-1 sm:mt-2 flex items-center gap-1 transition-colors">${escapeServiceHtml(t.button_text || 'Learn More')} <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></a>
              ` : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    function renderFaq(faqItems) {
      const container = document.getElementById('faqContainer');
      if (!container || !faqItems || faqItems.length === 0) return;

      const activeItems = faqItems.filter(item => item.status === 'active').sort((a,b) => (Number(a.sort_order) || 0) - (Number(b.sort_order) || 0));
      
      let html = '';
      activeItems.forEach(item => {
        html += `
          <div class="faq-item rounded-2xl border border-slate-200 dark:border-white/5 bg-slate-50 dark:bg-[#0a0a0a]">
            <button type="button" class="flex w-full items-center justify-between gap-3 sm:gap-4 p-4 sm:p-6 text-left font-medium text-base sm:text-xl text-slate-900 dark:text-white">
              ${escapeServiceHtml(item.question)}
              <svg class="w-5 h-5 text-slate-600 dark:text-[#a0a0a0] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </button>
            <div class="faq-content grid transition-all duration-300 grid-rows-[0fr] opacity-0">
              <div class="overflow-hidden">
                <div class="px-4 pb-4 sm:px-6 sm:pb-6 text-sm sm:text-lg leading-relaxed text-slate-600 dark:text-[#a0a0a0]">
                  ${String(item.answer || '').replace(/\n/g, '<br>')}
                </div>
              </div>
            </div>
          </div>
        `;
      });
      container.innerHTML = html;

      // Bind toggle event
      container.querySelectorAll('.faq-item button').forEach(button => {
        button.addEventListener('click', () => {
          const content = button.nextElementSibling;
          const icon = button.querySelector('svg');
          
          const isOpen = content.classList.contains('grid-rows-[1fr]');
          
          if (isOpen) {
            content.classList.remove('grid-rows-[1fr]', 'opacity-100');
            content.classList.add('grid-rows-[0fr]', 'opacity-0');
            icon.style.transform = 'rotate(0deg)';
          } else {
            content.classList.remove('grid-rows-[0fr]', 'opacity-0');
            content.classList.add('grid-rows-[1fr]', 'opacity-100');
            icon.style.transform = 'rotate(180deg)';
          }
        });
      });
    }

    // Fetch Settings and Apply
    fetch('/api/settings').then(r => r.json()).then(data => {
      if (data.success && data.settings) {
        if (data.settings.hero) {
          try {
            if (data.settings.hero.title_main) document.getElementById('dyn-hero-title_main').innerHTML = data.settings.hero.title_main;
            if (data.settings.hero.title_gradient) document.getElementById('dyn-hero-title_gradient').innerHTML = data.settings.hero.title_gradient;
            if (data.settings.hero.subtitle) document.getElementById('dyn-hero-subtitle').innerHTML = data.settings.hero.subtitle;
            if (data.settings.hero.cta_text) {
              const btn = document.getElementById('dyn-hero-cta');
              if (btn) {
                btn.innerHTML = data.settings.hero.cta_text;
                if (data.settings.hero.cta_link) btn.href = data.settings.hero.cta_link;
              }
            }
            if (data.settings.hero.backgrounds_data) {
              try {
                const bgArr = JSON.parse(data.settings.hero.backgrounds_data);
                if (Array.isArray(bgArr) && bgArr.length > 0) {
                  initHeroBackgroundSlider(bgArr);
                }
              } catch(e) {}
            }
          } catch(e) { console.error('Error applying hero settings:', e); }
        }
        if (data.settings.cta) {
          try {
            if (data.settings.cta.title) document.getElementById('dyn-cta-title').innerHTML = data.settings.cta.title;
            if (data.settings.cta.subtitle) document.getElementById('dyn-cta-subtitle').innerHTML = data.settings.cta.subtitle;
            if (data.settings.cta.button_text) {
              const btn = document.getElementById('dyn-cta-button');
              if (btn) {
                btn.innerHTML = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              ${data.settings.cta.button_text}`;
              }
            }
          } catch(e) { console.error('Error applying cta settings:', e); }
        }
        if (data.settings.footer) {
          try {
            if (data.settings.footer.description) {
              const el = document.getElementById('dyn-footer-description');
              if (el) el.innerHTML = data.settings.footer.description;
            }
            if (data.settings.footer.copyright) {
              const copyEl = document.getElementById('dyn-footer-copyright');
              if (copyEl) copyEl.innerHTML = data.settings.footer.copyright;
            }
          } catch(e) { console.error('Error applying footer settings:', e); }
        }
        
        // Additional Sections (Optional application if IDs exist)
        if (data.settings.navbar) {
          if (data.settings.navbar.logo_text) {
            const logoText = document.querySelector('nav a[href="#home"] span');
            if(logoText) logoText.innerHTML = data.settings.navbar.logo_text;
          }
          if (data.settings.navbar.logo_image) {
            const logoImg = document.querySelector('nav a[href="#home"] img');
            if (logoImg) logoImg.src = data.settings.navbar.logo_image;
          }
          if (data.settings.navbar.nav_links_data) {
            try {
              const navLinks = JSON.parse(data.settings.navbar.nav_links_data);
              if (Array.isArray(navLinks) && navLinks.length > 0) {
                const desktopMenu = document.getElementById('dyn-desktop-menu');
                const mobileMenuLinks = document.getElementById('dyn-mobile-links');
                
                if (desktopMenu) {
                  desktopMenu.innerHTML = navLinks.map(link => 
                    `<a data-nav-link href="${link.url}" class="nav-link hover:text-white transition-colors text-slate-300 ${link.url === '#home' ? 'text-white' : ''}">${link.text}</a>`
                  ).join('');
                }
                
                if (mobileMenuLinks) {
                  mobileMenuLinks.innerHTML = navLinks.map(link => 
                    `<a data-nav-link href="${link.url}" class="hover:text-brand-blue dark:hover:text-white transition-colors">${link.text}</a>`
                  ).join('');
                  
                  // Re-bind click event to close mobile menu
                  const mobileMenuNode = document.getElementById('mobileMenu');
                  mobileMenuLinks.querySelectorAll('a').forEach(link => {
                    link.addEventListener('click', () => {
                      mobileMenuNode.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
                      mobileMenuNode.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto');
                    });
                  });
                }
                
                // Update scrollspy sections
                const allNavLinks = document.querySelectorAll('nav a[data-nav-link]');
                const sections = document.querySelectorAll('section[id]');
                window.addEventListener('scroll', () => {
                  let current = '';
                  sections.forEach(section => {
                    const sectionTop = section.offsetTop;
                    if (scrollY >= (sectionTop - 150)) {
                      current = section.getAttribute('id');
                    }
                  });
                  allNavLinks.forEach(link => {
                    link.classList.remove('text-white');
                    link.classList.add('text-slate-300');
                    if (link.getAttribute('href').includes(current)) {
                      link.classList.remove('text-slate-300');
                      link.classList.add('text-white');
                    }
                  });
                });
              }
            } catch(e) { console.error(e); }
          }
        }
        if (data.settings.services) {
          try {
            const srvTitle = document.querySelector('#services h2');
            const srvDesc = document.querySelector('#services p');
            const srvButton = document.getElementById('dyn-services-button');
            if(srvTitle && data.settings.services.title) srvTitle.innerHTML = data.settings.services.title;
            if(srvDesc && data.settings.services.subtitle) srvDesc.innerHTML = data.settings.services.subtitle;
            if(srvButton && data.settings.services.button_text) srvButton.innerHTML = data.settings.services.button_text;
            if(srvButton && data.settings.services.button_link) srvButton.href = data.settings.services.button_link;
          } catch(e) { console.error('Error applying services settings:', e); }
        }
        if (data.settings.service_items) {
          renderServiceCarousel(Object.values(data.settings.service_items));
        }
        if (data.settings.projects) {
          try {
            const prjTitle = document.querySelector('#project h2');
            const prjDesc = document.querySelector('#project p');
            if(prjTitle && data.settings.projects.title) prjTitle.innerHTML = data.settings.projects.title;
            if(prjDesc && data.settings.projects.subtitle) prjDesc.innerHTML = data.settings.projects.subtitle;
          } catch(e) { console.error('Error applying projects settings:', e); }
        }
        if (data.settings.project_items) {
          renderProjectCarousel(Object.values(data.settings.project_items));
        }
        if (data.settings.timeline) {
          try {
            const tmTitle = document.querySelector('.timeline-section h2') || document.querySelectorAll('main section')[3]?.querySelector('h2');
            const tmDesc = document.querySelector('.timeline-section p') || document.querySelectorAll('main section')[3]?.querySelector('p');
            if(tmTitle && data.settings.timeline.title) tmTitle.innerHTML = data.settings.timeline.title;
            if(tmDesc && data.settings.timeline.subtitle) tmDesc.innerHTML = data.settings.timeline.subtitle;
          } catch(e) { console.error('Error applying timeline settings:', e); }
        }
        if (data.settings.timeline_items) {
          renderTimeline(Object.values(data.settings.timeline_items));
        }
        if (data.settings.faq) {
          try {
            const faqTitle = document.getElementById('dyn-faq-title');
            const faqDesc = document.getElementById('dyn-faq-subtitle');
            const faqBtn = document.getElementById('dyn-faq-button');
            if(faqTitle && data.settings.faq.title) faqTitle.innerHTML = data.settings.faq.title;
            if(faqDesc && data.settings.faq.subtitle) faqDesc.innerHTML = data.settings.faq.subtitle;
            if(faqBtn && data.settings.faq.button_text) {
              const btnText = faqBtn.querySelector('#dyn-faq-button-text');
              if(btnText) btnText.innerHTML = data.settings.faq.button_text;
              else faqBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg> <span id="dyn-faq-button-text">${data.settings.faq.button_text}</span>`;
            }
            if(faqBtn && data.settings.faq.button_link) faqBtn.href = data.settings.faq.button_link;
          } catch(e) { console.error('Error applying faq settings:', e); }
        }
        if (data.settings.faq_items) {
          renderFaq(Object.values(data.settings.faq_items));
        }
      }
    }).catch(console.error);
  </script>
</body>
</html>


