<!DOCTYPE html>
<html lang="id" class="scroll-smooth dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="8I6QUAg1wwrproClJ91FGsSoDu0CkLSbdtIz1yxXrRY" />
  <meta name="description" content="Apriprogram adalah jasa pembuatan website custom untuk bisnis, sekolah, UMKM, dan sistem operasional digital.">
  <title>Apriprogram - Jasa Pembuatan Website Custom</title>
  <link rel="icon" href="/assets/logo/favicon.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          fontFamily: {
            sans: ['Poppins', 'sans-serif'],
          },
          colors: {
            brand: {
              blue: "#243CFF",
              cyan: "#22D3EE",
              ink: "#050b14",
              card: "#0a111f"
            }
          }
        }
      }
    };
  </script>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    
    .hero-glow {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 100vw;
      height: 100vh;
      background: radial-gradient(circle at 50% -20%, rgba(36, 60, 255, 0.4), transparent 70%);
      z-index: -1;
      pointer-events: none;
    }
    .hero-lines {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(circle at top left, transparent 20%, rgba(255,255,255,0.03) 21%, transparent 22%),
        radial-gradient(circle at top right, transparent 20%, rgba(255,255,255,0.03) 21%, transparent 22%);
      background-size: 100% 100%;
      z-index: -1;
      pointer-events: none;
    }
    
    .reveal-element {
      opacity: 0;
      filter: blur(10px);
      transform: translateY(40px) scale(0.95);
      transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: opacity, transform, filter;
    }
    .reveal-element.active {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0) scale(1);
    }

    /* Premium Hover Interactions */
    a.bg-brand-blue, a[href="#contact"], .bg-transparent[href="#contact"] {
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) !important;
    }
    a.bg-brand-blue:hover, a[href="#contact"]:hover, .bg-transparent[href="#contact"]:hover {
      transform: translateY(-4px) scale(1.03);
      box-shadow: 0 20px 40px -10px rgba(56, 189, 248, 0.4) !important;
    }
    a.bg-brand-blue:active, a[href="#contact"]:active, .bg-transparent[href="#contact"]:active {
      transform: translateY(0) scale(0.97);
    }

    .rounded-2xl, .faq-item {
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .rounded-2xl:hover, .faq-item:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.15);
      z-index: 10;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-900 dark:bg-slate-50 dark:bg-[#0a0a0a] dark:text-slate-50 antialiased selection:bg-brand-blue selection:text-white">
  <!-- Removed hero-glow and hero-lines as background image is used in hero section -->

  <header class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-[#050b14]/60 backdrop-blur-lg transition-all duration-300" id="mainHeader">
    <nav class="mx-auto flex h-16 max-w-[85%] items-center justify-between px-4 sm:px-6">
      <a href="#home" class="flex items-center gap-3" aria-label="Apriprogram">
        <img src="/assets/logo/apriprogram.png" alt="Apriprogram Logo" class="h-6 sm:h-8 w-auto" />
        <span class="nav-text text-base sm:text-lg font-medium tracking-tight text-white transition-colors duration-300">Apriprogram</span>
      </a>

      <div id="dyn-desktop-menu" class="hidden items-center gap-8 text-sm font-semibold text-slate-300 lg:flex">
        <a data-nav-link href="#home" class="nav-link hover:text-white transition-colors">Home</a>
        <a data-nav-link href="#services" class="nav-link hover:text-white transition-colors">Layanan</a>
        <a data-nav-link href="#project" class="nav-link hover:text-white transition-colors">Project</a>
        <a data-nav-link href="#faq" class="nav-link hover:text-white transition-colors">FAQ</a>
        <a data-nav-link href="#contact" class="nav-link hover:text-white transition-colors">Kontak</a>
      </div>

      <div class="flex items-center gap-4">
        <button id="darkModeToggle" class="p-1 sm:p-2 text-slate-300 hover:text-white transition-colors" aria-label="Toggle Dark Mode">
          <!-- Moon Icon (for light mode) -->
          <svg id="moonIcon" class="w-4 h-4 sm:w-5 sm:h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
          <!-- Sun Icon (for dark mode) -->
          <svg id="sunIcon" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
        </button>

        <div class="hidden items-center gap-3 lg:flex">
          <% if (user && user.userId) { %>
            <a href="<%= (user.role === 'admin' || user.role === 'super admin') ? '/admin/dashboard' : '/order' %>" class="nav-link text-sm font-semibold text-slate-300 hover:text-white transition-colors mr-2">Dasbor</a>
            <a href="/logout" class="nav-link text-sm font-semibold text-slate-300 hover:text-white transition-colors mr-2">Logout</a>
          <% } else { %>
            <a href="/login" class="nav-link text-sm font-semibold text-slate-300 hover:text-white transition-colors mr-2">Login</a>
          <% } %>
        </div>

        <button id="mobileMenuButton" type="button" class="inline-flex p-1 sm:p-2 flex-col items-center justify-center gap-[3px] sm:gap-1.5 lg:hidden text-slate-300 hover:text-white transition-colors" aria-label="Buka menu">
          <span class="h-[2px] w-4 sm:w-5 rounded bg-white transition-colors"></span>
          <span class="h-[2px] w-4 sm:w-5 rounded bg-white transition-colors"></span>
          <span class="h-[2px] w-4 sm:w-5 rounded bg-white transition-colors"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile Menu Dropdown -->
    <div id="mobileMenu" class="absolute top-[72px] inset-x-4 z-40 flex flex-col bg-white dark:bg-[#0a0a0a] border border-slate-200 dark:border-white/10 p-6 rounded-2xl shadow-2xl lg:hidden opacity-0 scale-95 pointer-events-none transition-all duration-300 origin-top">
      <div class="flex flex-col gap-4 text-sm font-medium text-slate-900 dark:text-slate-300">
        <div id="dyn-mobile-links" class="flex flex-col gap-4">
          <a data-nav-link href="#home" class="hover:text-brand-blue dark:hover:text-white transition-colors">Home</a>
          <a data-nav-link href="#services" class="hover:text-brand-blue dark:hover:text-white transition-colors">Layanan</a>
          <a data-nav-link href="#project" class="hover:text-brand-blue dark:hover:text-white transition-colors">Project</a>
          <a data-nav-link href="#faq" class="hover:text-brand-blue dark:hover:text-white transition-colors">FAQ</a>
          <a data-nav-link href="#contact" class="hover:text-brand-blue dark:hover:text-white transition-colors">Kontak</a>
        </div>
        <div class="h-px w-full bg-slate-200 dark:bg-white/10 my-2"></div>
        <% if (user && user.userId) { %>
          <a href="<%= (user.role === 'admin' || user.role === 'super admin') ? '/admin/dashboard' : '/order' %>" class="hover:text-brand-blue dark:hover:text-white transition-colors">Dasbor</a>
          <a href="/logout" class="text-red-500 dark:text-red-400 hover:text-red-600 dark:hover:text-red-300 transition-colors">Logout</a>
        <% } else { %>
          <a href="/login" class="hover:text-brand-blue dark:hover:text-white transition-colors">Login</a>
        <% } %>
      </div>
    </div>
  </header>

  <main>
    <section id="home" class="relative flex min-h-screen flex-col items-center justify-center text-center pt-24 sm:pt-32 pb-20 overflow-hidden">
      <!-- Dynamic Background Carousel Container -->
      <div id="hero-bg-slider" class="absolute inset-0 z-[-1]">
        <!-- Fallback static background -->
        <img src="/assets/hero/bg_herosetion.png" alt="Hero Background" class="absolute inset-0 w-full h-full object-cover object-top opacity-100 no-reveal transition-opacity duration-1000 bg-slide active" />
        <div class="absolute inset-0 bg-gradient-to-b from-slate-900/10 via-transparent to-slate-900/60 z-10"></div>
      </div>

      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 flex flex-col items-center relative z-10 font-sans">
        <div class="mb-4 sm:mb-5 inline-flex items-center gap-2.5 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 sm:px-5 sm:py-2 text-[9px] sm:text-xs font-medium uppercase tracking-[0.15em] text-white backdrop-blur-md">
          Jasa Pembuatan Website Custom
        </div>
        <h1 class="mx-auto w-full text-2xl font-normal leading-tight tracking-tight sm:text-5xl lg:text-6xl mb-3 text-white">
          <span class="inline-block" id="dyn-hero-title_main">Website Profesional Untuk</span> <br>
          <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-brand-cyan" id="dyn-hero-title_gradient">Meningkatkan Bisnis Anda</span>
        </h1>
        <p class="mt-2 max-w-3xl text-xs sm:text-lg leading-relaxed text-[#a0a0a0]" id="dyn-hero-subtitle">
          Membantu Anda membangun landing page, toko online, hingga sistem operasional custom. Desain responsif, SEO-friendly, dan dikembangkan khusus untuk pertumbuhan bisnis Anda.
        </p>
        <div class="mt-6 flex justify-center">
          <a href="/login" id="dyn-hero-cta" class="rounded-lg bg-brand-blue px-5 py-2.5 sm:px-6 sm:py-2.5 text-xs sm:text-sm font-semibold text-white hover:bg-blue-600 transition-all w-full sm:w-auto text-center">
            Pesan Sekarang
          </a>
        </div>
      </div>
      
      <!-- Space for Image below button -->
      <div class="mx-auto mt-12 w-full max-w-[85%] px-4 relative z-10">
         <!-- Mockup container -->
         <div class="relative w-full rounded-xl sm:rounded-3xl p-0 overflow-hidden flex justify-center">
           <img src="/assets/hero/hero_konten.jpg" alt="Dashboard Mockup" class="w-full h-auto max-w-none rounded-xl sm:rounded-3xl shadow-2xl border-[3px] border-white/20" />
         </div>
      </div>
    </section>

    <!-- New Service Section (Google Blog Style) -->
    <style>#newServiceCarousel::-webkit-scrollbar { display: none; }</style>
    <section id="services" class="py-24 bg-white dark:bg-[#0a0a0a] transition-colors border-b border-slate-200 dark:border-white/5">
      <div class="mx-auto max-w-[85%] px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col md:flex-row gap-8 lg:gap-20 justify-between items-start mb-16">
          <h2 class="text-3xl sm:text-5xl lg:text-[4.5rem] tracking-tight font-normal text-slate-900 dark:text-white max-w-2xl leading-[1.05]">
            Our services<br>to help you
          </h2>
          <div class="flex flex-col items-start md:items-end gap-4 sm:gap-6 max-w-md pt-2">
             <p class="text-sm sm:text-base text-slate-600 dark:text-[#a0a0a0] leading-relaxed md:text-right">
               Kami menyediakan berbagai layanan digital profesional, mulai dari desain antarmuka hingga pengembangan sistem yang dirancang khusus untuk pertumbuhan bisnis Anda.
             </p>
             <a href="#contact" id="dyn-services-button" class="px-5 py-2.5 rounded-full border border-slate-200 dark:border-white/5 hover:bg-slate-50 dark:hover:bg-white/5 text-sm font-medium transition-colors hidden sm:block text-slate-900 dark:text-white">View all services</a>
          </div>
        </div>
        
        <div id="newServiceCarousel" class="flex overflow-x-auto gap-4 sm:gap-6 lg:gap-6 snap-x snap-mandatory pb-6" style="-ms-overflow-style: none; scrollbar-width: none;">
          <!-- Card 1 -->
          <div class="shrink-0 w-[85vw] md:w-[45vw] lg:w-[23vw] snap-start flex flex-col gap-6 cursor-pointer group">
            <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-2xl overflow-hidden bg-slate-100 dark:bg-[#1a1a1a]">
               <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=600&q=80" alt="Website Company Profile" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="text-lg sm:text-[1.35rem] font-normal text-slate-900 dark:text-white leading-snug">Website Company Profile</h3>
              <p class="text-xs sm:text-[13px] text-slate-500 dark:text-[#a0a0a0] mt-1 sm:mt-2 tracking-wide">May 19, 2026 &nbsp;&nbsp; Web Design</p>
              <a href="#" class="text-xs sm:text-sm font-medium text-slate-900 dark:text-white group-hover:underline mt-1 flex items-center gap-1">Read details &gt;</a>
            </div>
          </div>
          <!-- Card 2 -->
          <div class="shrink-0 w-[85vw] md:w-[45vw] lg:w-[23vw] snap-start flex flex-col gap-4 sm:gap-6 cursor-pointer group">
            <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-xl sm:rounded-2xl overflow-hidden bg-slate-100 dark:bg-[#1a1a1a]">
               <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=600&q=80" alt="Web App Dashboard" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="text-lg sm:text-[1.35rem] font-normal text-slate-900 dark:text-white leading-snug">Aplikasi Web & Dashboard</h3>
              <p class="text-xs sm:text-[13px] text-slate-500 dark:text-[#a0a0a0] mt-1 sm:mt-2 tracking-wide">May 20, 2026 &nbsp;&nbsp; Web App</p>
              <a href="#" class="text-xs sm:text-sm font-medium text-slate-900 dark:text-white group-hover:underline mt-1 flex items-center gap-1">Read details &gt;</a>
            </div>
          </div>
          <!-- Card 3 -->
          <div class="shrink-0 w-[85vw] md:w-[45vw] lg:w-[23vw] snap-start flex flex-col gap-4 sm:gap-6 cursor-pointer group">
            <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-xl sm:rounded-2xl overflow-hidden bg-slate-100 dark:bg-[#1a1a1a]">
               <img src="https://images.unsplash.com/photo-1522199755839-a2bacb67c546?auto=format&fit=crop&w=600&q=80" alt="Toko Online" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="text-lg sm:text-[1.35rem] font-normal text-slate-900 dark:text-white leading-snug">Toko Online Custom</h3>
              <p class="text-xs sm:text-[13px] text-slate-500 dark:text-[#a0a0a0] mt-1 sm:mt-2 tracking-wide">May 21, 2026 &nbsp;&nbsp; E-Commerce</p>
              <a href="#" class="text-xs sm:text-sm font-medium text-slate-900 dark:text-white group-hover:underline mt-1 flex items-center gap-1">Read details &gt;</a>
            </div>
          </div>
          <!-- Card 4 -->
          <div class="shrink-0 w-[85vw] md:w-[45vw] lg:w-[23vw] snap-start flex flex-col gap-4 sm:gap-6 cursor-pointer group">
            <div class="relative w-full aspect-[4/3] sm:aspect-square rounded-xl sm:rounded-2xl overflow-hidden bg-slate-100 dark:bg-[#1a1a1a]">
               <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=600&q=80" alt="SEO Optimization" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="flex flex-col gap-1.5">
              <h3 class="text-lg sm:text-[1.35rem] font-normal text-slate-900 dark:text-white leading-snug">SEO Optimization</h3>
              <p class="text-xs sm:text-[13px] text-slate-500 dark:text-[#a0a0a0] mt-1 sm:mt-2 tracking-wide">May 22, 2026 &nbsp;&nbsp; Marketing</p>
              <a href="#" class="text-xs sm:text-sm font-medium text-slate-900 dark:text-white group-hover:underline mt-1 flex items-center gap-1">Read details &gt;</a>
            </div>
          </div>
          <!-- Spacer -->
          <div class="shrink-0 w-1"></div>
        </div>

        <!-- Arrows Bottom -->
        <div class="flex gap-4 mt-8">
           <button onclick="document.getElementById('newServiceCarousel').scrollBy({left: -300, behavior: 'smooth'})" class="w-12 h-12 rounded-full border border-slate-200 dark:border-white/5 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
             <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-slate-900 dark:text-white"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
           </button>
           <button onclick="document.getElementById('newServiceCarousel').scrollBy({left: 300, behavior: 'smooth'})" class="w-12 h-12 rounded-full border border-slate-200 dark:border-white/5 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
             <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-slate-900 dark:text-white"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
           </button>
        </div>
      </div>
    </section>

    <!-- Solusi Produk Kami (Now Projects) -->
    <section id="project" class="relative py-24 z-10 bg-slate-50 dark:bg-[#0a0a0a] transition-colors">
      <div class="mx-auto max-w-[85%] px-4 sm:px-6 lg:px-8">
        
        <!-- Header Section -->
        <div class="flex flex-col md:flex-row gap-6 sm:gap-8 lg:gap-20 justify-between items-start mb-10 sm:mb-16">
          <h2 class="text-3xl sm:text-5xl lg:text-[4.5rem] tracking-tight font-normal text-slate-900 dark:text-white max-w-2xl leading-[1.05]">
            Our projects
          </h2>
          <div class="flex flex-col items-start md:items-end gap-4 sm:gap-6 max-w-md pt-2">
             <p class="text-sm sm:text-base text-slate-600 dark:text-[#a0a0a0] leading-relaxed md:text-right">
               Apriprogram is built for user trust, whether you're a growing startup building a new digital presence, a large enterprise, or anyone in between.
             </p>
             <!-- Global Navigation Arrows -->
             <div class="flex gap-4">
               <button onclick="document.getElementById('productCarousel').scrollBy({left: -400, behavior: 'smooth'})" class="w-12 h-12 rounded-full border border-slate-200 dark:border-white/5 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
                 <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-slate-900 dark:text-white"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
               </button>
               <button onclick="document.getElementById('productCarousel').scrollBy({left: 400, behavior: 'smooth'})" class="w-12 h-12 rounded-full border border-slate-200 dark:border-white/5 flex items-center justify-center hover:bg-slate-100 dark:hover:bg-white/5 transition-colors">
                 <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" class="text-slate-900 dark:text-white"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
               </button>
             </div>
          </div>
        </div>

        <!-- Carousel Container -->
        <div class="relative w-full -mx-4 sm:-mx-6 lg:-mx-8">
          <style>#productCarousel::-webkit-scrollbar { display: none; }</style>
          
          <!-- Scrollable Row -->
          <div id="productCarousel" class="flex overflow-x-auto gap-4 sm:gap-6 lg:gap-8 snap-x snap-mandatory pb-10 px-4 sm:px-6 lg:px-8" style="-ms-overflow-style: none; scrollbar-width: none;">
          </div>
      </div>
    </section>



    <!-- Timeline Developments -->
    <section class="py-24 relative overflow-hidden bg-white dark:bg-[#0a0a0a] border-t border-slate-200 dark:border-white/5">
      <div class="mx-auto max-w-[85%] px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-2xl mx-auto mb-16 sm:mb-24">
          <h2 class="text-3xl sm:text-5xl lg:text-[4.5rem] tracking-tight font-normal text-slate-900 dark:text-white leading-[1.05] mb-4 sm:mb-6">Timeline<br>Developments</h2>
          <p class="text-sm sm:text-base text-slate-600 dark:text-[#a0a0a0]">Step-by-step process of our general website development to ensure your project is delivered on time with high quality.</p>
        </div>

        <div id="timelineContainer" class="flex flex-col gap-16 sm:gap-24 lg:gap-32">
          <!-- Timeline items will be rendered here via JS -->
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="py-24 bg-white dark:bg-[#0a0a0a]">
      <div class="mx-auto grid max-w-[85%] gap-16 px-4 sm:px-6 lg:grid-cols-[1fr_1.5fr] lg:px-8">
        <div>
          <h2 class="text-3xl sm:text-5xl lg:text-[4.5rem] tracking-tight font-normal text-slate-900 dark:text-white leading-[1.05] mb-4" id="dyn-faq-title">Answers to your<br>top questions</h2>
          <p class="text-sm sm:text-lg text-slate-600 dark:text-[#a0a0a0] leading-relaxed mb-6 sm:mb-8" id="dyn-faq-subtitle">Pelajari lebih lanjut mengenai layanan kami, proses pengerjaan, dan apa yang bisa kami bantu untuk mengembangkan bisnis Anda secara digital.</p>
          <a href="#contact" id="dyn-faq-button" class="inline-flex items-center justify-center gap-2 rounded-full border border-slate-300 dark:border-white/20 bg-transparent px-4 py-2 sm:px-6 sm:py-3 text-xs sm:text-sm font-semibold text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
